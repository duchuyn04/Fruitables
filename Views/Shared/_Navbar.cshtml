@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<div class="container-fluid fixed-top">
    <div class="container topbar bg-primary d-none d-lg-block">
        <div class="d-flex justify-content-between">
            <div class="top-info ps-2">
                <small class="me-3"><i class="fas fa-map-marker-alt me-2 text-secondary"></i> <a href="#" class="text-white">Giao hàng tận nơi</a></small>
                <small class="me-3"><i class="fas fa-envelope me-2 text-secondary"></i><a href="#" class="text-white">Hỗ trợ khách hàng</a></small>
            </div>
            <div class="top-link pe-2">
                <a href="#" class="text-white"><small class="text-white mx-2">Chính sách bảo mật</small>/</a>
                <a href="#" class="text-white"><small class="text-white mx-2">Điều khoản sử dụng</small>/</a>
                <a href="#" class="text-white"><small class="text-white ms-2">Đổi trả và hoàn tiền</small></a>
            </div>
        </div>
    </div>
    <div class="container px-0">
        <nav class="navbar navbar-light bg-white navbar-expand-lg">
            <a asp-controller="Home" asp-action="Index" class="navbar-brand"><h1 class="text-primary display-6 m-0">Fruitables</h1></a>
            
            <div class="d-flex align-items-center order-lg-last ms-auto">
                <button class="btn-search btn border border-secondary btn-sm-square rounded-circle bg-white me-2 me-lg-4" data-bs-toggle="modal" data-bs-target="#searchModal" style="min-width: 44px; min-height: 44px;">
                    <i class="fas fa-search text-primary"></i>
                </button>
                <a asp-controller="Cart" asp-action="Index" class="position-relative me-3 me-lg-4 my-auto d-flex align-items-center" style="min-width: 44px; min-height: 44px;">
                    <i class="fa fa-shopping-bag fa-2x"></i>
                    <span class="position-absolute bg-secondary rounded-circle d-flex align-items-center justify-content-center text-dark px-1" style="top: -5px; left: 20px; height: 20px; min-width: 20px;">@(ViewBag.CartCount ?? 0)</span>
                </a>
                
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="dropdown me-2 me-lg-0">
                        <a href="#" class="my-auto dropdown-toggle text-dark text-decoration-none d-flex align-items-center" data-bs-toggle="dropdown" aria-expanded="false" style="min-height: 44px;">
                            @await Component.InvokeAsync("UserAvatar")
                            <span class="d-none d-lg-inline ms-2">@User.Identity.Name</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><span class="dropdown-item-text fw-bold">@User.Identity.Name</span></li>
                            <li><hr class="dropdown-divider"></li>
                            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                            {
                                <li>
                                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="dropdown-item text-primary fw-bold">
                                        <i class="fas fa-tachometer-alt me-2"></i>Trang quản trị
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                            }
                            <li>
                                <a asp-controller="Profile" asp-action="Index" class="dropdown-item">
                                    <i class="fas fa-user-circle me-2"></i>Thông tin cá nhân
                                </a>
                            </li>
                            <li>
                                <a asp-controller="Address" asp-action="Index" class="dropdown-item">
                                    <i class="fas fa-map-marker-alt me-2"></i>Địa chỉ của tôi
                                </a>
                            </li>
                            <li>
                                <a asp-controller="OrderHistory" asp-action="Index" class="dropdown-item">
                                    <i class="fas fa-shopping-bag me-2"></i>Lịch sử đơn hàng
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <div class="d-none d-lg-flex">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary me-2">Đăng nhập</a>
                        <a asp-controller="Account" asp-action="Register" class="btn btn-primary">Đăng ký</a>
                    </div>
                    <a asp-controller="Account" asp-action="Login" class="d-lg-none me-2 text-dark my-auto d-flex align-items-center justify-content-center" style="min-width: 44px; min-height: 44px;">
                        <i class="fas fa-user fa-2x"></i>
                    </a>
                }
                
                <button class="navbar-toggler py-2 px-3 ms-1" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" style="min-width: 44px; min-height: 44px;">
                    <span class="fa fa-bars text-primary"></span>
                </button>
            </div>

            <div class="collapse navbar-collapse bg-white" id="navbarCollapse">
                <div class="navbar-nav mx-auto">
                    <a asp-controller="Home" asp-action="Index" class="nav-item nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")">Trang chủ</a>
                    <a asp-controller="Shop" asp-action="Index" class="nav-item nav-link @(currentController == "Shop" && currentAction == "Index" ? "active" : "")">Cửa hàng</a>
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle @(currentController == "Cart" || currentController == "Checkout" || currentController == "Testimonial" ? "active" : "")" data-bs-toggle="dropdown">Tiện ích</a>
                        <div class="dropdown-menu m-0 rounded-0">
                            <a asp-controller="Cart" asp-action="Index" class="dropdown-item" style="min-height: 44px; display: flex; align-items: center;">Giỏ hàng</a>
                            <a asp-controller="Checkout" asp-action="Index" class="dropdown-item" style="min-height: 44px; display: flex; align-items: center;">Thanh toán</a>
                            <a asp-controller="Testimonial" asp-action="Index" class="dropdown-item" style="min-height: 44px; display: flex; align-items: center;">Đánh giá</a>
                            <a asp-controller="Home" asp-action="NotFound" class="dropdown-item" style="min-height: 44px; display: flex; align-items: center;">Trang lỗi 404</a>
                        </div>
                    </div>
                    <a asp-controller="Contact" asp-action="Index" class="nav-item nav-link @(currentController == "Contact" ? "active" : "")">Liên hệ</a>
                    
                    @if (User.Identity?.IsAuthenticated != true)
                    {
                        <div class="d-lg-none mt-4 d-flex flex-column gap-3 border-top pt-4">
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary w-100" style="min-height: 44px;">Đăng nhập</a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-primary w-100" style="min-height: 44px;">Đăng ký</a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </div>
</div>
