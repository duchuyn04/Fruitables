@model Fruitables.Models.Order
@using Fruitables.Models
@using Fruitables.Helpers
@{
    ViewData["Title"] = $"Đơn hàng #{Model.OrderNumber}";
    Layout = "~/Areas/Admin/Views/Shared/_AdminDashboardLayout.cshtml";

    var shippingAddress = AddressSnapshotHelper.FromSnapshot(Model.ShippingSnapshot);
    var vnTimeZone = TimeZoneInfo.FindSystemTimeZoneById("SE Asia Standard Time");
    var createdAtVN = TimeZoneInfo.ConvertTimeFromUtc(Model.CreatedAt, vnTimeZone);
}

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-action="Index" class="text-muted text-decoration-none mb-2 d-inline-block">
                <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
            </a>
            <h4 class="mb-1">Đơn hàng #@Model.OrderNumber</h4>
            <p class="text-muted mb-0">Ngày tạo: @createdAtVN.ToString("dd/MM/yyyy HH:mm:ss")</p>
        </div>
        <div>
            <span class="badge @GetStatusBadgeClass(Model.Status) fs-6 me-2">
                @GetStatusDisplayName(Model.Status)
            </span>
            <span class="badge @GetPaymentStatusBadgeClass(Model.PaymentStatus) fs-6">
                @GetPaymentStatusDisplayName(Model.PaymentStatus)
            </span>
        </div>
    </div>

    <div class="row">
        <!-- Left Column -->
        <div class="col-lg-8">
            <!-- Order Items -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-shopping-cart me-2"></i>Sản phẩm</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                @if (item.Product?.Images?.Any() == true)
                                                {
                                                    <img src="@item.Product.Images.First().ImageUrl" alt="@item.ProductName" 
                                                         class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;">
                                                }
                                                else
                                                {
                                                    <div class="bg-light rounded me-3 d-flex align-items-center justify-content-center" 
                                                         style="width: 50px; height: 50px;">
                                                        <i class="fas fa-image text-muted"></i>
                                                    </div>
                                                }
                                                <div>
                                                    <span class="fw-bold">@item.ProductName</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end">@item.Price.ToString("N0")đ</td>
                                        <td class="text-end fw-bold">@item.Total.ToString("N0")đ</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="3" class="text-end">Tạm tính:</td>
                                    <td class="text-end">@Model.Subtotal.ToString("N0")đ</td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end">Phí vận chuyển:</td>
                                    <td class="text-end">@Model.ShippingFee.ToString("N0")đ</td>
                                </tr>
                                @if (Model.Discount > 0)
                                {
                                    <tr>
                                        <td colspan="3" class="text-end">Giảm giá:</td>
                                        <td class="text-end text-danger">-@Model.Discount.ToString("N0")đ</td>
                                    </tr>
                                }
                                <tr>
                                    <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                                    <td class="text-end fw-bold text-primary fs-5">@Model.Total.ToString("N0")đ</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Status History -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-history me-2"></i>Lịch sử trạng thái</h5>
                </div>
                <div class="card-body">
                    @if (Model.StatusHistory?.Any() == true)
                    {
                        <div class="timeline">
                            @foreach (var history in Model.StatusHistory.OrderByDescending(h => h.CreatedAt))
                            {
                                <div class="timeline-item mb-3 pb-3 border-bottom">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <span class="badge @GetStatusBadgeClass(history.OldStatus) me-1">
                                                @GetStatusDisplayName(history.OldStatus)
                                            </span>
                                            <i class="fas fa-arrow-right mx-2 text-muted"></i>
                                            <span class="badge @GetStatusBadgeClass(history.NewStatus)">
                                                @GetStatusDisplayName(history.NewStatus)
                                            </span>
                                            @if (!string.IsNullOrEmpty(history.Notes))
                                            {
                                                <p class="text-muted mb-0 mt-2 small">
                                                    <i class="fas fa-comment me-1"></i>@history.Notes
                                                </p>
                                            }
                                        </div>
                                        <div class="text-end">
                                            <small class="text-muted d-block">@TimeZoneInfo.ConvertTimeFromUtc(history.CreatedAt, vnTimeZone).ToString("dd/MM/yyyy HH:mm")</small>
                                            @if (history.Admin != null)
                                            {
                                                <small class="text-muted">bởi @history.Admin.Name</small>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">Chưa có lịch sử thay đổi</p>
                    }
                </div>
            </div>

        </div>
        <div class="col-lg-4">
            <!-- Customer Info -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-user me-2"></i>Khách hàng</h5>
                </div>
                <div class="card-body">
                    @if (Model.User != null)
                    {
                        <p class="mb-1"><strong>@Model.User.Name</strong></p>
                        <p class="mb-1 text-muted"><i class="fas fa-envelope me-2"></i>@Model.User.Email</p>
                        @if (!string.IsNullOrEmpty(Model.User.Phone))
                        {
                            <p class="mb-0 text-muted"><i class="fas fa-phone me-2"></i>@Model.User.Phone</p>
                        }
                    }
                    else
                    {
                        <p class="text-muted mb-0">Khách vãng lai</p>
                    }
                </div>
            </div>

            <!-- Shipping Address -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-map-marker-alt me-2"></i>Địa chỉ giao hàng</h5>
                </div>
                <div class="card-body">
                    @if (shippingAddress != null)
                    {
                        <p class="mb-1"><strong>@shippingAddress.FullName</strong></p>
                        <p class="mb-1 text-muted"><i class="fas fa-phone me-2"></i>@shippingAddress.Phone</p>
                        <p class="mb-0 text-muted"><i class="fas fa-map-marker-alt me-2"></i>@shippingAddress.FullAddress</p>
                    }
                    else if (Model.Address != null)
                    {
                        <p class="mb-1"><strong>@Model.Address.FullName</strong></p>
                        <p class="mb-1 text-muted"><i class="fas fa-phone me-2"></i>@Model.Address.Phone</p>
                        <p class="mb-0 text-muted"><i class="fas fa-map-marker-alt me-2"></i>@Model.Address.FullAddress</p>
                    }
                    else
                    {
                        <p class="text-muted mb-0">Không có thông tin địa chỉ</p>
                    }
                </div>
            </div>

            <!-- Payment Info + Action -->
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-credit-card me-2"></i>Thanh toán</h5>
                    @if (Model.PaymentStatus == PaymentStatus.Pending)
                    {
                        <span class="badge bg-warning text-dark">Chưa thanh toán</span>
                    }
                    else if (Model.PaymentStatus == PaymentStatus.Paid)
                    {
                        <span class="badge bg-success">Đã thanh toán</span>
                    }
                    else
                    {
                        <span class="badge bg-info">Đã hoàn tiền</span>
                    }
                </div>
                <div class="card-body">
                    <p class="mb-1">
                        <strong>Phương thức:</strong> @GetPaymentMethodDisplayName(Model.PaymentMethod)
                    </p>
                    <p class="mb-1">
                        <strong>Vận chuyển:</strong> @GetShippingMethodDisplayName(Model.ShippingMethod)
                    </p>
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <hr>
                        <p class="mb-0 text-muted small">
                            <strong>Ghi chú:</strong> @Model.Notes
                        </p>
                    }
                    @if (Model.PaymentStatus == PaymentStatus.Pending &&
                         Model.Status != OrderStatus.Cancelled &&
                         Model.Status != OrderStatus.Returned)
                    {
                        <hr class="my-3">
                        <button type="button" class="btn btn-success w-100"
                                onclick="openPaymentModal()">
                            <i class="fas fa-check-circle me-1"></i> Xác nhận đã thu tiền
                        </button>
                    }
                </div>
            </div>

            <!-- Order Action Buttons -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-bolt me-2"></i>Thao tác đơn hàng</h5>
                </div>
                <div class="card-body d-grid gap-2">
                    @if (Model.Status == OrderStatus.Pending)
                    {
                        <button type="button" class="btn btn-info text-white"
                                onclick="confirmAction(@((int)OrderStatus.Processing), 'Duyệt đơn và bắt đầu xử lý?', false)">
                            <i class="fas fa-check me-1"></i> Duyệt đơn & Chuẩn bị hàng
                        </button>
                        <button type="button" class="btn btn-danger"
                                onclick="openCancelModal()">
                            <i class="fas fa-times me-1"></i> Hủy đơn hàng
                        </button>
                    }
                    else if (Model.Status == OrderStatus.Processing)
                    {
                        <button type="button" class="btn btn-primary"
                                onclick="confirmAction(@((int)OrderStatus.Shipped), 'Xác nhận đã giao cho đơn vị vận chuyển?', false)">
                            <i class="fas fa-shipping-fast me-1"></i> Giao cho vận chuyển
                        </button>
                        <button type="button" class="btn btn-danger"
                                onclick="openCancelModal()">
                            <i class="fas fa-times me-1"></i> Hủy đơn hàng
                        </button>
                    }
                    else if (Model.Status == OrderStatus.Shipped)
                    {
                        <button type="button" class="btn btn-success"
                                onclick="confirmAction(@((int)OrderStatus.Delivered), 'Xác nhận khách đã nhận được hàng?', false)">
                            <i class="fas fa-box-open me-1"></i> Xác nhận đã giao hàng
                        </button>
                        <button type="button" class="btn btn-warning text-dark"
                                onclick="openReturnModal()">
                            <i class="fas fa-undo me-1"></i> Giao thất bại / Hoàn hàng
                        </button>
                    }
                    else if (Model.Status == OrderStatus.Delivered)
                    {
                        <button type="button" class="btn btn-warning text-dark"
                                onclick="openReturnModal()">
                            <i class="fas fa-undo me-1"></i> Xử lý trả hàng
                        </button>
                        <p class="text-muted small mb-0 text-center">
                            <i class="fas fa-check-circle text-success me-1"></i>Đơn hàng đã hoàn thành
                        </p>
                    }
                    else if (Model.Status == OrderStatus.Cancelled || Model.Status == OrderStatus.Returned)
                    {
                        <div class="text-center text-muted py-2">
                            <i class="fas fa-lock fa-2x mb-2 d-block"></i>
                            <small>Đơn hàng đã kết thúc, không thể thay đổi trạng thái.</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusDisplayName(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "Chờ xử lý",
        OrderStatus.Processing => "Đang xử lý",
        OrderStatus.Shipped => "Đang giao",
        OrderStatus.Delivered => "Đã giao",
        OrderStatus.Cancelled => "Đã hủy",
        OrderStatus.Returned => "Trả hàng",
        _ => status.ToString()
    };

    string GetPaymentStatusDisplayName(PaymentStatus status) => status switch
    {
        PaymentStatus.Pending => "Chờ thanh toán",
        PaymentStatus.Paid => "Đã thanh toán",
        PaymentStatus.Refunded => "Đã hoàn tiền",
        _ => status.ToString()
    };

    string GetStatusBadgeClass(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "bg-warning text-dark",
        OrderStatus.Processing => "bg-info",
        OrderStatus.Shipped => "bg-primary",
        OrderStatus.Delivered => "bg-success",
        OrderStatus.Cancelled => "bg-danger",
        OrderStatus.Returned => "bg-secondary",
        _ => "bg-secondary"
    };

    string GetPaymentStatusBadgeClass(PaymentStatus status) => status switch
    {
        PaymentStatus.Pending => "bg-warning text-dark",
        PaymentStatus.Paid => "bg-success",
        PaymentStatus.Refunded => "bg-info",
        _ => "bg-secondary"
    };

    string GetPaymentMethodDisplayName(PaymentMethod method) => method switch
    {
        PaymentMethod.BankTransfer => "Chuyển khoản",
        PaymentMethod.Check => "Séc",
        PaymentMethod.COD => "Thanh toán khi nhận hàng",
        PaymentMethod.Paypal => "PayPal",
        _ => method.ToString()
    };

    string GetShippingMethodDisplayName(ShippingMethod method) => method switch
    {
        ShippingMethod.Free => "Miễn phí",
        ShippingMethod.FlatRate => "Phí cố định",
        ShippingMethod.LocalPickup => "Nhận tại cửa hàng",
        _ => method.ToString()
    };
}

<!-- ===== MODALS ===== -->

<!-- Modal: Xác nhận hành động thông thường (Duyệt / Giao hàng / Đã giao) -->
<div class="modal fade" id="actionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-question-circle me-2"></i>Xác nhận</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="actionMessage"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="actionForm" method="post" asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.Id">
                    <input type="hidden" name="newStatus" id="actionTargetStatus">
                    <textarea name="notes" class="form-control mt-2" id="actionNotes" rows="2"
                              placeholder="Ghi chú (không bắt buộc)" style="display:none;"></textarea>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-check me-1"></i>Xác nhận</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Hủy đơn hàng (cần note + file) -->
<div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="fas fa-times-circle me-2"></i>Hủy đơn hàng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-danger fw-bold">⚠️ Thao tác này không thể hoàn tác. Kho hàng sẽ được hoàn trả.</p>
                <form id="cancelForm" method="post" enctype="multipart/form-data"
                      asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.Id">
                    <input type="hidden" name="newStatus" value="@((int)OrderStatus.Cancelled)">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Lý do hủy <span class="text-danger">*</span></label>
                        <textarea name="notes" class="form-control" rows="3" required
                                  placeholder="Nhập lý do hủy đơn hàng..."></textarea>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Đính kèm bằng chứng (nếu có)</label>
                        <input type="file" name="Attachments" class="form-control"
                               multiple accept=".jpg,.jpeg,.png,.pdf">
                        <small class="text-muted">JPG, PNG, PDF. Tối đa 5MB/file</small>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-times me-1"></i>Xác nhận hủy đơn
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Hoàn hàng (cần note + file) -->
<div class="modal fade" id="returnModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-warning">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title"><i class="fas fa-undo me-2"></i>Xử lý Hoàn hàng / Trả hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted">Sau khi xác nhận, trạng thái thanh toán sẽ chuyển sang <strong>Đã hoàn tiền</strong>.</p>
                <form id="returnForm" method="post" enctype="multipart/form-data"
                      asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.Id">
                    <input type="hidden" name="newStatus" value="@((int)OrderStatus.Returned)">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Lý do hoàn hàng <span class="text-danger">*</span></label>
                        <textarea name="notes" class="form-control" rows="3" required
                                  placeholder="Nhập lý do hoàn hàng..."></textarea>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Đính kèm bằng chứng (nếu có)</label>
                        <input type="file" name="Attachments" class="form-control"
                               multiple accept=".jpg,.jpeg,.png,.pdf">
                        <small class="text-muted">JPG, PNG, PDF. Tối đa 5MB/file</small>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                        <button type="submit" class="btn btn-warning text-dark">
                            <i class="fas fa-undo me-1"></i>Xác nhận hoàn hàng
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Xác nhận đã thu tiền -->
<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-success">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-check-circle me-2"></i>Xác nhận Thu tiền</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn xác nhận đã nhận được <strong>@Model.Total.ToString("N0")đ</strong> từ khách hàng?</p>
                <form id="paymentForm" method="post"
                      asp-area="Admin" asp-controller="Order" asp-action="UpdatePaymentStatus">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.Id">
                    <input type="hidden" name="newPaymentStatus" value="@((int)PaymentStatus.Paid)">
                    <div class="mb-3">
                        <label class="form-label">Ghi chú (không bắt buộc)</label>
                        <textarea name="notes" class="form-control" rows="2"
                                  placeholder="VD: Thu tiền mặt qua shipper lúc 14:30..."></textarea>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-check me-1"></i>Xác nhận đã thu tiền
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@{
    var orderNotes = ViewBag.OrderNotes as List<Fruitables.Models.OrderNote> ?? new List<Fruitables.Models.OrderNote>();
    var currentAdminId = int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0");
}

<!-- Internal Notes Card -->
<div class="card mb-4" id="notesCard">
    <div class="card-header">
        <h5 class="mb-0"><i class="fas fa-sticky-note me-2"></i>Ghi chú nội bộ</h5>
    </div>
    <div class="card-body">
        <!-- Existing notes list -->
        <div id="notesList">
            @if (!orderNotes.Any())
            {
                <p class="text-muted small mb-3" id="emptyNotesMsg">Chưa có ghi chú nào.</p>
            }
            @foreach (var note in orderNotes)
            {
                <div class="note-item border-start border-3 border-primary ps-3 mb-3" data-note-id="@note.Id">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <strong class="small">@note.AdminName</strong>
                            <span class="text-muted small ms-2">@note.CreatedAt.AddHours(7).ToString("HH:mm dd/MM/yyyy")</span>
                        </div>
                        @if (note.AdminId == currentAdminId)
                        {
                            <button type="button" class="btn btn-link btn-sm text-danger p-0 delete-note-btn"
                                    data-note-id="@note.Id" title="Xóa ghi chú">
                                <i class="fas fa-times"></i>
                            </button>
                        }
                    </div>
                    <p class="mb-0 mt-1 small">@note.Content</p>
                </div>
            }
        </div>

        <!-- Add new note form -->
        <div class="mt-3">
            <textarea class="form-control form-control-sm mb-2" id="noteContent" rows="2"
                      placeholder="Nhập ghi chú nội bộ..." maxlength="1000"></textarea>
            <div class="d-flex justify-content-between align-items-center">
                <small class="text-muted"><span id="noteCharCount">0</span>/1000</small>
                <button type="button" class="btn btn-sm btn-primary" id="addNoteBtn">
                    <i class="fas fa-plus me-1"></i>Thêm ghi chú
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    <style>

        /* Main Timeline Container */
        .audit-timeline {
            position: relative;
            padding-left: 35px;
            margin: 0;
        }
        
        /* Timeline Connector Line (vertical line connecting all items) */
        .audit-timeline::before {
            content: '';
            position: absolute;
            left: 12px;
            top: 8px;
            bottom: 8px;
            width: 3px;
            background: linear-gradient(180deg, #0d6efd 0%, #81c408 50%, #e9ecef 100%);
            border-radius: 3px;
        }
        
        /* Timeline Item Container */
        .audit-timeline-item {
            position: relative;
            padding-bottom: 24px;
            margin-bottom: 0;
            animation: fadeInUp 0.3s ease-out;
        }
        
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .audit-timeline-item:last-child {
            padding-bottom: 0;
        }
        
        /* Timeline Marker (circular dot on the line) */
        .audit-timeline-marker {
            position: absolute;
            left: -27px;
            top: 8px;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background-color: #81c408;
            border: 3px solid #fff;
            box-shadow: 0 0 0 3px #81c408, 0 2px 8px rgba(129, 196, 8, 0.3);
            z-index: 2;
            transition: all 0.3s ease;
        }
        
        /* First item marker (most recent) - highlighted in blue */
        .audit-timeline-item:first-child .audit-timeline-marker {
            width: 18px;
            height: 18px;
            left: -29px;
            top: 6px;
            background-color: #0d6efd;
            box-shadow: 0 0 0 3px #0d6efd, 0 2px 12px rgba(13, 110, 253, 0.4);
            animation: pulse 2s infinite;
        }
        
        @@keyframes pulse {
            0% {
                box-shadow: 0 0 0 3px #0d6efd, 0 2px 12px rgba(13, 110, 253, 0.4);
            }
            50% {
                box-shadow: 0 0 0 5px rgba(13, 110, 253, 0.3), 0 2px 16px rgba(13, 110, 253, 0.5);
            }
            100% {
                box-shadow: 0 0 0 3px #0d6efd, 0 2px 12px rgba(13, 110, 253, 0.4);
            }
        }
        
        /* Hover effect on marker */
        .audit-timeline-item:hover .audit-timeline-marker {
            transform: scale(1.2);
        }
        
        /* Timeline Content Card */
        .audit-timeline-content {
            background-color: #fff;
            border-radius: 10px;
            padding: 16px;
            border-left: 4px solid #81c408;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            transition: all 0.3s ease;
            position: relative;
        }
        
        /* Arrow pointing to the marker */
        .audit-timeline-content::before {
            content: '';
            position: absolute;
            left: -10px;
            top: 12px;
            width: 0;
            height: 0;
            border-top: 8px solid transparent;
            border-bottom: 8px solid transparent;
            border-right: 10px solid #81c408;
        }
        
        .audit-timeline-content::after {
            content: '';
            position: absolute;
            left: -6px;
            top: 14px;
            width: 0;
            height: 0;
            border-top: 6px solid transparent;
            border-bottom: 6px solid transparent;
            border-right: 6px solid #fff;
        }
        
        /* First item content (most recent) - highlighted */
        .audit-timeline-item:first-child .audit-timeline-content {
            border-left-color: #0d6efd;
            background-color: #f8fbff;
            box-shadow: 0 4px 12px rgba(13, 110, 253, 0.1);
        }
        
        .audit-timeline-item:first-child .audit-timeline-content::before {
            border-right-color: #0d6efd;
        }
        
        .audit-timeline-item:first-child .audit-timeline-content::after {
            border-right-color: #f8fbff;
        }
        
        /* Hover effect on content */
        .audit-timeline-content:hover {
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            transform: translateX(4px);
        }
        
        /* Connector between items (dashed line segment) */
        .audit-timeline-item:not(:last-child)::after {
            content: '';
            position: absolute;
            left: -21px;
            top: 26px;
            bottom: -4px;
            width: 1px;
            border-left: 2px dashed rgba(129, 196, 8, 0.3);
        }
        
        /* Badge styling for status changes */
        .badge-sm {
            font-size: 0.7rem;
            padding: 0.3em 0.6em;
            font-weight: 500;
            letter-spacing: 0.02em;
        }
        
        /* Notes section styling */
        .audit-notes {
            font-style: italic;
            border-left: 3px solid #6c757d;
            background-color: #f8f9fa;
            color: #495057;
        }
        
        /* ============================================
           Attachment Card Styles - Requirement 10.4
           Enhanced styling for file attachments
           ============================================ */
        
        .attachment-link {
            background-color: #fff;
            transition: all 0.2s ease;
        }
        
        .attachment-link:hover {
            background-color: #f8f9fa;
            border-color: #81c408 !important;
        }
        
        .attachment-thumbnail {
            border: 1px solid #dee2e6;
        }
        
        /* Attachment Card Container */
        .attachment-card {
            display: flex;
            flex-direction: column;
            width: 120px;
            background-color: #fff;
            border: 2px solid #e9ecef;
            border-radius: 10px;
            overflow: hidden;
            transition: all 0.3s ease;
            text-decoration: none;
        }
        
        .attachment-card:hover {
            border-color: #81c408;
            box-shadow: 0 4px 12px rgba(129, 196, 8, 0.25);
            transform: translateY(-4px);
        }
        
        /* Image Thumbnail Wrapper */
        .attachment-thumbnail-wrapper {
            position: relative;
            width: 100%;
            height: 80px;
            overflow: hidden;
            background-color: #f8f9fa;
        }
        
        .attachment-thumbnail-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s ease;
        }
        
        .attachment-card:hover .attachment-thumbnail-img {
            transform: scale(1.1);
        }
        
        /* Overlay on hover */
        .attachment-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(129, 196, 8, 0.8), rgba(13, 110, 253, 0.8));
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .attachment-overlay i {
            color: #fff;
            font-size: 1.5rem;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
        }
        
        .attachment-card:hover .attachment-overlay {
            opacity: 1;
        }
        
        /* PDF/Document Icon Wrapper */
        .attachment-icon-wrapper {
            width: 100%;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #fff5f5 0%, #ffe8e8 100%);
            transition: background 0.3s ease;
        }
        
        .attachment-card-pdf:hover .attachment-icon-wrapper {
            background: linear-gradient(135deg, #ffe0e0 0%, #ffd0d0 100%);
        }
        
        .attachment-card-pdf:hover {
            border-color: #dc3545;
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.25);
        }
        
        /* Attachment Info Section */
        .attachment-info {
            padding: 10px;
            background-color: #f8f9fa;
            border-top: 1px solid #e9ecef;
        }
        
        .attachment-name {
            display: block;
            font-size: 0.75rem;
            color: #333;
            font-weight: 500;
            max-width: 100%;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        
        .attachment-size {
            display: block;
            font-size: 0.65rem;
            color: #6c757d;
            margin-top: 3px;
        }
        
        /* Audit Attachments Container */
        .audit-attachments {
            background-color: #fafafa;
            border-radius: 8px;
            padding: 12px;
            border: 1px dashed #dee2e6;
        }
        
        /* ============================================
           Responsive Design - Requirement 9.2
           Mobile-first responsive adjustments
           ============================================ */
        
        /* Tablet and below (max-width: 992px) */
        @@media (max-width: 992px) {
            .audit-timeline {
                padding-left: 30px;
            }
            
            .audit-timeline::before {
                left: 10px;
            }
            
            .audit-timeline-marker {
                left: -23px;
                width: 12px;
                height: 12px;
            }
            
            .audit-timeline-item:first-child .audit-timeline-marker {
                width: 16px;
                height: 16px;
                left: -25px;
            }
            
            .audit-timeline-content {
                padding: 14px;
            }
        }
        
        /* Mobile devices (max-width: 768px) */
        @@media (max-width: 768px) {
            .audit-timeline {
                padding-left: 25px;
            }
            
            .audit-timeline::before {
                left: 8px;
                width: 2px;
            }
            
            .audit-timeline-marker {
                left: -20px;
                width: 10px;
                height: 10px;
            }
            
            .audit-timeline-item:first-child .audit-timeline-marker {
                width: 14px;
                height: 14px;
                left: -22px;
            }
            
            .audit-timeline-content {
                padding: 12px;
                border-radius: 8px;
            }
            
            .audit-timeline-content::before,
            .audit-timeline-content::after {
                display: none; /* Hide arrows on mobile for cleaner look */
            }
            
            .audit-timeline-item:not(:last-child)::after {
                left: -17px;
            }
            
            /* Attachment cards on mobile */
            .attachment-card {
                width: 100px;
            }
            
            .attachment-thumbnail-wrapper,
            .attachment-icon-wrapper {
                height: 65px;
            }
            
            .attachment-info {
                padding: 8px;
            }
            
            .attachment-name {
                font-size: 0.7rem;
            }
            
            .attachment-size {
                font-size: 0.6rem;
            }
            
            /* Stack status badges vertically on mobile */
            .audit-timeline-content .d-flex.align-items-center.flex-wrap {
                flex-direction: column;
                align-items: flex-start !important;
            }
            
            .badge-sm {
                font-size: 0.65rem;
                margin-bottom: 2px;
            }
        }
        
        /* Small mobile devices (max-width: 576px) */
        @@media (max-width: 576px) {
            .audit-timeline {
                padding-left: 20px;
            }
            
            .audit-timeline::before {
                left: 6px;
            }
            
            .audit-timeline-marker {
                left: -17px;
                width: 8px;
                height: 8px;
            }
            
            .audit-timeline-item:first-child .audit-timeline-marker {
                width: 12px;
                height: 12px;
                left: -19px;
            }
            
            .audit-timeline-content {
                padding: 10px;
                border-left-width: 3px;
            }
            
            .audit-timeline-item:not(:last-child)::after {
                left: -14px;
            }
            
            /* Full width attachment cards on very small screens */
            .audit-attachments .d-flex.flex-wrap {
                flex-direction: column;
            }
            
            .attachment-card {
                width: 100%;
                flex-direction: row;
                height: 60px;
            }
            
            .attachment-thumbnail-wrapper,
            .attachment-icon-wrapper {
                width: 60px;
                height: 60px;
                flex-shrink: 0;
            }
            
            .attachment-info {
                flex: 1;
                display: flex;
                flex-direction: column;
                justify-content: center;
                border-top: none;
                border-left: 1px solid #e9ecef;
            }
        }
        
        /* Print styles */
        @@media print {
            .audit-timeline::before {
                background: #333;
            }
            
            .audit-timeline-marker {
                background-color: #333;
                box-shadow: none;
                border: 2px solid #fff;
            }
            
            .audit-timeline-content {
                box-shadow: none;
                border: 1px solid #ddd;
            }
            
            .audit-timeline-content:hover {
                transform: none;
            }
            
            @@keyframes pulse {
                0%, 50%, 100% {
                    box-shadow: none;
                }
            }
        }
    </style>
    <script>
        // ===== Modal helpers =====
        function confirmAction(newStatus, message, showNotes) {
            document.getElementById('actionMessage').textContent = message;
            document.getElementById('actionTargetStatus').value = newStatus;
            const notesEl = document.getElementById('actionNotes');
            notesEl.style.display = showNotes ? '' : 'none';
            new bootstrap.Modal(document.getElementById('actionModal')).show();
        }

        function openCancelModal() {
            new bootstrap.Modal(document.getElementById('cancelModal')).show();
        }

        function openReturnModal() {
            new bootstrap.Modal(document.getElementById('returnModal')).show();
        }

        function openPaymentModal() {
            new bootstrap.Modal(document.getElementById('paymentModal')).show();
        }

        // ===== Order Notes AJAX =====
        const orderId = @Model.Id;
        const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        // Character counter
        document.getElementById('noteContent')?.addEventListener('input', function () {
            document.getElementById('noteCharCount').textContent = this.value.length;
        });

        // Add note
        document.getElementById('addNoteBtn')?.addEventListener('click', async function () {
            const content = document.getElementById('noteContent').value.trim();
            if (!content) return;

            this.disabled = true;
            try {
                const resp = await fetch(`/Admin/Order/${orderId}/AddNote`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': antiForgeryToken
                    },
                    body: JSON.stringify({ content })
                });
                const data = await resp.json();
                if (data.success) {
                    const n = data.note;
                    const html = `
                        <div class="note-item border-start border-3 border-primary ps-3 mb-3" data-note-id="${n.id}">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <strong class="small">${n.adminName}</strong>
                                    <span class="text-muted small ms-2">${n.createdAt}</span>
                                </div>
                                ${n.isOwner ? `<button type="button" class="btn btn-link btn-sm text-danger p-0 delete-note-btn" data-note-id="${n.id}" title="Xóa ghi chú"><i class="fas fa-times"></i></button>` : ''}
                            </div>
                            <p class="mb-0 mt-1 small">${escHtml(n.content)}</p>
                        </div>`;
                    const notesList = document.getElementById('notesList');
                    const emptyMsg = document.getElementById('emptyNotesMsg');
                    if (emptyMsg) emptyMsg.remove();
                    notesList.insertAdjacentHTML('afterbegin', html);
                    document.getElementById('noteContent').value = '';
                    document.getElementById('noteCharCount').textContent = '0';
                    attachDeleteHandlers();
                }
            } finally {
                this.disabled = false;
            }
        });

        function attachDeleteHandlers() {
            document.querySelectorAll('.delete-note-btn').forEach(btn => {
                btn.replaceWith(btn.cloneNode(true)); // Remove old listeners
            });
            document.querySelectorAll('.delete-note-btn').forEach(btn => {
                btn.addEventListener('click', async function () {
                    if (!confirm('Xóa ghi chú này?')) return;
                    const noteId = this.dataset.noteId;
                    const resp = await fetch(`/Admin/Order/DeleteNote/${noteId}`, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': antiForgeryToken }
                    });
                    const data = await resp.json();
                    if (data.success) {
                        const item = document.querySelector(`.note-item[data-note-id="${noteId}"]`);
                        if (item) item.remove();
                        if (!document.querySelector('.note-item')) {
                            document.getElementById('notesList').insertAdjacentHTML('afterbegin',
                                '<p class="text-muted small mb-3" id="emptyNotesMsg">Chưa có ghi chú nào.</p>');
                        }
                    }
                });
            });
        }

        function escHtml(str) {
            return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        attachDeleteHandlers();
    </script>
}

