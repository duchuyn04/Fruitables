@using Fruitables.Models
@{
    ViewData["Title"] = "Trang chủ";

    var products = ViewBag.AllProducts as List<Product> ?? new List<Product>();
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
    var testimonials = ViewBag.Testimonials as List<Testimonial> ?? new List<Testimonial>();

    var saleProducts = products
        .Where(p => p.SalePrice.HasValue && p.SalePrice.Value < p.Price)
        .Take(4)
        .ToList();
    var featuredProducts = products
        .Where(p => p.IsFeatured)
        .Take(8)
        .ToList();
    var displayProducts = featuredProducts.Any()
        ? featuredProducts
        : products.Take(8).ToList();

    string ProductImage(Product product) =>
        product.Images?.FirstOrDefault(i => i.IsPrimary)?.ImageUrl
        ?? product.Images?.FirstOrDefault()?.ImageUrl
        ?? "/img/fruite-item-5.jpg";

    bool HasSale(Product product) =>
        product.SalePrice.HasValue && product.SalePrice.Value < product.Price;

    decimal DisplayPrice(Product product) =>
        HasSale(product) ? product.SalePrice!.Value : product.Price;

    int DiscountPercent(Product product) =>
        HasSale(product) ? (int)Math.Round((1 - product.SalePrice!.Value / product.Price) * 100) : 0;
}

<main class="home-marketplace">
    <section class="market-hero">
        <div class="container">
            <div class="market-hero-grid">
                <aside class="market-card market-category-panel">
                    <div class="market-card-title">
                        <i class="fas fa-bars"></i>
                        <span>Danh mục sản phẩm</span>
                    </div>
                    <div class="market-category-list">
                        @if (categories.Any())
                        {
                            @foreach (var category in categories.Take(8))
                            {
                                <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="@category.Id">
                                    <span>@category.Name</span>
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            }
                        }
                        else
                        {
                            <a asp-controller="Shop" asp-action="Index">
                                <span>Tất cả sản phẩm</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        }
                    </div>
                </aside>

                <section id="homeHeroCarousel" class="carousel slide carousel-fade market-hero-carousel" data-bs-ride="carousel" data-bs-interval="4000" data-bs-pause="hover" data-bs-touch="true">
                    <div class="carousel-indicators market-carousel-indicators">
                        <button type="button" data-bs-target="#homeHeroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Banner rau củ tươi"></button>
                        <button type="button" data-bs-target="#homeHeroCarousel" data-bs-slide-to="1" aria-label="Banner trái cây sạch"></button>
                        <button type="button" data-bs-target="#homeHeroCarousel" data-bs-slide-to="2" aria-label="Banner combo tiết kiệm"></button>
                    </div>
                    <div class="carousel-inner">
                        <div class="carousel-item active">
                            <div class="market-hero-banner market-hero-banner-green">
                                <div class="market-hero-content">
                                    <span class="market-label">Tươi mỗi ngày</span>
                                    <h1>Rau củ sạch cho bữa ăn gia đình</h1>
                                    <p>Chọn nhanh sản phẩm tươi, giá tốt và giao tận nhà từ Fruitables.</p>
                                    <form asp-controller="Shop" asp-action="Index" method="get" class="market-search">
                                        <input name="search" type="search" class="form-control" placeholder="Tìm rau củ, trái cây, combo..." />
                                        <button type="submit" class="btn btn-secondary text-white">Tìm kiếm</button>
                                    </form>
                                    <div class="market-hero-actions">
                                        <a asp-controller="Shop" asp-action="Index" class="btn btn-primary">Mua ngay</a>
                                        <a href="#uu-dai-hom-nay" class="btn btn-outline-light">Xem ưu đãi</a>
                                    </div>
                                </div>
                                <img src="~/img/hero-img-1.png" alt="Giỏ rau củ và trái cây tươi" />
                            </div>
                        </div>
                        <div class="carousel-item">
                            <div class="market-hero-banner market-hero-banner-orange">
                                <div class="market-hero-content">
                                    <span class="market-label">Trái cây chọn lọc</span>
                                    <h1>Trái cây tươi cho cả tuần</h1>
                                    <p>Mua theo mùa, dễ chọn, dễ thêm vào giỏ hàng cho mọi bữa phụ trong ngày.</p>
                                    <form asp-controller="Shop" asp-action="Index" method="get" class="market-search">
                                        <input name="search" type="search" class="form-control" placeholder="Tìm táo, cam, nho, dâu..." />
                                        <button type="submit" class="btn btn-secondary text-white">Tìm kiếm</button>
                                    </form>
                                    <div class="market-hero-actions">
                                        <a asp-controller="Shop" asp-action="Index" asp-route-search="trái cây" class="btn btn-primary">Mua trái cây</a>
                                        <a href="#san-pham-noi-bat" class="btn btn-outline-light">Xem gợi ý</a>
                                    </div>
                                </div>
                                <img src="~/img/hero-img-2.jpg" alt="Đĩa trái cây tươi" />
                            </div>
                        </div>
                        <div class="carousel-item">
                            <div class="market-hero-banner market-hero-banner-deep">
                                <div class="market-hero-content">
                                    <span class="market-label">Combo tiết kiệm</span>
                                    <h1>Đi chợ nhanh với combo gia đình</h1>
                                    <p>Gợi ý sản phẩm theo nhu cầu, giúp bạn tiết kiệm thời gian chọn hàng.</p>
                                    <form asp-controller="Shop" asp-action="Index" method="get" class="market-search">
                                        <input name="search" type="search" class="form-control" placeholder="Tìm combo bữa ăn, rau, củ..." />
                                        <button type="submit" class="btn btn-secondary text-white">Tìm kiếm</button>
                                    </form>
                                    <div class="market-hero-actions">
                                        <a asp-controller="Shop" asp-action="Index" asp-route-search="combo" class="btn btn-primary">Chọn combo</a>
                                        <a href="#uu-dai-hom-nay" class="btn btn-outline-light">Săn giá tốt</a>
                                    </div>
                                </div>
                                <img src="~/img/baner-1.png" alt="Combo nông sản tiết kiệm" />
                            </div>
                        </div>
                    </div>
                    <button class="carousel-control-prev market-carousel-control" type="button" data-bs-target="#homeHeroCarousel" data-bs-slide="prev" aria-label="Banner trước">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    </button>
                    <button class="carousel-control-next market-carousel-control" type="button" data-bs-target="#homeHeroCarousel" data-bs-slide="next" aria-label="Banner tiếp theo">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    </button>
                </section>

                <aside class="market-deal-stack">
                    <a href="#uu-dai-hom-nay" class="market-side-card market-side-card-hot">
                        <span>Ưu đãi chớp nhoáng</span>
                        <strong>Giá tốt hôm nay</strong>
                        <small>Sản phẩm giảm giá đang có sẵn</small>
                    </a>
                    <a asp-controller="Shop" asp-action="Index" class="market-side-card">
                        <span>Đi chợ nhanh</span>
                        <strong>Đặt online, nhận tận nhà</strong>
                        <small>Tiết kiệm thời gian mỗi ngày</small>
                    </a>
                    <a asp-controller="Contact" asp-action="Index" class="market-side-card">
                        <span>Cần hỗ trợ?</span>
                        <strong>Tư vấn chọn hàng</strong>
                        <small>Liên hệ cửa hàng khi cần gợi ý</small>
                    </a>
                </aside>
            </div>

            <div class="market-shortcuts">
                <a href="#uu-dai-hom-nay"><i class="fas fa-bolt"></i><span>Ưu đãi hôm nay</span></a>
                <a href="#san-pham-noi-bat"><i class="fas fa-star"></i><span>Sản phẩm nổi bật</span></a>
                <a asp-controller="Shop" asp-action="Index" asp-route-search="rau"><i class="fas fa-seedling"></i><span>Rau củ</span></a>
                <a asp-controller="Shop" asp-action="Index" asp-route-search="trái cây"><i class="fas fa-apple-alt"></i><span>Trái cây</span></a>
                <a asp-controller="Shop" asp-action="Index" asp-route-search="combo"><i class="fas fa-box-open"></i><span>Combo tiết kiệm</span></a>
            </div>
        </div>
    </section>

    <section class="market-trust">
        <div class="container">
            <div class="market-trust-grid">
                <div>
                    <i class="fas fa-truck"></i>
                    <strong>Giao hàng tận nơi</strong>
                    <span>Đóng gói kỹ, giao trong ngày theo khu vực</span>
                </div>
                <div>
                    <i class="fas fa-leaf"></i>
                    <strong>Nguồn hàng chọn lọc</strong>
                    <span>Ưu tiên nông sản tươi và rõ nguồn gốc</span>
                </div>
                <div>
                    <i class="fas fa-shield-alt"></i>
                    <strong>Thanh toán an toàn</strong>
                    <span>Hỗ trợ đặt hàng và thanh toán thuận tiện</span>
                </div>
                <div>
                    <i class="fas fa-headset"></i>
                    <strong>Hỗ trợ khách hàng</strong>
                    <span>Tư vấn khi cần chọn sản phẩm phù hợp</span>
                </div>
            </div>
        </div>
    </section>

    @if (saleProducts.Any())
    {
        <section id="uu-dai-hom-nay" class="market-section market-section-warm">
            <div class="container">
                <div class="market-section-heading">
                    <div>
                        <span>Ưu đãi hôm nay</span>
                        <h2>Giá tốt cho bữa ăn trong ngày</h2>
                    </div>
                    <a asp-controller="Shop" asp-action="Index">Xem tất cả</a>
                </div>
                <div class="market-product-grid market-product-grid-compact">
                    @foreach (var product in saleProducts)
                    {
                        <article class="market-product-card">
                            <a asp-controller="Shop" asp-action="Detail" asp-route-slug="@product.Slug" class="market-product-image">
                                <img src="@ProductImage(product)" alt="@product.Name" />
                                <span>-@DiscountPercent(product)%</span>
                            </a>
                            <div class="market-product-body">
                                <a asp-controller="Shop" asp-action="Detail" asp-route-slug="@product.Slug" class="market-product-name">@product.Name</a>
                                <p>@(product.ShortDescription ?? product.Description?.Substring(0, Math.Min(product.Description.Length, 70)) ?? "Sản phẩm tươi ngon cho gia đình.")</p>
                                <div class="market-product-footer">
                                    <div>
                                        <strong>@DisplayPrice(product).ToString("N0")đ</strong>
                                        <small>/ @product.Unit</small>
                                    </div>
                                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <button type="submit" aria-label="Thêm @product.Name vào giỏ hàng">
                                            <i class="fa fa-shopping-bag"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            </div>
        </section>
    }

    <section class="market-section">
        <div class="container">
            <div class="market-section-heading">
                <div>
                    <span>Mua theo danh mục</span>
                    <h2>Chọn nhanh nhóm sản phẩm bạn cần</h2>
                </div>
                <a asp-controller="Shop" asp-action="Index">Vào cửa hàng</a>
            </div>
            <div class="market-category-grid">
                @if (categories.Any())
                {
                    @foreach (var category in categories.Take(6))
                    {
                        <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="@category.Id">
                            <i class="fas fa-seedling"></i>
                            <strong>@category.Name</strong>
                            <span>Xem sản phẩm</span>
                        </a>
                    }
                }
                else
                {
                    <a asp-controller="Shop" asp-action="Index">
                        <i class="fas fa-store"></i>
                        <strong>Tất cả sản phẩm</strong>
                        <span>Xem cửa hàng</span>
                    </a>
                }
            </div>
        </div>
    </section>

    @if (displayProducts.Any())
    {
        <section id="san-pham-noi-bat" class="market-section market-section-soft">
            <div class="container">
                <div class="market-section-heading">
                    <div>
                        <span>Gợi ý cho bạn</span>
                        <h2>Sản phẩm nổi bật</h2>
                    </div>
                    <a asp-controller="Shop" asp-action="Index">Mua thêm</a>
                </div>
                <div class="market-product-grid">
                    @foreach (var product in displayProducts)
                    {
                        <article class="market-product-card">
                            <a asp-controller="Shop" asp-action="Detail" asp-route-slug="@product.Slug" class="market-product-image">
                                <img src="@ProductImage(product)" alt="@product.Name" />
                                @if (HasSale(product))
                                {
                                    <span>-@DiscountPercent(product)%</span>
                                }
                            </a>
                            <div class="market-product-body">
                                <a asp-controller="Shop" asp-action="Detail" asp-route-slug="@product.Slug" class="market-product-name">@product.Name</a>
                                <p>@(product.ShortDescription ?? product.Description?.Substring(0, Math.Min(product.Description.Length, 70)) ?? "Sản phẩm tươi ngon cho gia đình.")</p>
                                <div class="market-product-footer">
                                    <div>
                                        <strong>@DisplayPrice(product).ToString("N0")đ</strong>
                                        <small>/ @product.Unit</small>
                                    </div>
                                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <button type="submit" aria-label="Thêm @product.Name vào giỏ hàng">
                                            <i class="fa fa-shopping-bag"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            </div>
        </section>
    }

    <section class="market-promo">
        <div class="container">
            <div class="market-promo-grid">
                <article>
                    <span>Bữa ăn lành mạnh</span>
                    <h2>Rau củ tươi cho thực đơn mỗi ngày</h2>
                    <p>Kết hợp rau xanh, trái cây và combo tiết kiệm cho gia đình.</p>
                    <a asp-controller="Shop" asp-action="Index" asp-route-search="rau">Khám phá ngay</a>
                </article>
                <article>
                    <span>Tiện lợi hơn</span>
                    <h2>Đặt hàng nhanh, nhận hàng tại nhà</h2>
                    <p>Tìm sản phẩm, thêm vào giỏ và hoàn tất đơn hàng trong vài bước.</p>
                    <a asp-controller="Shop" asp-action="Index">Đi chợ online</a>
                </article>
            </div>
        </div>
    </section>

    @if (testimonials.Any())
    {
        <section class="market-section">
            <div class="container">
                <div class="market-section-heading">
                    <div>
                        <span>Khách hàng nói gì</span>
                        <h2>Trải nghiệm mua hàng tại Fruitables</h2>
                    </div>
                    <a asp-controller="Testimonial" asp-action="Index">Xem đánh giá</a>
                </div>
                <div class="market-testimonial-grid">
                    @foreach (var testimonial in testimonials.Take(3))
                    {
                        <article>
                            <div class="market-stars">
                                @for (var i = 0; i < 5; i++)
                                {
                                    <i class="fas fa-star @(i < testimonial.Rating ? "active" : "")"></i>
                                }
                            </div>
                            <p>@testimonial.Content</p>
                            <div class="market-customer">
                                <img src="@(testimonial.Avatar ?? "/img/testimonial-1.jpg")" alt="@testimonial.Name" />
                                <div>
                                    <strong>@testimonial.Name</strong>
                                    <span>@(string.IsNullOrWhiteSpace(testimonial.Profession) ? "Khách hàng" : testimonial.Profession)</span>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            </div>
        </section>
    }
</main>

<style>
    .home-marketplace {
        background: #ffffff;
        color: #273438;
        font-family: 'Be Vietnam Pro', sans-serif;
    }

    .home-marketplace h1,
    .home-marketplace h2,
    .home-marketplace h3,
    .home-marketplace h4,
    .home-marketplace h5,
    .home-marketplace h6,
    .home-marketplace input,
    .home-marketplace button,
    .home-marketplace .btn {
        font-family: 'Be Vietnam Pro', sans-serif;
        letter-spacing: 0;
    }

    .market-hero {
        padding: 168px 0 28px;
        background: #f6f8ef;
    }

    .market-hero-grid {
        display: grid;
        grid-template-columns: 260px minmax(0, 1fr) 280px;
        gap: 16px;
        align-items: stretch;
    }

    .market-card,
    .market-hero-carousel,
    .market-hero-banner,
    .market-side-card,
    .market-shortcuts a,
    .market-trust-grid > div,
    .market-product-card,
    .market-category-grid a,
    .market-promo-grid article,
    .market-testimonial-grid article {
        border-radius: 8px;
    }

    .market-card,
    .market-side-card,
    .market-shortcuts a,
    .market-trust-grid > div,
    .market-product-card,
    .market-category-grid a,
    .market-testimonial-grid article {
        background: #ffffff;
        border: 1px solid rgba(39, 52, 56, 0.08);
        box-shadow: 0 10px 28px rgba(31, 41, 55, 0.07);
        transition: transform 0.24s ease, box-shadow 0.24s ease, color 0.2s ease, background-color 0.2s ease;
    }

    .market-card-title {
        display: flex;
        align-items: center;
        gap: 10px;
        min-height: 54px;
        padding: 0 16px;
        border-bottom: 1px solid #edf1e5;
        color: #273438;
        font-weight: 800;
    }

    .market-card-title i,
    .market-category-grid i,
    .market-trust-grid i {
        color: #81c408;
    }

    .market-category-list {
        display: grid;
        padding: 8px;
    }

    .market-category-list a {
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 42px;
        padding: 8px 10px;
        border-radius: 6px;
        color: #45595b;
        font-size: 0.94rem;
        font-weight: 600;
        text-decoration: none;
    }

    .market-category-list a:hover {
        background: #f1f8df;
        color: #5f9307;
    }

    .market-category-list i {
        color: #a0aec0;
        font-size: 0.72rem;
    }

    .market-hero-carousel {
        position: relative;
        min-height: 420px;
        overflow: hidden;
        background: #2f5d12;
        box-shadow: 0 18px 45px rgba(45, 95, 6, 0.22);
    }

    .market-hero-carousel .carousel-inner,
    .market-hero-carousel .carousel-item {
        min-height: 420px;
        height: 100%;
    }

    .market-hero-carousel .carousel-item {
        transition: transform 0.7s ease-in-out, opacity 0.7s ease-in-out;
    }

    .market-hero-carousel .carousel-item a {
        position: static;
        transform: none;
        font-size: inherit;
        background: transparent;
    }

    .market-hero-banner {
        position: relative;
        min-height: 420px;
        height: 100%;
        overflow: hidden;
        padding: 38px;
        color: #ffffff;
    }

    .market-hero-banner-green {
        background:
            linear-gradient(135deg, rgba(38, 93, 14, 0.96), rgba(129, 196, 8, 0.82)),
            url('/img/banner-fruits.jpg') center/cover;
    }

    .market-hero-banner-orange {
        background:
            linear-gradient(135deg, rgba(223, 47, 47, 0.9), rgba(255, 181, 36, 0.78)),
            url('/img/hero-img-2.jpg') center/cover;
    }

    .market-hero-banner-deep {
        background:
            linear-gradient(135deg, rgba(39, 52, 56, 0.92), rgba(129, 196, 8, 0.68)),
            url('/img/baner-1.png') center/cover;
    }

    .market-hero-content {
        position: relative;
        z-index: 2;
        max-width: 560px;
    }

    .market-label,
    .market-section-heading span,
    .market-promo-grid span {
        display: inline-flex;
        margin-bottom: 6px;
        color: #e8590c;
        font-size: 0.82rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .market-hero-banner .market-label {
        padding: 6px 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.18);
        color: #ffffff;
    }

    .market-hero-banner h1 {
        max-width: 520px;
        margin: 8px 0 12px;
        color: #ffffff;
        font-size: clamp(2rem, 4vw, 3.35rem);
        font-weight: 900;
        line-height: 1.08;
    }

    .market-hero-banner p {
        max-width: 430px;
        margin-bottom: 22px;
        color: rgba(255, 255, 255, 0.9);
    }

    .market-hero-banner img {
        position: absolute;
        right: -14px;
        bottom: -26px;
        width: min(40%, 260px);
        max-height: 250px;
        object-fit: contain;
        filter: drop-shadow(0 22px 28px rgba(0, 0, 0, 0.26));
    }

    .market-carousel-indicators {
        right: auto;
        bottom: 18px;
        left: 38px;
        justify-content: flex-start;
        gap: 7px;
        margin: 0;
    }

    .market-carousel-indicators [data-bs-target] {
        width: 26px;
        height: 4px;
        margin: 0;
        border: 0;
        border-radius: 999px;
        background-color: rgba(255, 255, 255, 0.58);
        opacity: 1;
    }

    .market-carousel-indicators .active {
        width: 42px;
        background-color: #ffffff;
    }

    .market-carousel-control {
        width: 46px;
        height: 46px;
        top: 34px;
        bottom: auto;
        border: 0;
        background: transparent;
        transform: none;
        opacity: 1;
    }

    .market-carousel-control.carousel-control-prev {
        right: 92px;
        left: auto;
        margin-left: 0;
    }

    .market-carousel-control.carousel-control-next {
        right: 34px;
        margin-right: 0;
    }

    .market-carousel-control .carousel-control-prev-icon,
    .market-carousel-control .carousel-control-next-icon {
