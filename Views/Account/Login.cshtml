@model Fruitables.ViewModels.LoginRequest
@inject Fruitables.Services.Interfaces.IGoogleAuthService GoogleAuthService
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    var isGoogleEnabled = await GoogleAuthService.IsGoogleAuthEnabledAsync();
}

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
            <div class="toast-header bg-danger text-white">
                <i class="fas fa-exclamation-circle me-2"></i>
                <strong class="me-auto">Lỗi</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">@TempData["ErrorMessage"]</div>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
            <div class="toast-header bg-success text-white">
                <i class="fas fa-check-circle me-2"></i>
                <strong class="me-auto">Thành công</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">@TempData["SuccessMessage"]</div>
        </div>
    }
    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
    {
        <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
            <div class="toast-header bg-danger text-white">
                <i class="fas fa-exclamation-circle me-2"></i>
                <strong class="me-auto">Lỗi</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        </div>
    }
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5 col-xl-4">
            <div class="auth-card p-4 p-md-5">
                <!-- Logo/Header -->
                <div class="text-center mb-4">
                    <h1 class="h3 text-primary fw-bold">
                        <i class="fas fa-leaf me-2"></i>Fruitables
                    </h1>
                    <p class="text-muted">Đăng nhập vào tài khoản của bạn</p>
                </div>

                <!-- Login Form -->
                <form asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post">
                    <!-- Email -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">
                            <i class="fas fa-envelope me-1"></i>Email
                        </label>
                        <input asp-for="Email" 
                               class="form-control form-control-lg" 
                               placeholder="email@example.com"
                               autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <!-- Password -->
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <label asp-for="Password" class="form-label mb-0">
                                <i class="fas fa-lock me-1"></i>Mật khẩu
                            </label>
                            <a asp-action="ForgotPassword" class="text-primary small">Quên mật khẩu?</a>
                        </div>
                        <input asp-for="Password" 
                               type="password" 
                               class="form-control form-control-lg" 
                               placeholder="••••••••"
                               autocomplete="current-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <!-- Remember Me -->
                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label">
                                Ghi nhớ đăng nhập
                            </label>
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <div class="d-grid">
                        <button type="submit" class="btn btn-auth-primary btn-lg">
                            <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                        </button>
                    </div>
                </form>

                @if (isGoogleEnabled)
                {
                    <!-- Divider -->
                    <div class="divider my-4">
                        <span>hoặc</span>
                    </div>

                    <!-- Google Login -->
                    <div class="d-grid">
                        <a asp-action="GoogleLogin" asp-route-returnUrl="@ViewBag.ReturnUrl" class="btn btn-auth-google btn-lg w-100">
                            <i class="fab fa-google me-2"></i>Đăng nhập bằng Google
                        </a>
                    </div>
                }

                <!-- Register Link -->
                <div class="text-center mt-4">
                    <p class="mb-2">Chưa có tài khoản? <a asp-action="Register" class="text-primary fw-bold">Đăng ký ngay</a></p>
                </div>

                <!-- Footer -->
                <div class="text-center mt-3">
                    <a href="/" class="text-muted text-decoration-none">
                        <i class="fas fa-arrow-left me-1"></i>Quay lại trang chủ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function() {
            document.querySelectorAll('.toast.show').forEach(function(toast) {
                setTimeout(function() {
                    var bsToast = bootstrap.Toast.getOrCreateInstance(toast);
                    bsToast.hide();
                }, 5000);
            });
        })();
    </script>
}
