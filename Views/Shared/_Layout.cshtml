@inject Fruitables.Services.Interfaces.ISettingsService SettingsService
@{
    var siteName = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.SiteName, "Fruitables");
    var metaTitle = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.MetaTitle);
    var metaDescription = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.MetaDescription);
    var metaKeywords = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.MetaKeywords);
    var logoPath = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.Logo);
    var faviconPath = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.Favicon);
    var gaId = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.GoogleAnalyticsId);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>@(ViewData["Title"] ?? metaTitle) - @siteName</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="@metaKeywords" name="keywords">
    <meta content="@metaDescription" name="description">
    @if (!string.IsNullOrEmpty(faviconPath))
    {
        <link rel="icon" type="image/x-icon" href="@faviconPath">
    }

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600&family=Raleway:wght@600;800&display=swap" rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries Stylesheet -->
    <link href="~/lib/custom/lightbox/css/lightbox.min.css" rel="stylesheet">
    <link href="~/lib/custom/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">

    <!-- Customized Bootstrap Stylesheet -->
    <link href="~/css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="~/css/style.css" rel="stylesheet">
    @await RenderSectionAsync("Styles", required: false)
    
    @if (!string.IsNullOrEmpty(gaId))
    {
        <!-- Google Analytics -->
        <script async src="https://www.googletagmanager.com/gtag/js?id=@gaId"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '@gaId');
        </script>
    }
</head>
<body>
    <!-- Spinner Start -->
    <div id="spinner" class="show w-100 vh-100 bg-white position-fixed translate-middle top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-grow text-primary" role="status"></div>
    </div>
    <!-- Spinner End -->

    <!-- Navbar start -->
    <partial name="_Navbar" />
    <!-- Navbar End -->

    <!-- Modal Search Start -->
    <partial name="_SearchModal" />
    <!-- Modal Search End -->

    @RenderBody()

    <!-- Footer Start -->
    <partial name="_Footer" />
    <!-- Footer End -->

    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="toast align-items-center text-white border-0 show" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="3000" style="background-color: #81c408;">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="toast align-items-center text-bg-danger border-0 show" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="3000">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        }
    </div>

    <!-- Login Required Modal -->
    <div id="loginRequiredOverlay" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(15,23,42,0.55); backdrop-filter:blur(4px); -webkit-backdrop-filter:blur(4px); align-items:center; justify-content:center;">
        <div style="background:#fff; border-radius:20px; padding:0; max-width:420px; width:90%; overflow:hidden; box-shadow:0 25px 60px rgba(0,0,0,0.25); transform:translateY(0); animation:loginModalIn 0.3s ease;">
            <!-- Header gradient -->
            <div style="background:linear-gradient(135deg,#81c408 0%,#5a9a00 100%); padding:28px 32px 24px; text-align:center; position:relative;">
                <div style="width:64px;height:64px;background:rgba(255,255,255,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;border:2px solid rgba(255,255,255,0.4);">
                    <i class="fas fa-lock" style="font-size:26px;color:#fff;"></i>
                </div>
                <h4 style="color:#fff;margin:0;font-size:1.3rem;font-weight:700;letter-spacing:0.01em;">Yêu cầu đăng nhập</h4>
                <p style="color:rgba(255,255,255,0.85);margin:6px 0 0;font-size:0.9rem;">Bạn cần đăng nhập để tiếp tục</p>
                <button onclick="hideLoginModal()" style="position:absolute;top:14px;right:16px;background:rgba(255,255,255,0.2);border:none;border-radius:50%;width:32px;height:32px;cursor:pointer;color:#fff;font-size:16px;line-height:1;display:flex;align-items:center;justify-content:center;transition:background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.35)'" onmouseout="this.style.background='rgba(255,255,255,0.2)'">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <!-- Body -->
            <div style="padding:28px 32px 32px; text-align:center;">
                <p style="color:#475569;font-size:0.95rem;line-height:1.6;margin:0 0 24px;">
                    Vui lòng <strong style="color:#81c408;">đăng nhập</strong> vào tài khoản của bạn để thêm sản phẩm vào giỏ hàng hoặc mua hàng.
                </p>
                <!-- Benefits list -->
                <div style="background:#f8fafc;border-radius:12px;padding:16px;margin-bottom:24px;text-align:left;">
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;color:#475569;font-size:0.87rem;">
                        <i class="fas fa-check-circle" style="color:#81c408;flex-shrink:0;"></i>
                        <span>Theo dõi đơn hàng & lịch sử mua hàng</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;color:#475569;font-size:0.87rem;">
                        <i class="fas fa-check-circle" style="color:#81c408;flex-shrink:0;"></i>
                        <span>Lưu địa chỉ giao hàng tự động</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;color:#475569;font-size:0.87rem;">
                        <i class="fas fa-check-circle" style="color:#81c408;flex-shrink:0;"></i>
                        <span>Thanh toán nhanh hơn mỗi lần mua</span>
                    </div>
                </div>
                <!-- Buttons -->
                <a id="loginRedirectBtn" href="/Account/Login" style="display:block;background:linear-gradient(135deg,#81c408 0%,#5a9a00 100%);color:#fff;text-decoration:none;padding:13px 24px;border-radius:12px;font-weight:700;font-size:1rem;margin-bottom:10px;transition:all 0.2s;box-shadow:0 4px 15px rgba(129,196,8,0.35);" onmouseover="this.style.transform='translateY(-1px)';this.style.boxShadow='0 6px 20px rgba(129,196,8,0.45)'" onmouseout="this.style.transform='';this.style.boxShadow='0 4px 15px rgba(129,196,8,0.35)'">
                    <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập ngay
                </a>
                <a href="/Account/Register" style="display:block;background:#f1f5f9;color:#475569;text-decoration:none;padding:11px 24px;border-radius:12px;font-weight:600;font-size:0.9rem;transition:background 0.2s;" onmouseover="this.style.background='#e2e8f0'" onmouseout="this.style.background='#f1f5f9'">
                    Chưa có tài khoản? <strong style="color:#81c408;">Đăng ký miễn phí</strong>
                </a>
            </div>
        </div>
    </div>
    <style>
        @@keyframes loginModalIn {
            from { opacity: 0; transform: scale(0.92) translateY(16px); }
            to   { opacity: 1; transform: scale(1)   translateY(0); }
        }
    </style>



    <!-- Back to Top -->
    <a href="#" class="btn btn-primary border-3 border-primary rounded-circle back-to-top"><i class="fa fa-arrow-up"></i></a>

    <!-- JavaScript Libraries -->
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/custom/easing/easing.min.js"></script>
    <script src="~/lib/custom/waypoints/waypoints.min.js"></script>
    <script src="~/lib/custom/lightbox/js/lightbox.min.js"></script>
    <script src="~/lib/custom/owlcarousel/owl.carousel.min.js"></script>

    <!-- Template Javascript -->
    <script src="~/js/main.js"></script>
    
    <!-- Initialize Toasts -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var toastElList = [].slice.call(document.querySelectorAll('.toast'));
            toastElList.forEach(function(toastEl) {
                var toast = new bootstrap.Toast(toastEl);
                toast.show();
            });
        });
    </script>
    <!-- SignalR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
    <script>
        if (!window.ecommerceHub) {
            window.ecommerceHub = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/ecommerce")
                .withAutomaticReconnect()
                .build();
                
            window.ecommerceHubReady = window.ecommerceHub.start();
            window.ecommerceHubReady.catch(function (err) {
                return console.error("SignalR Connection Error: ", err.toString());
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Login Required Modal JS -->
    <script>
        // Expose auth state to JS from server
        var _isAuthenticated = @(User.Identity?.IsAuthenticated == true ? "true" : "false");

        // Modal helpers
        function showLoginModal(returnUrl) {
            var overlay = document.getElementById('loginRequiredOverlay');
            var loginBtn = document.getElementById('loginRedirectBtn');
            if (returnUrl) {
                loginBtn.href = '/Account/Login?returnUrl=' + encodeURIComponent(returnUrl);
            } else {
                loginBtn.href = '/Account/Login';
            }
            overlay.style.display = 'flex';
            // Re-trigger animation
            var card = overlay.querySelector('div');
            card.style.animation = 'none';
            card.offsetHeight; // reflow
            card.style.animation = 'loginModalIn 0.3s ease';
        }

        function hideLoginModal() {
            document.getElementById('loginRequiredOverlay').style.display = 'none';
        }

        // Close on backdrop click
        document.getElementById('loginRequiredOverlay').addEventListener('click', function(e) {
            if (e.target === this) hideLoginModal();
        });

        // Intercept purchase forms when not authenticated
        document.addEventListener('DOMContentLoaded', function () {
            if (!_isAuthenticated) {
                // All forms targeting Cart/AddToCart or Checkout/BuyNow
                document.querySelectorAll(
                    'form[action*="AddToCart"], form[action*="BuyNow"]'
                ).forEach(function (form) {
                    form.addEventListener('submit', function (e) {
                        e.preventDefault();
                        e.stopImmediatePropagation();
                        showLoginModal(window.location.pathname + window.location.search);
                    });
                });

                // Also intercept any submit button that references those forms via [form] attr
                document.querySelectorAll('[type="submit"][form]').forEach(function(btn) {
                    var formId = btn.getAttribute('form');
                    var linkedForm = document.getElementById(formId);
                    if (linkedForm && (
                        (linkedForm.action || '').includes('AddToCart') ||
                        (linkedForm.action || '').includes('BuyNow')
                    )) {
                        btn.addEventListener('click', function(e) {
                            e.preventDefault();
                            e.stopImmediatePropagation();
                            showLoginModal(window.location.pathname + window.location.search);
                        }, true);
                    }
                });
            }
        });
    </script>
</body>
</html>
