@using Fruitables.ViewModels
@model int

@{
    // This will be populated by the controller
    var statistics = ViewBag.ReviewStatistics as ReviewStatistics;
    var reviews = ViewBag.Reviews as PagedResult<ReviewViewModel>;
    var canReview = ViewBag.CanReview as bool? ?? false;
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

<!-- Anti-forgery token for AJAX requests -->
@Html.AntiForgeryToken()

<!-- Review Statistics Section -->
@if (statistics != null && statistics.TotalReviews > 0)
{
    <div class="review-statistics mb-4 p-4 bg-light rounded">
        <div class="row">
            <div class="col-md-4 text-center border-end">
                <h2 class="display-4 mb-0">@statistics.AverageRating.ToString("F1")</h2>
                <div class="mb-2">
                    @for (int i = 0; i < 5; i++)
                    {
                        <i class="fa fa-star @(i < Math.Round(statistics.AverageRating) ? "text-warning" : "text-muted")"></i>
                    }
                </div>
                <p class="text-muted mb-0">@statistics.TotalReviews đánh giá</p>
            </div>
            <div class="col-md-8">
                <h6 class="mb-3">Phân bố đánh giá</h6>
                @for (int star = 5; star >= 1; star--)
                {
                    var count = star == 5 ? statistics.FiveStarCount :
                                star == 4 ? statistics.FourStarCount :
                                star == 3 ? statistics.ThreeStarCount :
                                star == 2 ? statistics.TwoStarCount :
                                statistics.OneStarCount;
                    var percentage = statistics.TotalReviews > 0 ? (count * 100.0 / statistics.TotalReviews) : 0;
                    
                    <div class="d-flex align-items-center mb-2">
                        <span class="me-2" style="width: 60px;">@star <i class="fa fa-star text-warning"></i></span>
                        <div class="progress flex-grow-1 me-2" style="height: 8px;">
                            <div class="progress-bar bg-warning" role="progressbar" style="width: @percentage%" aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <span class="text-muted" style="width: 50px;">@count</span>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Write Review Button -->
@if (isAuthenticated)
{
    @if (canReview)
    {
        <div class="mb-4">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#writeReviewModal">
                <i class="fa fa-edit"></i> Viết đánh giá
            </button>
        </div>
    }
    else
    {
        <div class="alert alert-info mb-4">
            <i class="fa fa-info-circle"></i> Bạn đã đánh giá sản phẩm này hoặc chưa mua hàng.
        </div>
    }
}
else
{
    <div class="alert alert-warning mb-4">
        <i class="fa fa-sign-in"></i> Vui lòng <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path">đăng nhập</a> để viết đánh giá.
    </div>
}

<!-- Sort and Filter — luôn render để AJAX có thể dùng -->
<div class="d-flex justify-content-between align-items-center mb-3"
     id="reviewsHeader"
     data-product-id="@Model"
     @(reviews == null || !reviews.Items.Any() ? "style=\"display:none\"" : "")>
    <h5 class="mb-0" id="reviewsCountTitle">
        Tất cả đánh giá (@(reviews?.TotalCount ?? 0))
    </h5>
    <select class="form-select" style="width: 200px;" id="reviewSort" onchange="sortReviews(this.value)">
        <option value="newest">Mới nhất</option>
        <option value="oldest">Cũ nhất</option>
        <option value="highest">Đánh giá cao nhất</option>
        <option value="lowest">Đánh giá thấp nhất</option>
        <option value="helpful">Hữu ích nhất</option>
    </select>
</div>

<!-- Reviews List — luôn tồn tại trong DOM -->
<div id="reviewsList">
    @if (reviews != null && reviews.Items.Any())
    {
        @foreach (var review in reviews.Items)
        {
            <partial name="_ReviewItem" model="review" />
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="fa fa-comments fa-3x text-muted mb-3"></i>
            <p class="text-muted">Chưa có đánh giá nào. Hãy là người đầu tiên đánh giá sản phẩm này!</p>
        </div>
    }
</div>

@* Pagination chỉ khi có nhiều trang *@
@if (reviews != null && reviews.TotalPages > 1)
{
    <nav aria-label="Review pagination" class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(reviews.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="?page=@(reviews.CurrentPage - 1)" aria-label="Previous">
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>
            @for (int i = 1; i <= reviews.TotalPages; i++)
            {
                <li class="page-item @(i == reviews.CurrentPage ? "active" : "")">
                    <a class="page-link" href="?page=@i">@i</a>
                </li>
            }
            <li class="page-item @(reviews.CurrentPage == reviews.TotalPages ? "disabled" : "")">
                <a class="page-link" href="?page=@(reviews.CurrentPage + 1)" aria-label="Next">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>
        </ul>
    </nav>
}

<!-- Include Modals -->
<partial name="_WriteReviewModal" model="Model" />
<partial name="_ReportReviewModal" />

<!-- Modal xác nhận xóa đánh giá -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title text-danger" id="deleteConfirmModalLabel">
                    <i class="fa fa-exclamation-triangle me-2"></i>Xác nhận xóa
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Bạn có chắc chắn muốn xóa đánh giá này không? Hành động này không thể hoàn tác.</p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-sm btn-danger" id="confirmDeleteBtn" data-bs-dismiss="modal">
                    <i class="fa fa-trash me-1"></i>Xóa
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/review.js" asp-append-version="true"></script>
}

<script>
async function sortReviews(sortBy) {
    const header = document.getElementById('reviewsHeader');
    const productId = header ? header.getAttribute('data-product-id') : null;
    if (!productId) return;

    const reviewsList = document.getElementById('reviewsList');
    if (reviewsList) {
        reviewsList.style.opacity = '0.5';
        reviewsList.style.pointerEvents = 'none';
    }

    try {
        const resp = await fetch(`/Review/GetReviews?productId=${productId}&sortBy=${sortBy}&page=1`);
        const data = await resp.json();

        if (data.success) {
            renderReviews(data.items, data.totalCount);
            renderPagination(data.totalPages, data.currentPage, productId, sortBy);
        }
    } catch (err) {
        console.error('Sort reviews error:', err);
    } finally {
        if (reviewsList) {
            reviewsList.style.opacity = '';
            reviewsList.style.pointerEvents = '';
        }
    }
}

function renderReviews(items, totalCount) {
    const reviewsList = document.getElementById('reviewsList');
    const countTitle = document.getElementById('reviewsCountTitle');
    if (countTitle) countTitle.textContent = `Tất cả đánh giá (${totalCount})`;

    if (!reviewsList) return;

    if (!items || items.length === 0) {
        reviewsList.innerHTML = `
            <div class="text-center py-5">
                <i class="fa fa-comments fa-3x text-muted mb-3"></i>
                <p class="text-muted">Chưa có đánh giá nào. Hãy là người đầu tiên đánh giá sản phẩm này!</p>
            </div>`;
        return;
    }

    reviewsList.innerHTML = items.map(r => buildReviewHtml(r)).join('');

    // Re-attach event listeners after DOM rebuild
    if (typeof initializeReviewActions === 'function') {
        initializeReviewActions();
    }
    if (typeof restoreHelpfulState === 'function') {
        restoreHelpfulState();
    }
}

function buildReviewHtml(r) {
    const avatarHtml = (r.userAvatar && !r.userAvatar.includes('default-avatar'))
        ? `<img src="${r.userAvatar}" class="rounded-circle" style="width:60px;height:60px;object-fit:cover;" alt="${escHtml(r.userName)}">`
        : `<img src="/img/default-avatar.svg" class="rounded-circle" style="width:60px;height:60px;background-color:#e4e6eb;" alt="${escHtml(r.userName)}">`;

    const starsHtml = [1,2,3,4,5].map(i =>
        `<i class="fa fa-star ${i <= r.rating ? 'text-warning' : 'text-muted'}"></i>`
    ).join('');

    const verifiedBadge = r.isVerifiedPurchase
        ? `<span class="badge bg-success ms-2" title="Đã mua hàng"><i class="fa fa-check-circle"></i> Đã mua hàng</span>`
        : '';

    const updatedHtml = r.updatedAt
        ? `<small class="text-muted fst-italic">Đã chỉnh sửa: ${r.updatedAt}</small>`
        : '';

    const ownerBtns = r.isOwner ? `
        <button type="button" class="btn btn-sm btn-outline-primary edit-review-btn"
            data-review-id="${r.id}" data-rating="${r.rating}" data-comment="${escAttr(r.comment)}">
            <i class="fa fa-edit"></i> Sửa
        </button>
        <button type="button" class="btn btn-sm btn-outline-danger delete-review-btn" data-review-id="${r.id}">
            <i class="fa fa-trash"></i> Xóa
        </button>` : '';

    const reportBtn = !r.isOwner ? `
        <button type="button" class="btn btn-sm btn-outline-danger report-btn"
            data-review-id="${r.id}" data-bs-toggle="modal" data-bs-target="#reportReviewModal">
            <i class="fa fa-flag"></i> Báo cáo
        </button>` : '';

    return `
    <div class="review-item mb-4 p-3 border rounded">
        <div class="d-flex">
            <div class="review-avatar me-3">${avatarHtml}</div>
            <div class="review-content flex-grow-1">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <h6 class="mb-0">${escHtml(r.userName)}</h6>
                        <small class="text-muted">${r.createdAt}</small>
                        ${verifiedBadge}
                    </div>
                    <div class="review-rating">${starsHtml}</div>
                </div>
                <p class="review-comment mb-2">${escHtml(r.comment)}</p>
                ${updatedHtml}
                <div class="review-actions mt-3 d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary helpful-btn" data-review-id="${r.id}">
                        <i class="fa fa-thumbs-up"></i> Hữu ích (${r.helpfulCount})
                    </button>
                    ${reportBtn}
                    ${ownerBtns}
                </div>
            </div>
        </div>
    </div>`;
}

function renderPagination(totalPages, currentPage, productId, sortBy) {
    // Remove old pagination if exists
    const oldNav = document.querySelector('#reviewsList + nav');
    if (oldNav) oldNav.remove();
    // We rely on client-side sort so pagination calls sortReviews again with page
    // Simple implementation: not re-rendering pagination for now since most products have < 1 page
}

function escHtml(str) {
    if (!str) return '';
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;');
}

function escAttr(str) {
    if (!str) return '';
    return str.replace(/"/g, '&quot;').replace(/'/g, '&#039;');
}
</script>
