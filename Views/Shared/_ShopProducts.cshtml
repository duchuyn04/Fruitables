@using Fruitables.Models
@using Fruitables.ViewModels
@model ShopViewModel

@if (Model.Products.Any())
{
    @foreach (var product in Model.Products)
    {
        var primaryImage = product.Images?.FirstOrDefault(i => i.IsPrimary)?.ImageUrl 
            ?? product.Images?.FirstOrDefault()?.ImageUrl 
            ?? "~/img/fruite-item-5.jpg";
        <div class="col-md-6 col-lg-6 col-xl-4">
            <div class="rounded position-relative fruite-item">
                <div class="fruite-img">
                    <a asp-controller="Shop" asp-action="Detail" asp-route-slug="@product.Slug">
                        <img src="@primaryImage" class="img-fluid w-100 rounded-top" alt="@product.Name">
                    </a>
                </div>
                <div class="text-white bg-secondary px-3 py-1 rounded position-absolute" style="top: 10px; left: 10px;">
                    @product.Category?.Name
                </div>
                <div class="p-4 border border-secondary border-top-0 rounded-bottom">
                    <h4>
                        <a asp-controller="Shop" asp-action="Detail" asp-route-slug="@product.Slug" class="text-dark">
                            @product.Name
                        </a>
                    </h4>
                    <p>@(product.ShortDescription ?? product.Description?.Substring(0, Math.Min(product.Description?.Length ?? 0, 80)) ?? "")</p>
                    <div class="d-flex justify-content-between flex-lg-wrap">
                        @if (product.SalePrice.HasValue)
                        {
                            <p class="text-dark fs-5 fw-bold mb-0">
                                @product.SalePrice.Value.ToString("N0")đ / @product.Unit
                            </p>
                        }
                        else
                        {
                            <p class="text-dark fs-5 fw-bold mb-0">@product.Price.ToString("N0")đ / @product.Unit</p>
                        }
                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-inline">
                            <input type="hidden" name="productId" value="@product.Id" />
                            <button type="submit" class="btn border border-secondary rounded-pill px-3 text-primary">
                                <i class="fa fa-shopping-bag me-2 text-primary"></i> Thêm vào giỏ
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    
    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="col-12">
            <div class="pagination d-flex justify-content-center mt-5">
                @if (Model.CurrentPage > 1)
                {
                    <a asp-controller="Shop" asp-action="Index" 
                       asp-route-categoryId="@Model.SelectedCategoryId" 
                       asp-route-search="@Model.SearchTerm"
                       asp-route-page="@(Model.CurrentPage - 1)" class="rounded">&laquo;</a>
                }
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a asp-controller="Shop" asp-action="Index" 
                       asp-route-categoryId="@Model.SelectedCategoryId" 
                       asp-route-search="@Model.SearchTerm"
                       asp-route-page="@i" 
                       class="rounded @(i == Model.CurrentPage ? "active" : "")">@i</a>
                }
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a asp-controller="Shop" asp-action="Index" 
                       asp-route-categoryId="@Model.SelectedCategoryId" 
                       asp-route-search="@Model.SearchTerm"
                       asp-route-page="@(Model.CurrentPage + 1)" class="rounded">&raquo;</a>
                }
            </div>
        </div>
    }
}
else
{
    <div class="col-12 text-center py-5">
        <h4>Không tìm thấy sản phẩm</h4>
        <p>Hãy thử điều chỉnh tìm kiếm hoặc bộ lọc.</p>
        <a asp-controller="Shop" asp-action="Index" class="btn btn-primary">Xem tất cả sản phẩm</a>
    </div>
}

<style>
/* Container ảnh - chiều cao cố định cho Shop page */
.fruite-item .fruite-img {
    height: 250px !important;
    background-color: #f8f9fa !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    overflow: hidden !important;
    border-radius: 8px 8px 0 0 !important;
}

/* Ảnh sản phẩm - hiển thị toàn bộ không bị cắt */
.fruite-item .fruite-img img {
    width: 100% !important;
    height: 100% !important;
    object-fit: contain !important;
    padding: 10px !important;
}
</style>
