@model Address
@{
    ViewData["Title"] = "Chỉnh sửa Địa chỉ";
}

<!-- Page Header Start -->
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Chỉnh sửa Địa chỉ</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Địa chỉ</a></li>
        <li class="breadcrumb-item active text-white">Chỉnh sửa</li>
    </ol>
</div>
<!-- Page Header End -->

<!-- Custom styles for address validation -->
<style>
    .form-select.is-invalid,
    .form-control.is-invalid {
        border-color: #dc3545;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 12' width='12' height='12' fill='none' stroke='%23dc3545'%3e%3ccircle cx='6' cy='6' r='4.5'/%3e%3cpath stroke-linejoin='round' d='M5.8 3.6h.4L6 6.5z'/%3e%3ccircle cx='6' cy='8.2' r='.6' fill='%23dc3545' stroke='none'/%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right calc(0.375em + 0.1875rem) center;
        background-size: calc(0.75em + 0.375rem) calc(0.75em + 0.375rem);
    }
    .form-select.is-invalid:focus,
    .form-control.is-invalid:focus {
        border-color: #dc3545;
        box-shadow: 0 0 0 0.25rem rgba(220, 53, 69, 0.25);
    }
    .address-search-wrapper .is-invalid + .address-search-input {
        border-color: #dc3545;
    }
    .invalid-feedback {
        display: block;
        width: 100%;
        margin-top: 0.25rem;
        font-size: 0.875em;
        color: #dc3545;
    }
    .address-search-wrapper {
        position: relative;
    }
</style>

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
    {
        <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
            <div class="toast-header bg-danger text-white">
                <i class="fa fa-exclamation-circle me-2"></i>
                <strong class="me-auto">Lỗi</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        </div>
    }
</div>

<!-- Edit Address Form Start -->
<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-body p-5">
                        <h4 class="mb-4">Thông tin địa chỉ</h4>
                        
                        <form asp-action="Edit" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="Id" />

                            <div class="mb-3">
                                <label asp-for="FullName" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                                <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Phone" class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                                <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="StreetAddress" class="form-label">Số nhà, Tên đường <span class="text-danger">*</span></label>
                                <input asp-for="StreetAddress" class="form-control" 
                                       placeholder="Nhập số nhà, tên đường" maxlength="200" />
                                <span asp-validation-for="StreetAddress" class="text-danger"></span>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Tỉnh/Thành phố <span class="text-danger">*</span></label>
                                    <select asp-for="ProvinceCode" class="form-select" id="provinceSelect" disabled>
                                        <option value="">-- Đang tải --</option>
                                    </select>
                                    <input type="hidden" asp-for="ProvinceName" id="provinceName" />
                                    <span asp-validation-for="ProvinceCode" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Phường/Xã <span class="text-danger">*</span></label>
                                    <select asp-for="CommuneCode" class="form-select" id="communeSelect" disabled>
                                        <option value="">-- Chọn Tỉnh/TP trước --</option>
                                    </select>
                                    <input type="hidden" asp-for="CommuneName" id="communeName" />
                                    <span asp-validation-for="CommuneCode" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="mb-4">
                                <div class="form-check">
                                    <input asp-for="IsDefault" class="form-check-input" type="checkbox" />
                                    <label asp-for="IsDefault" class="form-check-label">
                                        Đặt làm địa chỉ mặc định
                                    </label>
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary rounded-pill px-4">
                                    <i class="fa fa-save me-2"></i>Cập nhật
                                </button>
                                <a asp-action="Index" class="btn btn-secondary rounded-pill px-4">
                                    <i class="fa fa-times me-2"></i>Hủy
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Edit Address Form End -->

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/addressHandler.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function() {
            // Auto-hide toast messages
            document.querySelectorAll('.toast.show').forEach(function(toast) {
                setTimeout(function() {
                    var bsToast = bootstrap.Toast.getOrCreateInstance(toast);
                    bsToast.hide();
                }, 5000);
            });

            // Saved address data from model
            var savedAddress = {
                provinceCode: '@Model.ProvinceCode',
                provinceName: '@Html.Raw(Model.ProvinceName?.Replace("'", "\\'") ?? "")',
                communeCode: '@Model.CommuneCode',
                communeName: '@Html.Raw(Model.CommuneName?.Replace("'", "\\'") ?? "")',
                streetAddress: '@Html.Raw(Model.StreetAddress?.Replace("'", "\\'") ?? "")'
            };

            // Initialize AddressHandler for cascading dropdowns
            var addressHandler = new AddressHandler({
                provinceSelector: '#provinceSelect',
                communeSelector: '#communeSelect',
                streetAddressSelector: '#StreetAddress',
                provinceNameSelector: '#provinceName',
                communeNameSelector: '#communeName',
                apiBaseUrl: '/api/address',
                enableSearch: true,
                onError: function(message, error) {
                    console.error('Address error:', message, error);
                    showAddressError(message);
                },
                onLoad: function() {
                    console.log('Address handler loaded successfully');
                    // Restore saved address after provinces are loaded
                    if (savedAddress.provinceCode) {
                        addressHandler.restoreSavedAddress(savedAddress).then(function(success) {
                            if (!success) {
                                console.warn('Some address components could not be restored');
                            }
                        });
                    }
                }
            });

            // Initialize and load provinces
            addressHandler.init();

            // Store handler for later use
            window.addressEditHandler = addressHandler;

            // Form validation before submit
            // **Validates: Requirements 4.2, 5.3**
            $('form').on('submit', function(e) {
                // Validate address fields
                var validation = addressHandler.validate();
                if (!validation.isValid) {
                    e.preventDefault();
                    
                    // Clear previous errors
                    $('.address-validation-error').remove();
                    
                    // Show validation errors
                    validation.errors.forEach(function(error) {
                        showAddressError(error);
                    });
                    
                    // Highlight invalid fields
                    highlightInvalidFields(addressHandler.getAddressValues());
                    
                    return false;
                }
                
                return true;
            });

            // Helper function to show error toast
            function showAddressError(message) {
                var toastHtml = '<div class="toast show address-error-toast" role="alert">' +
                    '<div class="toast-header bg-danger text-white">' +
                    '<i class="fa fa-exclamation-circle me-2"></i>' +
                    '<strong class="me-auto">Lỗi</strong>' +
                    '<button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>' +
                    '</div>' +
                    '<div class="toast-body">' + message + '</div>' +
                    '</div>';
                
                var toastContainer = $('.toast-container');
                if (toastContainer.length === 0) {
                    toastContainer = $('<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;"></div>');
                    $('body').append(toastContainer);
                }
                
                var toast = $(toastHtml);
                toastContainer.append(toast);
                
                // Auto-hide after 5 seconds
                setTimeout(function() {
                    toast.fadeOut(function() {
                        $(this).remove();
                    });
                }, 5000);
            }

            // Helper function to highlight invalid fields
            function highlightInvalidFields(values) {
                // Remove previous highlights
                $('.is-invalid').removeClass('is-invalid');
                $('.address-field-error').remove();
                
                if (!values.provinceCode) {
                    $('#provinceSelect').addClass('is-invalid');
                    showFieldError('#provinceSelect', 'Vui lòng chọn Tỉnh/Thành phố');
                }
                if (!values.communeCode) {
                    $('#communeSelect').addClass('is-invalid');
                    showFieldError('#communeSelect', 'Vui lòng chọn Phường/Xã');
                }
                if (!values.streetAddress) {
                    $('#StreetAddress').addClass('is-invalid');
                    showFieldError('#StreetAddress', 'Vui lòng nhập số nhà, tên đường');
                }
            }

            // Helper function to show field-level error
            function showFieldError(selector, message) {
                var field = $(selector);
                var wrapper = field.closest('.address-search-wrapper');
                var target = wrapper.length ? wrapper : field;
                
                // Check if error already exists
                if (target.next('.address-field-error').length === 0) {
                    target.after('<div class="address-field-error invalid-feedback" style="display: block;">' + message + '</div>');
                }
            }

            // Clear validation errors when user interacts with fields
            $('#provinceSelect, #communeSelect, #StreetAddress').on('change input', function() {
                $(this).removeClass('is-invalid');
                $(this).closest('.address-search-wrapper').next('.address-field-error').remove();
                $(this).next('.address-field-error').remove();
            });
        });
    </script>
}
