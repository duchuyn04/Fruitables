@model Fruitables.ViewModels.ProductListViewModel

<div class="card-header d-flex justify-content-between align-items-center">
    <span><i class="fas fa-box me-2"></i>Danh sách sản phẩm (<span id="totalItems">@Model.TotalItems</span>)</span>
</div>
<div class="card-body p-0">
    @if (Model.Products.Any())
    {
        <div class="table-responsive" style="overflow: visible;">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 80px">Ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Danh mục</th>
                        <th class="text-end">Giá</th>
                        <th class="text-center">Tồn kho</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center sticky-action-col" style="width: 100px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model.Products)
                    {
                        <tr>
                            <td>
                                @if (product.Images?.Any() == true)
                                {
                                    var primaryImage = product.Images.FirstOrDefault(i => i.IsPrimary) ?? product.Images.First();
                                    <img src="@primaryImage.ImageUrl" alt="@product.Name" class="img-thumbnail" style="width: 60px; height: 60px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                        <i class="fas fa-image text-muted"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="fw-semibold">@product.Name</div>
                                <small class="text-muted">@product.Slug</small>
                                @if (product.IsFeatured)
                                {
                                    <span class="badge bg-warning text-dark ms-1">Nổi bật</span>
                                }
                            </td>
                            <td>@product.Category?.Name</td>
                            <td class="text-end">
                                @if (product.SalePrice.HasValue && product.SalePrice < product.Price)
                                {
                                    <div class="text-decoration-line-through text-muted small">@product.Price.ToString("N0") đ</div>
                                    <div class="text-danger fw-semibold">@product.SalePrice.Value.ToString("N0") đ</div>
                                }
                                else
                                {
                                    <div class="fw-semibold">@product.Price.ToString("N0") đ</div>
                                }
                            </td>
                            <td class="text-center">
                                @if (product.StockQuantity > 0)
                                {
                                    <span class="badge bg-success">@product.StockQuantity</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Hết hàng</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (product.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Tạm ẩn</span>
                                }
                            </td>
                            <td class="text-center sticky-action-col bg-white">
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                        <i class="fas fa-ellipsis-v"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <a asp-action="Edit" asp-route-id="@product.Id" class="dropdown-item">
                                                <i class="fas fa-edit me-2 text-primary"></i>Chỉnh sửa
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a href="#" class="dropdown-item" onclick="confirmSoftDelete(@product.Id, '@product.Name.Replace("'", "\\'")'); return false;">
                                                <i class="fas fa-trash-alt me-2 text-warning"></i>Chuyển vào thùng rác
                                            </a>
                                        </li>
                                        <li>
                                            <a href="#" class="dropdown-item text-danger" onclick="confirmHardDelete(@product.Id, '@product.Name.Replace("'", "\\'")'); return false;">
                                                <i class="fas fa-trash me-2"></i>Xóa vĩnh viễn
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer">
                <nav>
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" href="#" onclick="loadPage(@(Model.CurrentPage - 1)); return false;">Trước</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            var pageNum = i;
                            <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                <a class="page-link" href="#" onclick="loadPage(@pageNum); return false;">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" href="#" onclick="loadPage(@(Model.CurrentPage + 1)); return false;">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
            <p class="text-muted">Không tìm thấy sản phẩm nào</p>
        </div>
    }
</div>
