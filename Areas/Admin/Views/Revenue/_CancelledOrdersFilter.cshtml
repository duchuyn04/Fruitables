@model Fruitables.ViewModels.RevenueFilterViewModel
@using Fruitables.ViewModels
@{
    var currentPreset = Model?.Preset;
}

<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-filter me-2"></i>Bộ lọc thời gian
    </div>
    <div class="card-body">
        <!-- Preset Buttons -->
        <div class="mb-3">
            <label class="form-label fw-semibold">Chọn nhanh</label>
            <div class="d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-sm preset-btn @(currentPreset == DateRangePreset.Today ? "btn-primary" : "btn-outline-primary")" 
                        data-preset="@DateRangePreset.Today">
                    Hôm nay
                </button>
                <button type="button" class="btn btn-sm preset-btn @(currentPreset == DateRangePreset.Yesterday ? "btn-primary" : "btn-outline-primary")" 
                        data-preset="@DateRangePreset.Yesterday">
                    Hôm qua
                </button>
                <button type="button" class="btn btn-sm preset-btn @(currentPreset == DateRangePreset.Last7Days ? "btn-primary" : "btn-outline-primary")" 
                        data-preset="@DateRangePreset.Last7Days">
                    7 ngày
                </button>
                <button type="button" class="btn btn-sm preset-btn @(currentPreset == DateRangePreset.LastWeek ? "btn-primary" : "btn-outline-primary")" 
                        data-preset="@DateRangePreset.LastWeek">
                    Tuần trước
                </button>
                <button type="button" class="btn btn-sm preset-btn @(currentPreset == DateRangePreset.Last30Days ? "btn-primary" : "btn-outline-primary")" 
                        data-preset="@DateRangePreset.Last30Days">
                    30 ngày
                </button>
                <button type="button" class="btn btn-sm preset-btn @(currentPreset == DateRangePreset.ThisMonth ? "btn-primary" : "btn-outline-primary")" 
                        data-preset="@DateRangePreset.ThisMonth">
                    Tháng này
                </button>
                <button type="button" class="btn btn-sm preset-btn @(currentPreset == DateRangePreset.LastMonth ? "btn-primary" : "btn-outline-primary")" 
                        data-preset="@DateRangePreset.LastMonth">
                    Tháng trước
                </button>
                <button type="button" class="btn btn-sm preset-btn @(currentPreset == DateRangePreset.ThisYear ? "btn-primary" : "btn-outline-primary")" 
                        data-preset="@DateRangePreset.ThisYear">
                    Năm nay
                </button>
                <button type="button" class="btn btn-sm preset-btn @(currentPreset == DateRangePreset.AllTime ? "btn-primary" : "btn-outline-primary")" 
                        data-preset="@DateRangePreset.AllTime">
                    Tất cả
                </button>
            </div>
        </div>

        <!-- Custom Date Range -->
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Từ ngày</label>
                <input type="date" id="filterStartDate" class="form-control" 
                       value="@Model?.StartDate?.ToString("yyyy-MM-dd")">
            </div>
            <div class="col-md-4">
                <label class="form-label">Đến ngày</label>
                <input type="date" id="filterEndDate" class="form-control" 
                       value="@Model?.EndDate?.ToString("yyyy-MM-dd")">
            </div>
            <div class="col-md-4">
                <button type="button" id="applyCustomDateBtn" class="btn btn-secondary">
                    <i class="fas fa-search me-1"></i>Áp dụng
                </button>
            </div>
        </div>

        <!-- Hidden fields for form submission -->
        <input type="hidden" id="filterPreset" name="Preset" value="@Model?.Preset">
    </div>
</div>
