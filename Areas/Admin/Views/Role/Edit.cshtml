@model Fruitables.Models.Role
@{
    ViewData["Title"] = $"Chỉnh sửa vai trò - {Model.Name}";
    Layout = "~/Areas/Admin/Views/Shared/_AdminDashboardLayout.cshtml";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="mb-4">
        <a href="@Url.Action("Detail", "Role", new { area = "Admin", id = Model.Id })" class="text-muted text-decoration-none mb-2 d-inline-block">
            <i class="fas fa-arrow-left me-1"></i> Quay lại chi tiết
        </a>
        <h4 class="mb-1">Chỉnh sửa vai trò</h4>
        <p class="text-muted mb-0">Cập nhật thông tin vai trò</p>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        @if (TempData["Error"] != null)
        {
            <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
                <div class="toast-header bg-danger text-white">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    <strong class="me-auto">Lỗi</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">@TempData["Error"]</div>
            </div>
        }
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-user-tag me-2"></i>Thông tin vai trò</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="Edit" asp-controller="Role" asp-area="Admin" asp-route-id="@Model.Id" id="editRoleForm">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-3">
                            <label for="name" class="form-label">
                                Tên vai trò <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control @(TempData["Error"] != null && TempData["Error"].ToString().Contains("tên") ? "is-invalid" : "")" 
                                   id="name" name="name" 
                                   value="@Model.Name" required maxlength="100">
                            <div class="invalid-feedback" id="nameError">
                                @if (TempData["Error"] != null && TempData["Error"].ToString().Contains("tên"))
                                {
                                    @TempData["Error"]
                                }
                            </div>
                            <div class="form-text">Tên vai trò phải là duy nhất trong hệ thống</div>
                        </div>

                        <div class="mb-4">
                            <label for="description" class="form-label">Mô tả</label>
                            <textarea class="form-control" id="description" name="description" 
                                      rows="4" maxlength="500">@Model.Description</textarea>
                            <div class="form-text">Tối đa 500 ký tự</div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i>Lưu thay đổi
                            </button>
                            <a href="@Url.Action("Detail", "Role", new { area = "Admin", id = Model.Id })" class="btn btn-secondary">
                                <i class="fas fa-times me-1"></i>Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Thông tin</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="text-muted small">Trạng thái</label>
                        <p class="mb-0">
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Vô hiệu hóa</span>
                            }
                        </p>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted small">Ngày tạo</label>
                        <p class="mb-0">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted small">Cập nhật lần cuối</label>
                        <p class="mb-0">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>

                    <hr>

                    <h6 class="fw-semibold mb-2">Lưu ý</h6>
                    <ul class="small text-muted mb-0">
                        <li>Tên vai trò phải là duy nhất</li>
                        <li>Thay đổi sẽ ảnh hưởng đến tất cả người dùng có vai trò này</li>
                        <li>Để vô hiệu hóa vai trò, sử dụng công tắc trạng thái ở trang danh sách</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Initialize toasts
    document.addEventListener('DOMContentLoaded', function() {
        const toastElList = [].slice.call(document.querySelectorAll('.toast'));
        toastElList.map(function(toastEl) {
            return new bootstrap.Toast(toastEl);
        });
    });

    // Form validation with Bootstrap styles
    const form = document.getElementById('editRoleForm');
    const nameInput = document.getElementById('name');
    const nameError = document.getElementById('nameError');

    form.addEventListener('submit', function(e) {
        let isValid = true;
        
        // Reset validation states
        nameInput.classList.remove('is-invalid', 'is-valid');
        
        // Validate name
        const name = nameInput.value.trim();
        if (!name) {
            e.preventDefault();
            nameInput.classList.add('is-invalid');
            nameError.textContent = 'Tên vai trò không được để trống';
            isValid = false;
        } else if (name.length > 100) {
            e.preventDefault();
            nameInput.classList.add('is-invalid');
            nameError.textContent = 'Tên vai trò không được vượt quá 100 ký tự';
            isValid = false;
        } else {
            nameInput.classList.add('is-valid');
        }
        
        if (!isValid) {
            nameInput.focus();
        }
    });

    // Real-time validation
    nameInput.addEventListener('input', function() {
        const name = this.value.trim();
        if (name && name.length <= 100) {
            this.classList.remove('is-invalid');
            this.classList.add('is-valid');
        } else if (name.length > 100) {
            this.classList.remove('is-valid');
            this.classList.add('is-invalid');
            nameError.textContent = 'Tên vai trò không được vượt quá 100 ký tự';
        }
    });
</script>
}
