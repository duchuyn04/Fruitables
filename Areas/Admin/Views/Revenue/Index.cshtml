@model Fruitables.Areas.Admin.Controllers.RevenueIndexViewModel
@using Fruitables.ViewModels
@{
    ViewData["Title"] = "Thống kê doanh thu";
    Layout = "~/Areas/Admin/Views/Shared/_AdminDashboardLayout.cshtml";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="fas fa-chart-line me-2"></i>Thống kê doanh thu</h4>
        <p class="text-muted mb-0">Phân tích chi tiết doanh thu và hiệu suất bán hàng</p>
    </div>
    <div>
        <button class="btn btn-outline-primary" onclick="exportReport()">
            <i class="fas fa-download me-1"></i>Xuất báo cáo
        </button>
    </div>
</div>

<!-- Anti-forgery token for AJAX -->
@Html.AntiForgeryToken()

<!-- Filter Section -->
@await Html.PartialAsync("_RevenueFilter", Model.Filter)

<!-- Overview Stats Cards -->
<div class="row g-4 mb-4" id="overviewCards">
    <!-- Total Revenue -->
    <div class="col-md-6 col-xl-3">
        <div class="admin-card p-3 h-100">
            <div class="d-flex align-items-center">
                <div class="flex-shrink-0">
                    <div class="bg-success bg-opacity-10 rounded-circle p-3">
                        <i class="fas fa-dollar-sign text-success fa-2x"></i>
                    </div>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h3 class="mb-0" id="totalRevenue">@Model.Overview.TotalRevenue.ToString("N0")</h3>
                    <small class="text-muted">Tổng doanh thu (VND)</small>
                </div>
            </div>
        </div>
    </div>


    <!-- Filtered Period Revenue -->
    <div class="col-md-6 col-xl-3">
        <div class="admin-card p-3 h-100">
            <div class="d-flex align-items-center">
                <div class="flex-shrink-0">
                    <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                        <i class="fas fa-calendar-alt text-primary fa-2x"></i>
                    </div>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h3 class="mb-0" id="monthlyRevenue">@Model.Overview.TotalRevenue.ToString("N0")</h3>
                    <small class="text-muted" id="monthlyRevenueLabel">Doanh thu tất cả</small>
                    <div class="mt-1" id="monthlyGrowthContainer" style="display: none;">
                        <span class="badge bg-success" id="monthlyGrowth"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Orders -->
    <div class="col-md-6 col-xl-3">
        <div class="admin-card p-3 h-100">
            <div class="d-flex align-items-center">
                <div class="flex-shrink-0">
                    <div class="bg-info bg-opacity-10 rounded-circle p-3">
                        <i class="fas fa-shopping-cart text-info fa-2x"></i>
                    </div>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h3 class="mb-0" id="totalOrders">@Model.Overview.TotalOrders</h3>
                    <small class="text-muted">Tổng đơn hàng</small>
                    @if (Model.Overview.TodayOrders > 0)
                    {
                        <div class="mt-1">
                            <span class="badge bg-primary" id="todayOrders">+@Model.Overview.TodayOrders hôm nay</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Average Order Value -->
    <div class="col-md-6 col-xl-3">
        <div class="admin-card p-3 h-100">
            <div class="d-flex align-items-center">
                <div class="flex-shrink-0">
                    <div class="bg-warning bg-opacity-10 rounded-circle p-3">
                        <i class="fas fa-receipt text-warning fa-2x"></i>
                    </div>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h3 class="mb-0" id="avgOrderValue">@Model.Overview.AverageOrderValue.ToString("N0")</h3>
                    <small class="text-muted">Giá trị TB/đơn (VND)</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-4 mb-4">
    <!-- Revenue Trend Chart -->
    <div class="col-lg-8">
        <div class="admin-card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-chart-area me-2"></i>Xu hướng doanh thu</span>
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-outline-primary active" data-period="Daily">Ngày</button>
                    <button type="button" class="btn btn-outline-primary" data-period="Weekly">Tuần</button>
                    <button type="button" class="btn btn-outline-primary" data-period="Monthly">Tháng</button>
                </div>
            </div>
            <div class="card-body">
                <canvas id="revenueTrendChart" height="300"></canvas>
            </div>
        </div>
    </div>

    <!-- Category Revenue Chart -->
    <div class="col-lg-4">
        <div class="admin-card h-100">
            <div class="card-header">
                <i class="fas fa-chart-pie me-2"></i>Doanh thu theo danh mục
            </div>
            <div class="card-body">
                <canvas id="categoryChart" height="300"></canvas>
            </div>
        </div>
    </div>
</div>


<!-- Tables Row -->
<div class="row g-4">
    <!-- Top Products -->
    <div class="col-lg-7">
        <div class="admin-card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-trophy me-2"></i>Sản phẩm bán chạy</span>
                <span class="badge bg-primary">Top 10</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0" id="topProductsTable">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Sản phẩm</th>
                                <th>Danh mục</th>
                                <th class="text-end">SL bán</th>
                                <th class="text-end">Doanh thu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TopProducts.Products.Any())
                            {
                                var rank = 1;
                                foreach (var product in Model.TopProducts.Products)
                                {
                                    <tr>
                                        <td>
                                            @if (rank <= 3)
                                            {
                                                <span class="badge @(rank == 1 ? "bg-warning" : rank == 2 ? "bg-secondary" : "bg-danger")">
                                                    @rank
                                                </span>
                                            }
                                            else
                                            {
                                                @rank
                                            }
                                        </td>
                                        <td>
                                            <strong>@product.ProductName</strong>
                                        </td>
                                        <td><span class="badge bg-light text-dark">@product.CategoryName</span></td>
                                        <td class="text-end">@product.QuantitySold</td>
                                        <td class="text-end text-success fw-bold">@product.Revenue.ToString("N0")đ</td>
                                    </tr>
                                    rank++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">Chưa có dữ liệu</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Category Revenue Table -->
    <div class="col-lg-5">
        <div class="admin-card h-100">
            <div class="card-header">
                <i class="fas fa-tags me-2"></i>Chi tiết theo danh mục
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0" id="categoryTable">
                        <thead class="table-light">
                            <tr>
                                <th>Danh mục</th>
                                <th class="text-end">Đơn hàng</th>
                                <th class="text-end">Doanh thu</th>
                                <th class="text-end">Tỷ lệ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.CategoryRevenue.Categories.Any())
                            {
                                foreach (var category in Model.CategoryRevenue.Categories)
                                {
                                    <tr>
                                        <td><strong>@category.CategoryName</strong></td>
                                        <td class="text-end">@category.OrderCount</td>
                                        <td class="text-end text-success">@category.Revenue.ToString("N0")đ</td>
                                        <td class="text-end">
                                            <div class="d-flex align-items-center justify-content-end">
                                                <div class="progress flex-grow-1 me-2" style="height: 6px; max-width: 60px;">
                                                    <div class="progress-bar bg-primary" style="width: @category.Percentage%"></div>
                                                </div>
                                                <span>@category.Percentage%</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">Chưa có dữ liệu</td>
                                </tr>
                            }
                        </tbody>
                        @if (Model.CategoryRevenue.Categories.Any())
                        {
                            <tfoot class="table-light">
                                <tr>
                                    <th>Tổng cộng</th>
                                    <th class="text-end">@Model.CategoryRevenue.Categories.Sum(c => c.OrderCount)</th>
                                    <th class="text-end text-success">@Model.CategoryRevenue.TotalRevenue.ToString("N0")đ</th>
                                    <th class="text-end">100%</th>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Chart instances
        let revenueTrendChart = null;
        let categoryChart = null;

        // Initial data from server
        const initialTrendData = {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Trend.Labels)),
            revenue: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Trend.RevenueData)),
            orders: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Trend.OrdersData))
        };

        const initialCategoryData = {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategoryRevenue.Categories.Select(c => c.CategoryName))),
            data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategoryRevenue.Categories.Select(c => c.Revenue)))
        };

        // Initialize charts on page load
        document.addEventListener('DOMContentLoaded', function() {
            initRevenueTrendChart(initialTrendData);
            initCategoryChart(initialCategoryData);
            initFilterHandlers();
        });

        function initRevenueTrendChart(data) {
            const ctx = document.getElementById('revenueTrendChart').getContext('2d');
            
            if (revenueTrendChart) {
                revenueTrendChart.destroy();
            }

            revenueTrendChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: data.labels,
                    datasets: [{
                        label: 'Doanh thu (VND)',
                        data: data.revenue,
                        borderColor: '#81c408',
                        backgroundColor: 'rgba(129, 196, 8, 0.1)',
                        fill: true,
                        tension: 0.4,
                        yAxisID: 'y'
                    }, {
                        label: 'Số đơn hàng',
                        data: data.orders,
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13, 110, 253, 0.1)',
                        fill: false,
                        tension: 0.4,
                        yAxisID: 'y1'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false
                    },
                    scales: {
                        y: {
                            type: 'linear',
                            display: true,
                            position: 'left',
                            ticks: {
                                callback: function(value) {
                                    return value.toLocaleString('vi-VN') + 'đ';
                                }
                            }
                        },
                        y1: {
                            type: 'linear',
                            display: true,
                            position: 'right',
                            grid: {
                                drawOnChartArea: false
                            }
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    if (context.datasetIndex === 0) {
                                        return 'Doanh thu: ' + context.raw.toLocaleString('vi-VN') + 'đ';
                                    }
                                    return 'Đơn hàng: ' + context.raw;
                                }
                            }
                        }
                    }
                }
            });
        }

        function initCategoryChart(data) {
            const ctx = document.getElementById('categoryChart').getContext('2d');
            
            if (categoryChart) {
                categoryChart.destroy();
            }

            const colors = [
                '#81c408', '#0d6efd', '#ffc107', '#dc3545', '#6f42c1',
                '#20c997', '#fd7e14', '#6c757d', '#0dcaf0', '#d63384'
            ];

            categoryChart = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: data.labels,
                    datasets: [{
                        data: data.data,
                        backgroundColor: colors.slice(0, data.labels.length),
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 15,
                                usePointStyle: true
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const percentage = ((context.raw / total) * 100).toFixed(1);
                                    return context.label + ': ' + context.raw.toLocaleString('vi-VN') + 'đ (' + percentage + '%)';
                                }
                            }
                        }
                    }
                }
            });
        }


        function initFilterHandlers() {
            // Preset button handlers
            document.querySelectorAll('.preset-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.preset-btn').forEach(b => {
                        b.classList.remove('btn-primary');
                        b.classList.add('btn-outline-primary');
                    });
                    this.classList.remove('btn-outline-primary');
                    this.classList.add('btn-primary');
                    
                    const preset = this.dataset.preset;
                    document.getElementById('filterPreset').value = preset;
                    applyFilter(preset);
                });
            });

            // Custom date apply button
            document.getElementById('applyCustomDateBtn').addEventListener('click', function() {
                const startDate = document.getElementById('filterStartDate').value;
                const endDate = document.getElementById('filterEndDate').value;
                
                if (!startDate || !endDate) {
                    alert('Vui lòng chọn ngày bắt đầu và kết thúc.');
                    return;
                }
                
                applyFilter('Custom', startDate, endDate);
            });

            // Period toggle buttons
            document.querySelectorAll('[data-period]').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('[data-period]').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    loadRevenueTrend(this.dataset.period);
                });
            });
        }

        // Current period state
        let currentPeriod = 'Daily';

        // Load revenue trend by period
        function loadRevenueTrend(period) {
            currentPeriod = period;
            fetch(`/Admin/Revenue/RevenueTrend?period=${period}`)
                .then(response => response.json())
                .then(data => {
                    initRevenueTrendChart({
                        labels: data.labels,
                        revenue: data.revenueData,
                        orders: data.ordersData
                    });
                })
                .catch(error => {
                    console.error('Error loading trend:', error);
                });
        }

        // Store current preset for label updates
        let currentFilterPreset = 'ThisMonth';

        function applyFilter(preset, startDate = null, endDate = null) {
            currentFilterPreset = preset;
            const categoryId = document.getElementById('filterCategoryId')?.value || null;
            
            const requestData = {
                preset: preset,
                startDate: startDate,
                endDate: endDate,
                categoryId: categoryId ? parseInt(categoryId) : null
            };

            fetch('/Admin/Revenue/FilterByPreset', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify(requestData)
            })
            .then(response => {
                if (!response.ok) {
                    return response.json().then(err => { throw new Error(err.error); });
                }
                return response.json();
            })
            .then(data => {
                updateDashboard(data, preset);
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Lỗi: ' + error.message);
            });
        }

        function getPresetLabel(preset) {
            const labels = {
                'Today': 'Doanh thu hôm nay',
                'Yesterday': 'Doanh thu hôm qua',
                'Last7Days': 'Doanh thu 7 ngày',
                'LastWeek': 'Doanh thu tuần trước',
                'Last30Days': 'Doanh thu 30 ngày',
                'ThisMonth': 'Doanh thu tháng này',
                'LastMonth': 'Doanh thu tháng trước',
                'ThisYear': 'Doanh thu năm nay',
                'AllTime': 'Doanh thu tất cả',
                'Custom': 'Doanh thu (tùy chọn)'
            };
            return labels[preset] || 'Doanh thu (theo bộ lọc)';
        }

        function updateDashboard(data, preset) {
            // Update overview cards
            if (data.overview) {
                document.getElementById('totalRevenue').textContent = data.overview.totalRevenue.toLocaleString('vi-VN');
                document.getElementById('totalOrders').textContent = data.overview.totalOrders;
                document.getElementById('avgOrderValue').textContent = data.overview.averageOrderValue.toLocaleString('vi-VN');
                
                // Update monthly revenue card with filtered data
                const monthlyRevenueEl = document.getElementById('monthlyRevenue');
                if (monthlyRevenueEl) {
                    monthlyRevenueEl.textContent = data.overview.totalRevenue.toLocaleString('vi-VN');
                }
                
                // Update label dynamically
                const monthlyLabelEl = document.getElementById('monthlyRevenueLabel');
                if (monthlyLabelEl) {
                    monthlyLabelEl.textContent = getPresetLabel(preset);
                }
                
                // Hide growth badge when not ThisMonth
                const growthContainer = document.getElementById('monthlyGrowthContainer');
                if (growthContainer) {
                    growthContainer.style.display = preset === 'ThisMonth' ? '' : 'none';
                }
            }

            // Update trend chart
            if (data.trend) {
                initRevenueTrendChart({
                    labels: data.trend.labels,
                    revenue: data.trend.revenueData,
                    orders: data.trend.ordersData
                });
            }

            // Update category chart
            if (data.categoryRevenue && data.categoryRevenue.categories) {
                initCategoryChart({
                    labels: data.categoryRevenue.categories.map(c => c.categoryName),
                    data: data.categoryRevenue.categories.map(c => c.revenue)
                });
                updateCategoryTable(data.categoryRevenue);
            }

            // Update top products table
            if (data.topProducts && data.topProducts.products) {
                updateTopProductsTable(data.topProducts.products);
            }
        }

        function updateCategoryTable(categoryRevenue) {
            const tbody = document.querySelector('#categoryTable tbody');
            const tfoot = document.querySelector('#categoryTable tfoot');
            
            if (categoryRevenue.categories.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-4">Chưa có dữ liệu</td></tr>';
                if (tfoot) tfoot.style.display = 'none';
                return;
            }

            tbody.innerHTML = categoryRevenue.categories.map(cat => `
                <tr>
                    <td><strong>${cat.categoryName}</strong></td>
                    <td class="text-end">${cat.orderCount}</td>
                    <td class="text-end text-success">${cat.revenue.toLocaleString('vi-VN')}đ</td>
                    <td class="text-end">
                        <div class="d-flex align-items-center justify-content-end">
                            <div class="progress flex-grow-1 me-2" style="height: 6px; max-width: 60px;">
                                <div class="progress-bar bg-primary" style="width: ${cat.percentage}%"></div>
                            </div>
                            <span>${cat.percentage}%</span>
                        </div>
                    </td>
                </tr>
            `).join('');

            if (tfoot) {
                tfoot.style.display = '';
                const totalOrders = categoryRevenue.categories.reduce((sum, c) => sum + c.orderCount, 0);
                tfoot.innerHTML = `
                    <tr>
                        <th>Tổng cộng</th>
                        <th class="text-end">${totalOrders}</th>
                        <th class="text-end text-success">${categoryRevenue.totalRevenue.toLocaleString('vi-VN')}đ</th>
                        <th class="text-end">100%</th>
                    </tr>
                `;
            }
        }

        function updateTopProductsTable(products) {
            const tbody = document.querySelector('#topProductsTable tbody');
            
            if (products.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4">Chưa có dữ liệu</td></tr>';
                return;
            }

            tbody.innerHTML = products.map((product, index) => {
                const rank = index + 1;
                let rankBadge = rank;
                if (rank <= 3) {
                    const badgeClass = rank === 1 ? 'bg-warning' : rank === 2 ? 'bg-secondary' : 'bg-danger';
                    rankBadge = `<span class="badge ${badgeClass}">${rank}</span>`;
                }
                return `
                    <tr>
                        <td>${rankBadge}</td>
                        <td><strong>${product.productName}</strong></td>
                        <td><span class="badge bg-light text-dark">${product.categoryName}</span></td>
                        <td class="text-end">${product.quantitySold}</td>
                        <td class="text-end text-success fw-bold">${product.revenue.toLocaleString('vi-VN')}đ</td>
                    </tr>
                `;
            }).join('');
        }

        function exportReport() {
            const preset = document.getElementById('filterPreset')?.value || 'AllTime';
            const startDate = document.getElementById('filterStartDate')?.value || '';
            const endDate = document.getElementById('filterEndDate')?.value || '';
            
            let url = `/Admin/Revenue/ExportReport?preset=${preset}`;
            if (preset === 'Custom' && startDate && endDate) {
                url += `&startDate=${startDate}&endDate=${endDate}`;
            }
            
            window.location.href = url;
        }
    </script>
}
