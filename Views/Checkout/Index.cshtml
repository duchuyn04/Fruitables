@using Fruitables.ViewModels
@using Fruitables.Models
@model CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
    var cart = ViewBag.Cart as CartViewModel ?? new CartViewModel();
    var savedAddresses = ViewBag.SavedAddresses as List<AddressViewModel> ?? new List<AddressViewModel>();
}

<!-- Single Page Header start -->
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Thanh toán</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item active text-white">Thanh toán</li>
    </ol>
</div>
<!-- Single Page Header End -->

<!-- Toast Container for validation errors -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;"></div>

<!-- Custom styles for address validation -->
<!-- **Feature: checkout-address-split, Task 21.3: Cập nhật validation messages** -->
<!-- **Validates: Requirements 4.2, 5.3** -->
<style>
    /* Invalid field styling */
    .form-select.is-invalid,
    .form-control.is-invalid {
        border-color: #dc3545 !important;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 12' width='12' height='12' fill='none' stroke='%23dc3545'%3e%3ccircle cx='6' cy='6' r='4.5'/%3e%3cpath stroke-linejoin='round' d='M5.8 3.6h.4L6 6.5z'/%3e%3ccircle cx='6' cy='8.2' r='.6' fill='%23dc3545' stroke='none'/%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right calc(0.375em + 0.1875rem) center;
        background-size: calc(0.75em + 0.375rem) calc(0.75em + 0.375rem);
    }
    .form-select.is-invalid:focus,
    .form-control.is-invalid:focus {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.25rem rgba(220, 53, 69, 0.25) !important;
    }
    
    /* Search wrapper invalid state */
    .address-search-wrapper.is-invalid .form-select,
    .address-search-wrapper .is-invalid {
        border-color: #dc3545 !important;
    }
    .address-search-wrapper .is-invalid + .address-search-input {
        border-color: #dc3545;
    }
    
    /* Validation feedback styling */
    .invalid-feedback,
    .address-field-error {
        display: block;
        width: 100%;
        margin-top: 0.25rem;
        font-size: 0.875em;
        color: #dc3545;
    }
    
    /* Field-specific error message styling */
    .field-validation-error {
        display: block;
        color: #dc3545;
        font-size: 0.875em;
        margin-top: 0.25rem;
    }
    
    /* Character counter styling */
    .char-counter {
        font-size: 0.75em;
        color: #6c757d;
        text-align: right;
        margin-top: 0.25rem;
    }
    .char-counter.warning {
        color: #ffc107;
    }
    .char-counter.danger {
        color: #dc3545;
    }
    
    /* Validation summary styling */
    .validation-summary {
        background-color: #f8d7da;
        border: 1px solid #f5c6cb;
        border-radius: 0.375rem;
        padding: 1rem;
        margin-bottom: 1rem;
    }
    .validation-summary ul {
        margin-bottom: 0;
        padding-left: 1.25rem;
    }
    .validation-summary li {
        color: #721c24;
        margin-bottom: 0.25rem;
    }
    .validation-summary li:last-child {
        margin-bottom: 0;
    }
</style>

<!-- Checkout Page Start -->
<div class="container-fluid py-5">
    <div class="container py-5">
        <h1 class="mb-4">Thông tin thanh toán</h1>
        <form asp-controller="Checkout" asp-action="PlaceOrder" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-5">
                <div class="col-md-12 col-lg-6 col-xl-7">
                    @if (savedAddresses.Any())
                    {
                        <div class="mb-4">
                            <h5 class="mb-3">Chọn địa chỉ giao hàng</h5>
                            <select id="addressSelect" class="form-control form-select mb-3" asp-for="SelectedAddressId">
                                <option value="">-- Chọn địa chỉ hoặc nhập mới --</option>
                                @foreach (var addr in savedAddresses)
                                {
                                    <option value="@addr.Id" 
                                            data-fullname="@addr.FullName"
                                            data-phone="@addr.Phone"
                                            data-address="@addr.FullAddress"
                                            data-provincecode="@addr.ProvinceCode"
                                            data-provincename="@addr.ProvinceName"
                                            data-districtcode="@addr.DistrictCode"
                                            data-districtname="@addr.DistrictName"
                                            data-wardcode="@addr.WardCode"
                                            data-wardname="@addr.WardName"
                                            data-streetaddress="@addr.StreetAddress"
                                            selected="@addr.IsDefault">
                                        @addr.DisplayText @(addr.IsDefault ? "(Mặc định)" : "")
                                    </option>
                                }
                                <option value="new">+ Thêm địa chỉ mới</option>
                            </select>
                            
                            <div id="selectedAddressDisplay" class="alert alert-info" style="display: none;">
                                <h6 class="mb-2"><i class="fas fa-map-marker-alt me-2"></i>Địa chỉ đã chọn:</h6>
                                <div id="addressDetails"></div>
                            </div>
                            <hr class="my-4">
                        </div>
                    }
                    
                    <div id="addressFormSection">
                        <h5 class="mb-3" id="addressFormTitle">@(savedAddresses.Any() ? "Hoặc nhập địa chỉ mới" : "Thông tin giao hàng")</h5>
                        
                        <div class="form-item">
                            <label class="form-label my-3">Họ tên<sup>*</sup></label>
                            <input asp-for="FirstName" class="form-control" placeholder="Nhập họ tên đầy đủ" id="FullNameInput" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                    <div class="form-item">
                        <label asp-for="Mobile" class="form-label my-3">Số điện thoại<sup>*</sup></label>
                        <input asp-for="Mobile" type="tel" class="form-control" placeholder="Nhập số điện thoại" />
                        <span asp-validation-for="Mobile" class="text-danger"></span>
                    </div>
                    <div class="form-item">
                        <label asp-for="StreetAddress" class="form-label my-3">Số nhà, Tên đường<sup>*</sup></label>
                        <input asp-for="StreetAddress" class="form-control" placeholder="Nhập số nhà, tên đường" maxlength="200" id="StreetAddressInput" />
                        <div class="char-counter" id="streetAddressCounter">0/200 ký tự</div>
                        <span asp-validation-for="StreetAddress" class="text-danger"></span>
                        <div class="address-field-error invalid-feedback" id="streetAddressError" style="display: none;"></div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 form-item">
                            <label class="form-label my-3">Tỉnh/Thành phố<sup>*</sup></label>
                            <select asp-for="ProvinceCode" class="form-control form-select" id="provinceSelect" disabled>
                                <option value="">-- Đang tải --</option>
                            </select>
                            <input type="hidden" asp-for="ProvinceName" id="provinceName" />
                            <span asp-validation-for="ProvinceCode" class="text-danger"></span>
                            <div class="address-field-error invalid-feedback" id="provinceError" style="display: none;">Vui lòng chọn Tỉnh/Thành phố</div>
                        </div>
                        <div class="col-md-4 form-item">
                            <label class="form-label my-3">Quận/Huyện<sup>*</sup></label>
                            <select asp-for="DistrictCode" class="form-control form-select" id="districtSelect" disabled>
                                <option value="">-- Chọn Tỉnh/TP trước --</option>
                            </select>
                            <input type="hidden" asp-for="DistrictName" id="districtName" />
                            <span asp-validation-for="DistrictCode" class="text-danger"></span>
                            <div class="address-field-error invalid-feedback" id="districtError" style="display: none;">Vui lòng chọn Quận/Huyện</div>
                        </div>
                        <div class="col-md-4 form-item">
                            <label class="form-label my-3">Phường/Xã<sup>*</sup></label>
                            <select asp-for="WardCode" class="form-control form-select" id="wardSelect" disabled>
                                <option value="">-- Chọn Quận/Huyện trước --</option>
                            </select>
                            <input type="hidden" asp-for="WardName" id="wardName" />
                            <span asp-validation-for="WardCode" class="text-danger"></span>
                            <div class="address-field-error invalid-feedback" id="wardError" style="display: none;">Vui lòng chọn Phường/Xã</div>
                        </div>
                    </div>
                    <div class="form-item">
                        <label asp-for="Notes" class="form-label my-3">Ghi chú đơn hàng (Tùy chọn)</label>
                        <textarea asp-for="Notes" class="form-control" cols="30" rows="4" placeholder="Ghi chú về đơn hàng, ví dụ: thời gian giao hàng"></textarea>
                    </div>
                    
                    @if (savedAddresses.Any())
                    {
                        <div class="form-check my-3" id="saveAddressSection" style="display: none;">
                            <input type="checkbox" asp-for="SaveAddress" class="form-check-input" id="SaveAddressCheck" checked />
                            <label class="form-check-label" for="SaveAddressCheck">
                                Lưu địa chỉ này cho lần mua sau
                            </label>
                        </div>
                        <div class="form-check my-3" id="setDefaultSection" style="display: none;">
                            <input type="checkbox" asp-for="SetAsDefault" class="form-check-input" id="SetDefaultCheck" />
                            <label class="form-check-label" for="SetDefaultCheck">
                                Đặt làm địa chỉ mặc định
                            </label>
                        </div>
                    }
                    </div>
                    
                    <!-- Hidden fields for compatibility -->
                    <input asp-for="LastName" type="hidden" value="" />
                    <input asp-for="Email" type="hidden" value="customer@example.com" />
                    <input asp-for="City" type="hidden" value="" />
                </div>
                <div class="col-md-12 col-lg-6 col-xl-5">

                    <!-- Order Summary Card -->
                    <div class="card border-0 shadow-sm mb-3" style="border-radius:12px; overflow:hidden;">
                        <div class="card-header py-3" style="background:#f8f9fa; border-bottom:1px solid #eee;">
                            <h6 class="mb-0 fw-bold text-dark">
                                <i class="fas fa-shopping-bag me-2 text-success"></i>
                                Đơn hàng của bạn
                                <span class="badge bg-success ms-2">@cart.Items.Sum(i => i.Quantity) sản phẩm</span>
                            </h6>
                        </div>
                        <div class="card-body p-0">
                            <!-- Item list -->
                            @foreach (var item in cart.Items)
                            {
                                <div class="d-flex align-items-center px-3 py-2 border-bottom">
                                    <div class="position-relative me-3" style="flex-shrink:0;">
                                        <img src="@(string.IsNullOrEmpty(item.ProductImage) ? "~/img/vegetable-item-2.jpg" : item.ProductImage)"
                                             class="rounded" style="width:60px;height:60px;object-fit:cover;" alt="@item.ProductName" />
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-secondary"
                                              style="font-size:10px;">@item.Quantity</span>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold text-dark" style="font-size:.9rem;">@item.ProductName</div>
                                        <small class="text-muted">@item.Price.ToString("N0")đ × @item.Quantity</small>
                                    </div>
                                    <div class="fw-bold text-dark">@item.Total.ToString("N0")đ</div>
                                </div>
                            }

                            <!-- Price breakdown -->
                            <div class="px-3 py-3">
                                <div class="d-flex justify-content-between text-muted mb-2" id="checkout-subtotal-row">
                                    <span>Tạm tính</span>
                                    <span class="text-dark">@cart.Subtotal.ToString("N0")đ</span>
                                </div>

                                @if (cart.Discount > 0)
                                {
                                    <div class="d-flex justify-content-between mb-2" id="checkout-discount-row">
                                        <span class="text-success">
                                            <i class="fas fa-tag me-1"></i>Giảm giá
                                            @if (!string.IsNullOrEmpty(cart.CouponCode))
                                            {
                                                <small class="text-muted" id="checkout-coupon-label">(@cart.CouponCode)</small>
                                            }
                                        </span>
                                        <span class="text-success fw-semibold" id="checkout-discount-amount">-@cart.Discount.ToString("N0")đ</span>
                                    </div>
                                }

                                <div class="d-flex justify-content-between mb-2 text-muted">
                                    <span>Vận chuyển</span>
                                    <div id="checkout-shipping-info" class="text-end">
                                        @if (cart.ShippingInfo != null)
                                        {
                                            if (cart.ShippingInfo.IsFreeShipping)
                                            {
                                                <span class="text-success fw-semibold" id="checkout-shipping-fee">
                                                    <i class="fas fa-check-circle me-1"></i>Miễn phí
                                                </span>
                                            }
                                            else
                                            {
                                                <span id="checkout-shipping-fee">@cart.ShippingInfo.ShippingFee.ToString("N0")đ</span>
                                            }
                                            @if (!string.IsNullOrEmpty(cart.ShippingInfo.Message))
                                            {
                                                <br />
                                                <small class="@(cart.ShippingInfo.IsFreeShipping || cart.ShippingInfo.IsReducedShipping ? "text-success" : "text-info")"
                                                       id="checkout-shipping-message">
                                                    @cart.ShippingInfo.Message
                                                </small>
                                            }
                                        }
                                        else
                                        {
                                            <span id="checkout-shipping-fee">@cart.ShippingFee.ToString("N0")đ</span>
                                        }
                                    </div>
                                </div>

                                <input type="hidden" asp-for="ShippingMethod" value="FlatRate" />

                                <hr class="my-2" />
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold fs-6">Tổng cộng</span>
                                    <span class="fw-bold fs-5 text-success" id="totalAmount">@cart.Total.ToString("N0")đ</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Coupon -->
                    @{
                        var couponSuccess = TempData["CouponSuccess"] as string;
                        var couponError   = TempData["CouponError"] as string;
                    }
                    @if (!string.IsNullOrEmpty(couponSuccess))
                    {
                        <div class="alert alert-success py-2 mb-2 rounded-3"><i class="fas fa-check-circle me-2"></i>@couponSuccess</div>
                    }
                    @if (!string.IsNullOrEmpty(couponError))
                    {
                        <div class="alert alert-danger py-2 mb-2 rounded-3"><i class="fas fa-exclamation-circle me-2"></i>@couponError</div>
                    }

                    <div class="d-flex align-items-center justify-content-between border rounded-3 px-3 py-2 mb-3"
                         style="background:#fff9f0; border-color:#ee4d2d !important; cursor:pointer;"
                         onclick="openCouponModal()">
                        <span>
                            <i class="fas fa-ticket-alt me-2 text-danger"></i>
                            @if (!string.IsNullOrEmpty(cart.CouponCode))
                            {
                                <span>Mã <strong class="text-danger">@cart.CouponCode</strong> &mdash; giảm <strong class="text-success">@cart.Discount.ToString("N0")đ</strong></span>
                            }
                            else
                            {
                                <span class="text-muted">Chọn mã giảm giá Fruitables</span>
                            }
                        </span>
                        <i class="fas fa-chevron-right text-muted small"></i>
                    </div>

                    @if (!string.IsNullOrEmpty(cart.CouponCode))
                    {
                        <form asp-controller="Cart" asp-action="RemoveCoupon" method="post" id="removeCouponForm" class="d-none">
                            <input type="hidden" name="returnUrl" value="/Checkout" />
                            @Html.AntiForgeryToken()
                        </form>
                    }
                    <form asp-controller="Cart" asp-action="ApplyCoupon" method="post" id="applyCouponForm" class="d-none">
                        <input type="hidden" name="returnUrl" value="/Checkout" />
                        <input type="hidden" name="couponCode" id="selectedCouponCode" />
                        @Html.AntiForgeryToken()
                    </form>

                    <!-- Payment Method Card -->
                    <div class="card border-0 shadow-sm mb-3" style="border-radius:12px; overflow:hidden;">
                        <div class="card-header py-3" style="background:#f8f9fa; border-bottom:1px solid #eee;">
                            <h6 class="mb-0 fw-bold text-dark">
                                <i class="fas fa-credit-card me-2 text-success"></i>Phương thức thanh toán
                            </h6>
                        </div>
                        <div class="card-body p-3">
                            <label class="payment-option d-flex align-items-center p-3 mb-2 rounded-3 border"
                                   style="cursor:pointer; transition:.2s;" id="lbl-cod"
                                   onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background=''">
                                <input type="radio" asp-for="PaymentMethod" value="COD" class="form-check-input me-3 mt-0" id="Delivery-1" checked
                                       onchange="updatePaymentStyle()" />
                                <div>
                                    <div class="fw-semibold"><i class="fas fa-motorcycle me-2 text-success"></i>Thanh toán khi nhận hàng (COD)</div>
                                    <small class="text-muted">Trả tiền mặt khi nhận hàng</small>
                                </div>
                            </label>
                            <label class="payment-option d-flex align-items-center p-3 rounded-3 border"
                                   style="cursor:pointer; transition:.2s;" id="lbl-bank"
                                   onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background=''">
                                <input type="radio" asp-for="PaymentMethod" value="BankTransfer" class="form-check-input me-3 mt-0" id="Transfer-1"
                                       onchange="updatePaymentStyle()" />
                                <div>
                                    <div class="fw-semibold"><i class="fas fa-university me-2 text-primary"></i>Chuyển khoản ngân hàng</div>
                                    <small class="text-muted">Sử dụng mã đơn hàng làm nội dung CK</small>
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- Place Order Button -->
                    <button type="submit"
                            class="btn w-100 py-3 fw-bold text-white"
                            style="background: linear-gradient(135deg,#5cb85c,#3d8b3d); border-radius:12px; font-size:1.05rem; letter-spacing:.5px; box-shadow: 0 4px 15px rgba(92,184,92,.4);">
                        <i class="fas fa-lock me-2"></i>Đặt hàng ngay
                    </button>
                    <p class="text-center text-muted mt-2 small"><i class="fas fa-shield-alt me-1"></i>Thanh toán an toàn &amp; bảo mật</p>
                </div>
            </div>
        </form>
    </div>
</div>
<!-- Checkout Page End -->

<!-- Modal coupon style Shopee -->
<div class="modal fade" id="couponModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:480px;">
        <div class="modal-content" style="border-radius:12px; overflow:hidden;">
            <div class="modal-header py-3" style="background:#81c408;">
                <h5 class="modal-title text-white fw-bold"><i class="fas fa-ticket-alt me-2"></i>Chọn mã giảm giá</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3">
                <div id="couponList">
                    <div class="text-center py-4 text-muted">
                        <i class="fas fa-spinner fa-spin me-2"></i>Đang tải mã giảm giá...
                    </div>
                </div>
                <button type="button" id="applyCouponBtn" class="btn fw-semibold w-100 mt-3 text-white" style="background:#81c408; border-color:#81c408;" onclick="applySelectedCoupon()" disabled>
                    Áp dụng
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/addressHandler.js"></script>
    <script>
        $(document).ready(function() {
            
            
            // Initialize AddressHandler for cascading dropdowns
            // **Validates: Requirements 1.1, 2.1, 3.1, 4.1, 5.1**
            var addressHandler = new AddressHandler({
                provinceSelector: '#provinceSelect',
                districtSelector: '#districtSelect',
                wardSelector: '#wardSelect',
                streetAddressSelector: '#StreetAddressInput',
                provinceNameSelector: '#provinceName',
                districtNameSelector: '#districtName',
                wardNameSelector: '#wardName',
                apiBaseUrl: '/api/address',
                enableSearch: true,
                onProvinceChange: function(code, name) {
                    // Ensure hidden field is updated when province changes
                    $('#provinceName').val(name || '');
                    // Clear validation errors when user makes selection
                    // **Feature: checkout-address-split, Task 21.3: Clear validation errors**
                    // **Validates: Requirements 4.2, 5.3**
                    clearFieldError('province');
                },
                onDistrictChange: function(code, name) {
                    // Ensure hidden field is updated when district changes
                    $('#districtName').val(name || '');
                    // Clear validation errors when user makes selection
                    clearFieldError('district');
                },
                onWardChange: function(code, name) {
                    // Ensure hidden field is updated when ward changes
                    $('#wardName').val(name || '');
                    // Clear validation errors when user makes selection
                    clearFieldError('ward');
                },
                onError: function(message, error) {
                    console.error('Address error:', message, error);
                    // Show error toast
                    showAddressError(message);
                },
                onLoad: function() {
                    console.log('Address handler loaded successfully');
                }
            });

            // Initialize and load provinces
            addressHandler.init();

            // Store handler for later use (accessible globally for debugging)
            window.checkoutAddressHandler = addressHandler;

            // Handle address dropdown change (for saved addresses)
            $('#addressSelect').change(function() {
                var selectedValue = $(this).val();
                var selectedOption = $(this).find('option:selected');
                
                if (selectedValue === 'new') {
                    // Show form for new address
                    $('#selectedAddressDisplay').hide();
                    $('#addressFormSection').show();
                    $('#addressFormTitle').text('Nhập địa chỉ mới');
                    $('#saveAddressSection').show();
                    $('#setDefaultSection').show();
                    
                    // Clear form fields
                    clearAddressForm();
                    
                    // Enable form fields
                    enableAddressForm(true);
                    
                    // Re-enable jQuery validation for required fields
                    var form = $('form');
                    if (form.data('validator')) {
                        form.validate().resetForm();
                    }
                    
                    // Re-initialize address handler for new address
                    addressHandler.init();
                } else if (selectedValue) {
                    // Show selected address details
                    var fullName = selectedOption.data('fullname');
                    var phone = selectedOption.data('phone');
                    var address = selectedOption.data('address');
                    var provinceCode = selectedOption.data('provincecode');
                    var provinceName = selectedOption.data('provincename');
                    var districtCode = selectedOption.data('districtcode');
                    var districtName = selectedOption.data('districtname');
                    var wardCode = selectedOption.data('wardcode');
                    var wardName = selectedOption.data('wardname');
                    var streetAddress = selectedOption.data('streetaddress');
                    
                    // Display selected address
                    $('#addressDetails').html(
                        '<p class="mb-1"><strong>' + fullName + '</strong></p>' +
                        '<p class="mb-1"><i class="fas fa-phone me-2"></i>' + phone + '</p>' +
                        '<p class="mb-0"><i class="fas fa-map-marker-alt me-2"></i>' + address + '</p>'
                    );
                    $('#selectedAddressDisplay').show();
                    
                    // Hide form section
                    $('#addressFormSection').hide();
                    $('#saveAddressSection').hide();
                    $('#setDefaultSection').hide();
                    
                    // Fill hidden fields for form submission
                    // **Validates: Requirements 5.1 - Ensure all address data is submitted**
                    $('#FullNameInput').val(fullName);
                    $('#FirstName').val(fullName);
                    $('#Mobile').val(phone);
                    
                    // Update select values (even though hidden)
                    $('#ProvinceCode').val(provinceCode);
                    $('#provinceName').val(provinceName);
                    $('#DistrictCode').val(districtCode);
                    $('#districtName').val(districtName);
                    $('#WardCode').val(wardCode);
                    $('#wardName').val(wardName);
                    $('#StreetAddress').val(streetAddress);
                    $('#StreetAddressInput').val(streetAddress);
                    
                    // Also update the actual select elements to ensure they have the right value
                    $('#provinceSelect').val(provinceCode);
                    $('#districtSelect').val(districtCode);
                    $('#wardSelect').val(wardCode);
                    
                    // Remove validation from hidden fields when using saved address
                    $('#FirstName, #Mobile, #ProvinceCode, #DistrictCode, #WardCode, #StreetAddress').each(function() {
                        $(this).rules('remove');
                        $(this).removeClass('input-validation-error');
                        $(this).next('.field-validation-error').removeClass('field-validation-error').addClass('field-validation-valid').text('');
                    });
                    
                    // Log for debugging
                    console.log('Filled address fields:', {
                        fullName: fullName,
                        phone: phone,
                        provinceCode: provinceCode,
                        districtCode: districtCode,
                        wardCode: wardCode,
                        streetAddress: streetAddress
                    });
                    
                    // Update shipping based on selected address district (Requirements 4.1, 6.1)
                    if (districtName) {
                        updateShippingForDistrict(districtName);
                    }
                } else {
                    // No selection - show empty form
                    $('#selectedAddressDisplay').hide();
                    $('#addressFormSection').show();
                    $('#addressFormTitle').text('Thông tin giao hàng');
                    $('#saveAddressSection').hide();
                    $('#setDefaultSection').hide();
                    
                    // Clear form fields
                    clearAddressForm();
                    
                    // Enable form fields
                    enableAddressForm(true);
                    
                    // Re-initialize address handler
                    addressHandler.init();
                }
            });
            
            // Auto-select default address on page load
            var defaultOption = $('#addressSelect option[selected="selected"]').first();
            if (defaultOption.length && defaultOption.val()) {
                $('#addressSelect').val(defaultOption.val()).trigger('change');
            }
            
            // Sync full name to FirstName field
            $('#FullNameInput').on('input', function() {
                $('#FirstName').val($(this).val());
            });
            
            // Street address input handlers
            // **Feature: checkout-address-split, Task 21.3: Character counter and validation**
            // **Validates: Requirements 4.1, 4.2**
            $('#StreetAddressInput, #StreetAddress').on('input', function() {
                var value = $(this).val();
                var length = value ? value.length : 0;
                
                // Update character counter
                updateCharCounter(length);
                
                // Sync both inputs
                $('#StreetAddressInput').val(value);
                $('#StreetAddress').val(value);
                
                // Clear validation error on input
                clearFieldError('streetAddress');
                
                // Show warning if approaching limit
                if (length > 200) {
                    showFieldError('streetAddress', 'Địa chỉ không được vượt quá 200 ký tự');
                }
            });

            // Phone number input handler - clear error on input
            $('#Mobile').on('input', function() {
                $(this).removeClass('is-invalid');
            });

            // Form validation and submission handler
            // **Feature: checkout-address-split, Task 21.3: Cập nhật validation messages**
            // **Validates: Requirements 4.2, 5.1, 5.3**
            $('form').on('submit', function(e) {
                var selectedAddressId = $('#addressSelect').val();
                var form = $(this);
                
                // If using saved address, skip validation (data already filled)
                if (selectedAddressId && selectedAddressId !== 'new' && selectedAddressId !== '') {
                    console.log('Using saved address, bypassing all validation');
                    
                    // Prevent default first
                    e.preventDefault();
                    e.stopImmediatePropagation();
                    
                    // Enable all address fields before submit to ensure values are sent
                    $('#provinceSelect, #districtSelect, #wardSelect').prop('disabled', false);
                    
                    // Remove all validation
                    form.removeData('validator');
                    form.removeData('unobtrusiveValidation');
                    
                    // Submit the form directly using native submit
                    console.log('Submitting form directly');
                    form[0].submit();
                    
                    return false;
                }
                
                console.log('Validating new address form');
                
                // Re-enable jQuery validation for new address
                if (form.data('validator')) {
                    form.data('validator').settings.ignore = ':hidden:not(select)';
                }
                
                // Enable all address fields before validation
                $('#provinceSelect, #districtSelect, #wardSelect').prop('disabled', false);
                
                // Clear all previous errors first
                clearAllFieldErrors();
                
                // Validate address fields for new address
                var validation = addressHandler.validate();
                var addressValues = addressHandler.getAddressValues();
                
                // Additional validation for street address length
                if (addressValues.streetAddress && addressValues.streetAddress.length > 200) {
                    validation.isValid = false;
                    validation.errors.push('Địa chỉ không được vượt quá 200 ký tự');
                }
                
                // Validate phone number (10-11 digits)
                var phone = $('#Mobile').val();
                if (!phone || !/^\d{10,11}$/.test(phone)) {
                    validation.isValid = false;
                    validation.errors.push('Số điện thoại phải có 10-11 chữ số');
                    $('#Mobile').addClass('is-invalid');
                } else {
                    $('#Mobile').removeClass('is-invalid');
                }
                
                if (!validation.isValid) {
                    e.preventDefault();
                    
                    // Show validation summary at top of form
                    showValidationSummary(validation.errors);
                    
                    // Highlight invalid fields with individual error messages
                    highlightInvalidFields(addressValues);
                    
                    // Scroll to validation summary or first error
                    var scrollTarget = $('.validation-summary').length ? 
                        $('.validation-summary') : $('.is-invalid').first();
                    
                    if (scrollTarget.length) {
                        $('html, body').animate({
                            scrollTop: scrollTarget.offset().top - 100
                        }, 300);
                    }
                    
                    return false;
                }
                
                // Ensure hidden name fields are populated before submit
                // **Validates: Requirements 5.1 - Compose full address**
                var addressValues = addressHandler.getAddressValues();
                $('#provinceName').val(addressValues.provinceName);
                $('#districtName').val(addressValues.districtName);
                $('#wardName').val(addressValues.wardName);
                
                // Clear SelectedAddressId so it doesn't send "new" which causes server model binding error
                if ($('#addressSelect').val() === 'new') {
                    $('input[name="SelectedAddressId"]').val('');
                }
                
                return true;
            });

            // Helper functions
            // **Feature: checkout-address-split, Task 21.3: Cập nhật validation messages**
            // **Validates: Requirements 4.2, 5.3**
            
            /**
             * Clear all form fields and validation states
             */
            function clearAddressForm() {
                $('#FullNameInput').val('');
                $('#FirstName').val('');
                $('#Mobile').val('');
                $('#StreetAddressInput').val('');
                $('#StreetAddress').val('');
                $('#ProvinceCode').val('');
                $('#provinceName').val('');
                $('#DistrictCode').val('');
                $('#districtName').val('');
                $('#WardCode').val('');
                $('#wardName').val('');
                
                // Clear validation states
                clearAllFieldErrors();
                
                // Reset character counter
                updateCharCounter(0);
            }

            /**
             * Enable or disable address form fields
             */
            function enableAddressForm(enable) {
                $('#FullNameInput').prop('readonly', !enable);
                $('#Mobile').prop('readonly', !enable);
                $('#StreetAddressInput').prop('readonly', !enable);
                $('#StreetAddress').prop('readonly', !enable);
            }

            /**
             * Show toast notification for address errors
             */
            function showAddressError(message) {
                // Create toast notification for error
                var toastHtml = '<div class="toast show address-error-toast" role="alert">' +
                    '<div class="toast-header bg-danger text-white">' +
                    '<i class="fa fa-exclamation-circle me-2"></i>' +
                    '<strong class="me-auto">Lỗi</strong>' +
                    '<button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>' +
                    '</div>' +
                    '<div class="toast-body">' + message + '</div>' +
                    '</div>';
                
                var toastContainer = $('.toast-container');
                if (toastContainer.length === 0) {
                    toastContainer = $('<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;"></div>');
                    $('body').append(toastContainer);
                }
                
                var toast = $(toastHtml);
                toastContainer.append(toast);
                
                // Auto-hide after 5 seconds
                setTimeout(function() {
                    toast.fadeOut(function() {
                        $(this).remove();
                    });
                }, 5000);
            }

            /**
             * Clear error for a specific field
             * fieldName - Field name (province, district, ward, streetAddress)
             */
            function clearFieldError(fieldName) {
                var selectors = {
                    'province': { select: '#provinceSelect', error: '#provinceError' },
                    'district': { select: '#districtSelect', error: '#districtError' },
                    'ward': { select: '#wardSelect', error: '#wardError' },
                    'streetAddress': { input: '#StreetAddressInput, #StreetAddress', error: '#streetAddressError' }
                };
                
                var config = selectors[fieldName];
                if (!config) return;
                
                if (config.select) {
                    $(config.select).removeClass('is-invalid');
                    $(config.select).closest('.address-search-wrapper').removeClass('is-invalid');
                }
                if (config.input) {
                    $(config.input).removeClass('is-invalid');
                }
                $(config.error).hide().text('');
            }

            /**
             * Clear all field errors
             */
            function clearAllFieldErrors() {
                $('.is-invalid').removeClass('is-invalid');
                $('.address-field-error').hide().text('');
                $('.address-search-wrapper').removeClass('is-invalid');
                $('.validation-summary').remove();
            }

            /**
             * Show error for a specific field
             * fieldName - Field name (province, district, ward, streetAddress)
             * message - Error message
             */
            function showFieldError(fieldName, message) {
                var selectors = {
                    'province': { select: '#provinceSelect', error: '#provinceError' },
                    'district': { select: '#districtSelect', error: '#districtError' },
                    'ward': { select: '#wardSelect', error: '#wardError' },
                    'streetAddress': { input: '#StreetAddressInput, #StreetAddress', error: '#streetAddressError' }
                };
                
                var config = selectors[fieldName];
                if (!config) return;
                
                if (config.select) {
                    $(config.select).addClass('is-invalid');
                    $(config.select).closest('.address-search-wrapper').addClass('is-invalid');
                }
                if (config.input) {
                    $(config.input).addClass('is-invalid');
                }
                $(config.error).text(message).show();
            }

            /**
             * Highlight all invalid fields based on address values
             * values - Address values from addressHandler.getAddressValues()
             */
            function highlightInvalidFields(values) {
                // Clear previous errors first
                clearAllFieldErrors();
                
                // Check each field and show appropriate error
                if (!values.provinceCode) {
                    showFieldError('province', 'Vui lòng chọn Tỉnh/Thành phố');
                }
                if (!values.districtCode) {
                    showFieldError('district', 'Vui lòng chọn Quận/Huyện');
                }
                if (!values.wardCode) {
                    showFieldError('ward', 'Vui lòng chọn Phường/Xã');
                }
                if (!values.streetAddress) {
                    showFieldError('streetAddress', 'Vui lòng nhập số nhà, tên đường');
                } else if (values.streetAddress.length > 200) {
                    showFieldError('streetAddress', 'Địa chỉ không được vượt quá 200 ký tự');
                }
            }

            /**
             * Update character counter for street address
             * length - Current character count
             */
            function updateCharCounter(length) {
                var counter = $('#streetAddressCounter');
                counter.text(length + '/200 ký tự');
                
                // Update counter color based on length
                counter.removeClass('warning danger');
                if (length >= 200) {
                    counter.addClass('danger');
                } else if (length >= 180) {
                    counter.addClass('warning');
                }
            }

            /**
             * Show validation summary at the top of the form
             * errors - Array of error messages
             */
            function showValidationSummary(errors) {
                // Remove existing summary
                $('.validation-summary').remove();
                
                if (errors.length === 0) return;
                
                var summaryHtml = '<div class="validation-summary">' +
                    '<strong><i class="fa fa-exclamation-triangle me-2"></i>Vui lòng kiểm tra lại các thông tin sau:</strong>' +
                    '<ul>';
                
                errors.forEach(function(error) {
                    summaryHtml += '<li>' + error + '</li>';
                });
                
                summaryHtml += '</ul></div>';
                
                $('#addressFormSection').prepend(summaryHtml);
            }

            // Update shipping when district changes (Requirements 4.1, 6.1)
            // This function is called when user selects a saved address or changes district
            function updateShippingForDistrict(districtName) {
                if (!districtName) {
                    return;
                }
                
                var subtotal = @cart.Subtotal;
                
                // Call API to recalculate shipping
                $.ajax({
                    url: '/Cart/CalculateShippingAjax',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ 
                        subtotal: subtotal, 
                        district: districtName 
                    }),
                    success: function(data) {
                        if (data.success) {
                            updateCheckoutShippingDisplay(data.shippingInfo);
                            // Update total
                            var total = subtotal + data.shippingInfo.shippingFee;
                            $('#totalAmount').text(total.toLocaleString('vi-VN') + 'đ');
                        }
                    },
                    error: function(err) {
                        console.error('Error calculating shipping:', err);
                    }
                });
            }
            
            // Update checkout shipping display (Requirements 5.1, 5.2, 5.3, 5.4)
            function updateCheckoutShippingDisplay(shippingInfo) {
                var zoneNames = {
                    1: 'Nội thành',
                    2: 'Ngoại thành',
                    3: 'Vùng xa'
                };
                
                var zoneName = zoneNames[shippingInfo.zone] || 'Vùng xa';
                $('#checkout-zone-name').text(zoneName);
                
                var feeEl = $('#checkout-shipping-fee');
                if (shippingInfo.isFreeShipping) {
                    feeEl.html('<i class="fas fa-check-circle me-1"></i>Miễn phí vận chuyển');
                    feeEl.removeClass('mb-1').addClass('mb-1 text-success');
                } else {
                    feeEl.html('<strong>Phí ship:</strong> ' + shippingInfo.shippingFee.toLocaleString('vi-VN') + 'đ');
                    feeEl.removeClass('text-success').addClass('mb-1');
                }
                
                var messageEl = $('#checkout-shipping-message');
                if (shippingInfo.message) {
                    if (!messageEl.length) {
                        messageEl = $('<small id="checkout-shipping-message"></small>');
                        $('#checkout-shipping-fee').after(messageEl);
                    }
                    
                    if (shippingInfo.isFreeShipping || shippingInfo.isReducedShipping) {
                        messageEl.html('<i class="fas fa-gift me-1"></i>' + shippingInfo.message);
                        messageEl.removeClass('text-info').addClass('text-success');
                    } else if (shippingInfo.amountToFreeShipping > 0) {
                        messageEl.html('<i class="fas fa-info-circle me-1"></i>' + shippingInfo.message);
                        messageEl.removeClass('text-success').addClass('text-info');
                    }
                    messageEl.show();
                } else if (messageEl.length) {
                    messageEl.hide();
                }
            }
            
            // Hook into district change from AddressHandler
            var originalOnDistrictChange = addressHandler.options.onDistrictChange;
            addressHandler.options.onDistrictChange = function(code, name) {
                if (originalOnDistrictChange) {
                    originalOnDistrictChange(code, name);
                }
                // Update shipping when district changes
                if (name) {
                    updateShippingForDistrict(name);
                }
            };
        });

        // Coupon modal logic
        var currentCouponCode = '@(cart.CouponCode ?? "")';
        var couponListCache = [];
        var couponPrimaryColor = '#81c408';
        var couponPrimarySoftBackground = '#f7fce8';
        var couponPrimarySoftMuted = '#d8eab1';
        var couponPrimarySoftBorder = 'rgba(129,196,8,.35)';

        function openCouponModal() {
            document.getElementById('selectedCouponCode').value = currentCouponCode || '';
            updateApplyCouponButtonState();
            var modal = new bootstrap.Modal(document.getElementById('couponModal'));
            modal.show();
            fetchCoupons();
        }

        function fetchCoupons() {
            fetch('/Cart/GetAvailableCoupons')
                .then(function(r) { return r.json(); })
                .then(function(coupons) {
                    couponListCache = Array.isArray(coupons) ? coupons : [];
                    renderCoupons(couponListCache);
                })
                .catch(function() {
                    document.getElementById('couponList').innerHTML =
                        '<div class="text-center text-danger py-3">Không thể tải mã giảm giá</div>';
                });
        }

        function renderCoupons(coupons) {
            var el = document.getElementById('couponList');
            if (!coupons.length) {
                el.innerHTML = '<div class="text-center text-muted py-3">Không có mã giảm giá nào</div>';
                return;
            }

            var html = '';
            coupons.forEach(function(c) {
                var eligible = c.isEligible;
                var discount = eligible
                    ? (c.type === 'percent'
                        ? 'Giảm ' + c.value + '%'
                        : 'Giảm ' + c.discountAmount.toLocaleString('vi-VN') + 'đ')
                    : (c.type === 'percent'
                        ? 'Giảm ' + c.value + '%'
                        : 'Giảm ' + c.value.toLocaleString('vi-VN') + 'đ');

                var expire = c.endDate ? 'HSD: ' + c.endDate : 'Không giới hạn';
                var hasSelectedCoupon = !!currentCouponCode;
                var isSelected = currentCouponCode && c.code === currentCouponCode;
                var isDimmed = hasSelectedCoupon && eligible && !isSelected;
                var cardStyle = (eligible ? 'cursor:pointer;' : 'cursor:default;') +
                    'transition:opacity .18s ease;' +
                    (isDimmed ? ' opacity:.45;' : '') +
                    (eligible ? (' border-color:' + (isDimmed ? couponPrimarySoftBorder : couponPrimaryColor) + ';') : '');
                var brandBackground = eligible ? (isDimmed ? couponPrimarySoftMuted : couponPrimaryColor) : '#aaa';
                var contentBackground = eligible ? couponPrimarySoftBackground : '#f5f5f5';
                var titleClass = isDimmed ? 'text-muted' : (eligible ? 'text-success' : 'text-muted');
                var codeBadgeClass = eligible ? (isDimmed ? 'bg-secondary' : 'bg-success') : 'bg-secondary';
                var indicatorStyle = isSelected
                    ? 'width:32px; height:32px; border-radius:50%; border:2px solid ' + couponPrimaryColor + '; background:#fff; display:flex; align-items:center; justify-content:center; flex-shrink:0; pointer-events:none;'
                    : (isDimmed
                        ? 'width:32px; height:32px; border-radius:50%; border:2px solid ' + couponPrimarySoftBorder + '; background:#fff; display:flex; align-items:center; justify-content:center; flex-shrink:0; pointer-events:none;'
                        : (eligible
                            ? 'width:32px; height:32px; border-radius:50%; border:2px solid ' + couponPrimaryColor + '; background:#fff; display:flex; align-items:center; justify-content:center; flex-shrink:0; pointer-events:none;'
                            : 'width:32px; height:32px; border-radius:50%; border:2px solid #c7c7c7; background:#f3f3f3; display:flex; align-items:center; justify-content:center; flex-shrink:0; pointer-events:none;'));
                var indicatorDot = isSelected
                    ? '<span style="width:12px; height:12px; border-radius:50%; background:' + couponPrimaryColor + '; display:block;"></span>'
                    : '';

                html += '<div class="coupon-card d-flex mb-2 rounded overflow-hidden border ' +
                    (eligible ? '' : 'border-secondary opacity-50') + '" ' +
                    (eligible ? 'onclick="selectCoupon(\'' + c.code + '\')" style="' + cardStyle + '"' : 'style="' + cardStyle + '"') + '>' +

                    // Left side: brand tag strip
                    '<div class="d-flex flex-column align-items-center justify-content-center px-3 py-3" ' +
                    'style="background:' + brandBackground + '; min-width:70px;">' +
                    '<i class="fas fa-ticket-alt text-white fa-2x mb-1"></i>' +
                    '<small class="text-white fw-bold">FRUITABLES</small>' +
                    '</div>' +

                    // Right side: info
                    '<div class="flex-grow-1 px-3 py-2 position-relative" style="background:' + contentBackground + '">' +
                    '<div class="d-flex justify-content-between align-items-start">' +
                    '<strong class="' + titleClass + '">' + discount + '</strong>' +
                    '<span class="badge ' + codeBadgeClass + ' ms-2">' + c.code + '</span>' +
                    '</div>' +
                    (c.minOrderAmount > 0
                        ? '<small class="text-muted">Đơn tối thiểu ' + c.minOrderAmount.toLocaleString('vi-VN') + 'đ</small><br>'
                        : '') +
                    '<small class="text-muted">' + expire + '</small>' +
                    (!eligible
                        ? '<br><small class="text-warning fw-semibold"><i class="fas fa-exclamation-triangle me-1"></i>' + c.reason + '</small>'
                        : '') +
                    '<div class="position-absolute top-50 end-0 translate-middle-y me-3"><span class="coupon-check-indicator" aria-hidden="true" style="' + indicatorStyle + '">' + indicatorDot + '</span></div>' +
                    '</div>' +
                    '</div>';
            });

            el.innerHTML = html;
            updateApplyCouponButtonState();
        }

        function selectCoupon(code) {
            currentCouponCode = code;
            document.getElementById('selectedCouponCode').value = code;

            if (couponListCache.length) {
                renderCoupons(couponListCache);
            }
        }

        function applySelectedCoupon() {
            var selectedCode = document.getElementById('selectedCouponCode').value.trim();
            var code = selectedCode || currentCouponCode;
            if (!code) return;

            var btn = document.getElementById('applyCouponBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Đang áp dụng...';

            fetch('/Cart/ApplyCouponAjax', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ couponCode: code })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    // Đóng modal
                    var modalEl = document.getElementById('couponModal');
                    var modal = bootstrap.Modal.getInstance(modalEl);
                    if (modal) modal.hide();

                    // Cập nhật currentCouponCode
                    currentCouponCode = data.couponCode;

                    // Cập nhật UI checkout
                    updateCheckoutPricingUI(data);

                    // Cập nhật dòng coupon trên trang
                    updateCouponBanner(data.couponCode, data.discount);

                    showCouponToast('success', data.message);
                } else {
                    showCouponToast('error', data.message || 'Không thể áp dụng mã giảm giá');
                    btn.disabled = false;
                    btn.innerHTML = 'Áp dụng';
                }
            })
            .catch(function() {
                showCouponToast('error', 'Đã xảy ra lỗi, vui lòng thử lại');
                btn.disabled = false;
                btn.innerHTML = 'Áp dụng';
            });
        }

        function updateCheckoutPricingUI(data) {
            var subtotal = data.subtotal || 0;
            var discount = data.discount || 0;
            var shippingFee = data.shippingFee || 0;
            var total = data.total || (subtotal - discount + shippingFee);

            // Cập nhật dòng giảm giá
            var discountRow = document.getElementById('checkout-discount-row');
            if (discount > 0) {
                if (!discountRow) {
                    // Tạo mới dòng discount nếu chưa có
                    var subtotalRow = document.getElementById('checkout-subtotal-row');
                    if (subtotalRow) {
                        var newRow = document.createElement('div');
                        newRow.id = 'checkout-discount-row';
                        newRow.className = 'd-flex justify-content-between mb-2';
                        newRow.innerHTML =
                            '<span class="text-success"><i class="fas fa-tag me-1"></i>Giảm giá <small class="text-muted" id="checkout-coupon-label">(' + data.couponCode + ')</small></span>' +
                            '<span class="text-success fw-semibold" id="checkout-discount-amount">-' + discount.toLocaleString('vi-VN') + 'đ</span>';
                        subtotalRow.insertAdjacentElement('afterend', newRow);
                    }
                } else {
                    var labelEl = document.getElementById('checkout-coupon-label');
                    if (labelEl) labelEl.textContent = '(' + data.couponCode + ')';
                    var amountEl = document.getElementById('checkout-discount-amount');
                    if (amountEl) amountEl.textContent = '-' + discount.toLocaleString('vi-VN') + 'đ';
                    discountRow.style.display = '';
                }
            } else if (discountRow) {
                discountRow.style.display = 'none';
            }

            // Cập nhật tổng cộng
            var totalEl = document.getElementById('totalAmount');
            if (totalEl) totalEl.textContent = total.toLocaleString('vi-VN') + 'đ';

            // Reset button
            var btn = document.getElementById('applyCouponBtn');
            if (btn) {
                btn.disabled = false;
                btn.innerHTML = 'Áp dụng';
            }
        }

        function updateCouponBanner(code, discount) {
            // Cập nhật banner chọn mã giảm giá ngoài trang checkout
            var bannerSpan = document.querySelector('[onclick="openCouponModal()"] span:first-child');
            if (bannerSpan) {
                bannerSpan.innerHTML = 'Mã <strong class="text-danger">' + code + '</strong> &mdash; giảm <strong class="text-success">' + discount.toLocaleString('vi-VN') + 'đ</strong>';
            }
        }

        function showCouponToast(type, message) {
            var color = type === 'success' ? '#81c408' : '#dc3545';
            var icon  = type === 'success' ? 'fas fa-check-circle' : 'fas fa-exclamation-circle';
            var toastHtml = '<div class="toast show" role="alert" style="min-width:260px;">' +
                '<div class="toast-header text-white" style="background:' + color + ';">' +
                '<i class="' + icon + ' me-2"></i><strong class="me-auto">' +
                (type === 'success' ? 'Thành công' : 'Lỗi') + '</strong>' +
                '<button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button></div>' +
                '<div class="toast-body">' + message + '</div></div>';
            var container = document.querySelector('.toast-container');
            if (!container) {
                container = document.createElement('div');
                container.className = 'toast-container position-fixed bottom-0 end-0 p-3';
                container.style.zIndex = '1200';
                document.body.appendChild(container);
            }
            var toastEl = document.createElement('div');
            toastEl.innerHTML = toastHtml;
            var toast = toastEl.firstChild;
            container.appendChild(toast);
            setTimeout(function() { toast.remove(); }, 4000);
        }

        function updateApplyCouponButtonState() {
            var button = document.getElementById('applyCouponBtn');
            if (!button) return;

            var selectedCode = document.getElementById('selectedCouponCode').value.trim();
            var hasSelectedCoupon = !!(selectedCode || currentCouponCode);

            button.disabled = !hasSelectedCoupon;
            button.style.opacity = hasSelectedCoupon ? '1' : '0.6';
            button.style.cursor = hasSelectedCoupon ? 'pointer' : 'not-allowed';
        }

        function updatePaymentStyle() {
            var codSelected = document.getElementById('Delivery-1').checked;
            var lblCod  = document.getElementById('lbl-cod');
            var lblBank = document.getElementById('lbl-bank');
            if (codSelected) {
                lblCod.style.borderColor  = '#5cb85c';
                lblCod.style.background   = '#f0fdf4';
                lblBank.style.borderColor = '';
                lblBank.style.background  = '';
            } else {
                lblBank.style.borderColor = '#0d6efd';
                lblBank.style.background  = '#f0f4ff';
                lblCod.style.borderColor  = '';
                lblCod.style.background   = '';
            }
        }

        // Init payment style on load
        updatePaymentStyle();
    </script>
}
