@model Fruitables.ViewModels.CancelledOrdersOverviewViewModel
@using Fruitables.ViewModels
@{
    ViewData["Title"] = "Thống kê đơn hủy";
    Layout = "~/Areas/Admin/Views/Shared/_AdminDashboardLayout.cshtml";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="fas fa-times-circle me-2 text-danger"></i>Thống kê đơn hủy</h4>
        <p class="text-muted mb-0">Phân tích chi tiết đơn hàng bị hủy và lý do hủy</p>
    </div>
    <div>
        <a asp-action="Index" asp-controller="Revenue" asp-area="Admin" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Quay lại doanh thu
        </a>
    </div>
</div>

<!-- Anti-forgery token for AJAX -->
@Html.AntiForgeryToken()

<!-- Filter Section -->
@await Html.PartialAsync("_CancelledOrdersFilter", Model.Filter)

<!-- Overview Stats Cards -->
<div class="row g-4 mb-4" id="overviewCards">
    <!-- Total Cancelled Orders -->
    <div class="col-md-6 col-xl-3">
        <div class="admin-card p-3 h-100">
            <div class="d-flex align-items-center">
                <div class="flex-shrink-0">
                    <div class="bg-danger bg-opacity-10 rounded-circle p-3">
                        <i class="fas fa-times-circle text-danger fa-2x"></i>
                    </div>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h3 class="mb-0" id="totalCancelledOrders">@Model.TotalCancelledOrders</h3>
                    <small class="text-muted">Tổng đơn hủy</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Cancellation Rate -->
    <div class="col-md-6 col-xl-3">
        <div class="admin-card p-3 h-100">
            <div class="d-flex align-items-center">
                <div class="flex-shrink-0">
                    <div class="bg-warning bg-opacity-10 rounded-circle p-3">
                        <i class="fas fa-percentage text-warning fa-2x"></i>
                    </div>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h3 class="mb-0" id="cancellationRate">@Model.CancellationRate.ToString("F1")%</h3>
                    <small class="text-muted">Tỷ lệ hủy</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Cancelled Value -->
    <div class="col-md-6 col-xl-3">
        <div class="admin-card p-3 h-100">
            <div class="d-flex align-items-center">
                <div class="flex-shrink-0">
                    <div class="bg-secondary bg-opacity-10 rounded-circle p-3">
                        <i class="fas fa-dollar-sign text-secondary fa-2x"></i>
                    </div>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h3 class="mb-0" id="totalCancelledValue">@Model.TotalCancelledValue.ToString("N0")</h3>
                    <small class="text-muted">Giá trị hủy (VND)</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Orders -->
    <div class="col-md-6 col-xl-3">
        <div class="admin-card p-3 h-100">
            <div class="d-flex align-items-center">
                <div class="flex-shrink-0">
                    <div class="bg-info bg-opacity-10 rounded-circle p-3">
                        <i class="fas fa-shopping-cart text-info fa-2x"></i>
                    </div>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h3 class="mb-0" id="totalOrders">@Model.TotalOrders</h3>
                    <small class="text-muted">Tổng đơn hàng</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-4 mb-4">
    <!-- Cancelled Orders Trend Chart -->
    <div class="col-lg-8">
        <div class="admin-card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-chart-area me-2"></i>Xu hướng đơn hủy</span>
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-outline-primary active" data-period="Daily">Ngày</button>
                    <button type="button" class="btn btn-outline-primary" data-period="Weekly">Tuần</button>
                    <button type="button" class="btn btn-outline-primary" data-period="Monthly">Tháng</button>
                </div>
            </div>
            <div class="card-body">
                <canvas id="cancelledTrendChart" height="300"></canvas>
            </div>
        </div>
    </div>

    <!-- Cancel Reason Chart -->
    <div class="col-lg-4">
        <div class="admin-card h-100">
            <div class="card-header">
                <i class="fas fa-chart-pie me-2"></i>Lý do hủy đơn
            </div>
            <div class="card-body">
                <canvas id="cancelReasonChart" height="300"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Cancel Reason Table -->
<div class="row g-4">
    <div class="col-12">
        <div class="admin-card">
            <div class="card-header">
                <i class="fas fa-list me-2"></i>Chi tiết lý do hủy đơn
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0" id="cancelReasonTable">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Lý do hủy</th>
                                <th class="text-end">Số lượng</th>
                                <th class="text-end">Tỷ lệ</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    <i class="fas fa-spinner fa-spin me-2"></i>Đang tải dữ liệu...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/cancelledOrdersChart.js"></script>
}
