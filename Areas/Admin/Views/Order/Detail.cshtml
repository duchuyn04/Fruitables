@model Fruitables.Models.Order
@using Fruitables.Models
@using Fruitables.Helpers
@{
    ViewData["Title"] = $"Đơn hàng #{Model.OrderNumber}";
    Layout = null; // Remove old layout

    var shippingAddress = AddressSnapshotHelper.FromSnapshot(Model.ShippingSnapshot);
    var vnTimeZone = TimeZoneInfo.FindSystemTimeZoneById("SE Asia Standard Time");
    var createdAtVN = TimeZoneInfo.ConvertTimeFromUtc(Model.CreatedAt, vnTimeZone);
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - NEW DESIGN</title>
    <!-- Load dark mode preference BEFORE Tailwind -->
    <script>
        // Load dark mode immediately to prevent flash
        // Default to dark mode if no preference is set
        const darkMode = localStorage.getItem('darkMode');
        if (darkMode === 'true' || darkMode === null) {
            document.documentElement.classList.add('dark');
            if (darkMode === null) {
                localStorage.setItem('darkMode', 'true');
            }
        }
    </script>
    <!-- TAILWIND CSS NEW DESIGN -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: "class",
            important: true,
            theme: {
                extend: {
                    colors: {
                        primary: "#0ea5e9",
                        "background-light": "#f8fafc",
                        "background-dark": "#0f172a",
                    },
                    fontFamily: {
                        display: ["Inter", "sans-serif"],
                        sans: ["Inter", "sans-serif"],
                    },
                    borderRadius: {
                        DEFAULT: "0.75rem",
                    },
                },
            },
        };
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            margin: 0 !important;
            padding: 0 !important;
        }
        /* Override any existing styles */
        * {
            box-sizing: border-box;
        }
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }
        .dark .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #475569;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 min-h-screen transition-colors duration-200">
    <!-- Header -->
    <header class="sticky top-0 z-30 w-full bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800">
        <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <a asp-action="Index" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full transition-colors flex items-center">
                    <span class="material-icons-outlined text-slate-500">arrow_back</span>
                </a>
                <div>
                    <h1 class="text-xl font-bold flex items-center gap-3">
                        Đơn hàng #@Model.OrderNumber
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @GetStatusBadgeClass(Model.Status)">
                            @GetStatusDisplayName(Model.Status)
                        </span>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @GetPaymentStatusBadgeClass(Model.PaymentStatus)">
                            @GetPaymentStatusDisplayName(Model.PaymentStatus)
                        </span>
                    </h1>
                    <p class="text-xs text-slate-500 dark:text-slate-400">Ngày tạo: @createdAtVN.ToString("dd/MM/yyyy HH:mm:ss")</p>
                </div>
            </div>
            <div class="flex items-center gap-3">
                <button id="darkModeToggle" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full transition-colors">
                    <span class="material-icons-outlined text-slate-600 dark:text-slate-300">dark_mode</span>
                </button>
                <button class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-700 transition-all flex items-center gap-2" onclick="window.print()">
                    <span class="material-icons-outlined text-sm">print</span> In đơn hàng
                </button>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 py-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Column -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Order Items -->
                <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex items-center gap-2">
                        <span class="material-icons-outlined text-primary">shopping_bag</span>
                        <h2 class="font-semibold text-slate-800 dark:text-slate-100">Sản phẩm trong đơn</h2>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="bg-slate-50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider">
                                    <th class="px-6 py-3 font-medium">Sản phẩm</th>
                                    <th class="px-6 py-3 font-medium text-center">Số lượng</th>
                                    <th class="px-6 py-3 font-medium text-right">Đơn giá</th>
                                    <th class="px-6 py-3 font-medium text-right">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-4">
                                                <div class="h-12 w-12 rounded-lg bg-slate-100 dark:bg-slate-800 flex-shrink-0 overflow-hidden border border-slate-200 dark:border-slate-700">
                                                    @if (item.Product?.Images?.Any() == true)
                                                    {
                                                        <img alt="@item.ProductName" class="h-full w-full object-cover" src="@item.Product.Images.First().ImageUrl"/>
                                                    }
                                                    else
                                                    {
                                                        <div class="h-full w-full flex items-center justify-center">
                                                            <span class="material-icons-outlined text-slate-400">image</span>
                                                        </div>
                                                    }
                                                </div>
                                                <div>
                                                    <p class="font-medium text-slate-800 dark:text-slate-100">@item.ProductName</p>
                                                    <p class="text-xs text-slate-500">ID: #@item.ProductId</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 text-center text-slate-600 dark:text-slate-400">@item.Quantity</td>
                                        <td class="px-6 py-4 text-right text-slate-600 dark:text-slate-400">@item.Price.ToString("N0")₫</td>
                                        <td class="px-6 py-4 text-right font-medium text-slate-800 dark:text-slate-100">@item.Total.ToString("N0")₫</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="bg-slate-50/50 dark:bg-slate-800/30 px-6 py-6 border-t border-slate-200 dark:border-slate-800">
                        <div class="flex flex-col items-end gap-3">
                            <div class="flex justify-between w-full max-w-xs text-sm">
                                <span class="text-slate-500">Tạm tính:</span>
                                <span class="text-slate-800 dark:text-slate-200">@Model.Subtotal.ToString("N0")₫</span>
                            </div>
                            <div class="flex justify-between w-full max-w-xs text-sm">
                                <span class="text-slate-500">Phí vận chuyển:</span>
                                <span class="text-slate-800 dark:text-slate-200">@Model.ShippingFee.ToString("N0")₫</span>
                            </div>
                            @if (Model.Discount > 0)
                            {
                                <div class="flex justify-between w-full max-w-xs text-sm">
                                    <span class="text-slate-500">Giảm giá:</span>
                                    <span class="text-red-600 dark:text-red-400">-@Model.Discount.ToString("N0")₫</span>
                                </div>
                            }
                            <div class="flex justify-between w-full max-w-xs pt-3 border-t border-slate-200 dark:border-slate-700">
                                <span class="text-lg font-bold text-slate-800 dark:text-slate-100">Tổng cộng:</span>
                                <span class="text-xl font-bold text-green-600 dark:text-green-400">@Model.Total.ToString("N0")₫</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Status History & Order Notes -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Status History -->
                    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm h-full">
                        <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex items-center gap-2">
                            <span class="material-icons-outlined text-slate-500">history</span>
                            <h2 class="font-semibold text-slate-800 dark:text-slate-100">Lịch sử trạng thái</h2>
                        </div>
                        <div class="p-6">
                            @if (Model.StatusHistory?.Any() == true)
                            {
                                <div class="flex flex-col gap-4">
                                    @foreach (var history in Model.StatusHistory.OrderByDescending(h => h.CreatedAt))
                                    {
                                        <div class="border-l-4 border-primary pl-4 py-2">
                                            <div class="flex items-center gap-2 mb-1">
                                                @if (history.OldStatus != history.NewStatus)
                                                {
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium @GetStatusBadgeClass(history.OldStatus)">
                                                        @GetStatusDisplayName(history.OldStatus)
                                                    </span>
                                                    <span class="material-icons-outlined text-xs text-slate-400">arrow_forward</span>
                                                }
                                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium @GetStatusBadgeClass(history.NewStatus)">
                                                    @GetStatusDisplayName(history.NewStatus)
                                                </span>
                                            </div>
                                            @if (!string.IsNullOrEmpty(history.Notes))
                                            {
                                                <p class="text-xs text-slate-600 dark:text-slate-400 mt-1">@history.Notes</p>
                                            }
                                            <p class="text-xs text-slate-400 mt-1">
                                                @TimeZoneInfo.ConvertTimeFromUtc(history.CreatedAt, vnTimeZone).ToString("dd/MM/yyyy HH:mm")
                                                @if (history.Admin != null)
                                                {
                                                    <span>- @history.Admin.Name</span>
                                                }
                                            </p>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="flex items-center gap-3 text-sm text-slate-500 italic">
                                    <span class="material-icons-outlined text-sm">info</span>
                                    Chưa có lịch sử thay đổi
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Order Notes -->
                    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm h-full">
                        <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex items-center gap-2">
                            <span class="material-icons-outlined text-slate-500">assignment</span>
                            <h2 class="font-semibold text-slate-800 dark:text-slate-100">Ghi chú nội bộ</h2>
                        </div>
                        <div class="p-6">
                            @{
                                var orderNotes = ViewBag.OrderNotes as List<Fruitables.Models.OrderNote> ?? new List<Fruitables.Models.OrderNote>();
                            }
                            <div id="notesList" class="space-y-3 mb-4">
                                @if (!orderNotes.Any())
                                {
                                    <div class="flex items-center gap-3 text-sm text-slate-500 italic" id="emptyNotesMsg">
                                        <span class="material-icons-outlined text-sm">history_edu</span>
                                        Chưa có ghi chú nào
                                    </div>
                                }
                                else
                                {
                                    @foreach (var note in orderNotes)
                                    {
                                        <div class="border-l-4 border-blue-500 pl-3 py-2 bg-slate-50 dark:bg-slate-800/50 rounded-r" data-note-id="@note.Id">
                                            <div class="flex justify-between items-start">
                                                <div>
                                                    <p class="text-xs font-semibold text-slate-700 dark:text-slate-300">@note.AdminName</p>
                                                    <p class="text-xs text-slate-500 dark:text-slate-400">@note.CreatedAt.AddHours(7).ToString("dd/MM/yyyy HH:mm")</p>
                                                </div>
                                                @if (note.AdminId == int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0"))
                                                {
                                                    <button type="button" class="text-red-500 hover:text-red-700 delete-note-btn" data-note-id="@note.Id">
                                                        <span class="material-icons-outlined text-sm">close</span>
                                                    </button>
                                                }
                                            </div>
                                            <p class="text-sm text-slate-600 dark:text-slate-300 mt-1">@note.Content</p>
                                        </div>
                                    }
                                }
                            </div>
                            <div class="mt-4">
                                <textarea class="w-full px-3 py-2 text-sm border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent dark:bg-slate-800 dark:text-slate-100" 
                                          id="noteContent" rows="2" placeholder="Nhập ghi chú nội bộ..." maxlength="1000"></textarea>
                                <div class="flex justify-between items-center mt-2">
                                    <small class="text-slate-500"><span id="noteCharCount">0</span>/1000</small>
                                    <button type="button" class="bg-primary hover:bg-sky-600 text-white text-sm font-medium py-2 px-4 rounded-lg flex items-center gap-2 transition-all" id="addNoteBtn">
                                        <span class="material-icons-outlined text-sm">add</span> Thêm ghi chú
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column -->
            <div class="space-y-6">
                <!-- Customer Info -->
                <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                    <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex items-center gap-2">
                        <span class="material-icons-outlined text-slate-500">person</span>
                        <h2 class="font-semibold text-slate-800 dark:text-slate-100">Khách hàng</h2>
                    </div>
                    <div class="p-6">
                        @if (Model.User != null)
                        {
                            <div class="flex items-center gap-4 mb-4">
                                <div class="h-12 w-12 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-lg">
                                    @Model.User.Name.Substring(0, 1).ToUpper()
                                </div>
                                <div>
                                    <h3 class="font-bold text-slate-900 dark:text-slate-100">@Model.User.Name</h3>
                                    <p class="text-xs text-slate-500">Thành viên từ @Model.User.CreatedAt.Year</p>
                                </div>
                            </div>
                            <div class="space-y-3">
                                <div class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-400">
                                    <span class="material-icons-outlined text-sm">email</span>
                                    @Model.User.Email
                                </div>
                                @if (!string.IsNullOrEmpty(Model.User.Phone))
                                {
                                    <div class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-400">
                                        <span class="material-icons-outlined text-sm">phone</span>
                                        @Model.User.Phone
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-slate-500 text-sm">Khách vãng lai</p>
                        }
                    </div>
                </div>

                <!-- Shipping Address -->
                <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                    <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex items-center gap-2">
                        <span class="material-icons-outlined text-slate-500">local_shipping</span>
                        <h2 class="font-semibold text-slate-800 dark:text-slate-100">Địa chỉ giao hàng</h2>
                    </div>
                    <div class="p-6">
                        @if (shippingAddress != null)
                        {
                            <div class="mb-4">
                                <p class="font-bold text-slate-900 dark:text-slate-100 mb-1">@shippingAddress.FullName</p>
                                <p class="text-sm text-slate-600 dark:text-slate-400 flex items-center gap-2">
                                    <span class="material-icons-outlined text-xs">phone</span> @shippingAddress.Phone
                                </p>
                            </div>
                            <div class="flex gap-3 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
                                <span class="material-icons-outlined text-sm mt-0.5 text-primary">location_on</span>
                                @shippingAddress.FullAddress
                            </div>
                        }
                        else if (Model.Address != null)
                        {
                            <div class="mb-4">
                                <p class="font-bold text-slate-900 dark:text-slate-100 mb-1">@Model.Address.FullName</p>
                                <p class="text-sm text-slate-600 dark:text-slate-400 flex items-center gap-2">
                                    <span class="material-icons-outlined text-xs">phone</span> @Model.Address.Phone
                                </p>
                            </div>
                            <div class="flex gap-3 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
                                <span class="material-icons-outlined text-sm mt-0.5 text-primary">location_on</span>
                                @Model.Address.FullAddress
                            </div>
                        }
                        else
                        {
                            <p class="text-slate-500 text-sm">Không có thông tin địa chỉ</p>
                        }
                    </div>
                </div>

                <!-- Payment Info -->
                <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                    <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <span class="material-icons-outlined text-slate-500">payments</span>
                            <h2 class="font-semibold text-slate-800 dark:text-slate-100">Thanh toán</h2>
                        </div>
                        <span class="px-2 py-0.5 @GetPaymentStatusBadgeClass(Model.PaymentStatus) text-[10px] font-bold rounded uppercase">
                            @GetPaymentStatusDisplayName(Model.PaymentStatus)
                        </span>
                    </div>
                    <div class="p-6 space-y-4">
                        <div>
                            <p class="text-xs text-slate-400 uppercase font-semibold mb-1">Phương thức</p>
                            <p class="text-sm text-slate-700 dark:text-slate-300">@GetPaymentMethodDisplayName(Model.PaymentMethod)</p>
                        </div>
                        <div>
                            <p class="text-xs text-slate-400 uppercase font-semibold mb-1">Vận chuyển</p>
                            <p class="text-sm text-slate-700 dark:text-slate-300">@GetShippingMethodDisplayName(Model.ShippingMethod)</p>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Notes))
                        {
                            <div>
                                <p class="text-xs text-slate-400 uppercase font-semibold mb-1">Ghi chú</p>
                                <p class="text-sm text-slate-700 dark:text-slate-300">@Model.Notes</p>
                            </div>
                        }
                        @if (Model.PaymentStatus == PaymentStatus.Pending && Model.Status != OrderStatus.Cancelled && Model.Status != OrderStatus.Returned)
                        {
                            <button type="button" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3 px-4 rounded-lg flex items-center justify-center gap-2 transition-all shadow-sm" onclick="openPaymentModal()">
                                <span class="material-icons-outlined">check_circle</span>
                                Xác nhận đã thu tiền
                            </button>
                        }
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="bg-slate-50 dark:bg-slate-900/40 p-1 rounded-xl border border-slate-200 dark:border-slate-800 space-y-2">
                    @if (Model.Status == OrderStatus.Pending)
                    {
                        <button type="button" class="w-full bg-primary hover:bg-sky-600 text-white font-semibold py-3 px-4 rounded-lg flex items-center justify-center gap-2 transition-all shadow-sm"
                                onclick="confirmAction(@((int)OrderStatus.Processing), 'Duyệt đơn và bắt đầu xử lý?', false)">
                            <span class="material-icons-outlined">fact_check</span>
                            Duyệt đơn & Chuẩn bị hàng
                        </button>
                        <button type="button" class="w-full bg-white dark:bg-slate-800 hover:bg-rose-50 dark:hover:bg-rose-900/20 text-rose-600 border border-slate-200 dark:border-slate-700 font-semibold py-3 px-4 rounded-lg flex items-center justify-center gap-2 transition-all"
                                onclick="openCancelModal()">
                            <span class="material-icons-outlined">cancel</span>
                            Hủy đơn hàng
                        </button>
                    }
                    else if (Model.Status == OrderStatus.Processing)
                    {
                        <button type="button" class="w-full bg-primary hover:bg-sky-600 text-white font-semibold py-3 px-4 rounded-lg flex items-center justify-center gap-2 transition-all shadow-sm"
                                onclick="confirmAction(@((int)OrderStatus.Shipped), 'Xác nhận đã giao cho đơn vị vận chuyển?', false)">
                            <span class="material-icons-outlined">local_shipping</span>
                            Giao cho vận chuyển
                        </button>
                        <button type="button" class="w-full bg-white dark:bg-slate-800 hover:bg-rose-50 dark:hover:bg-rose-900/20 text-rose-600 border border-slate-200 dark:border-slate-700 font-semibold py-3 px-4 rounded-lg flex items-center justify-center gap-2 transition-all"
                                onclick="openCancelModal()">
                            <span class="material-icons-outlined">cancel</span>
                            Hủy đơn hàng
                        </button>
                    }
                    else if (Model.Status == OrderStatus.Shipped)
                    {
                        <button type="button" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3 px-4 rounded-lg flex items-center justify-center gap-2 transition-all shadow-sm"
                                onclick="confirmAction(@((int)OrderStatus.Delivered), 'Xác nhận khách đã nhận được hàng?', false)">
                            <span class="material-icons-outlined">check_circle</span>
                            Xác nhận đã giao hàng
                        </button>
                        <button type="button" class="w-full bg-amber-500 hover:bg-amber-600 text-white font-semibold py-3 px-4 rounded-lg flex items-center justify-center gap-2 transition-all"
                                onclick="openReturnModal()">
                            <span class="material-icons-outlined">undo</span>
                            Giao thất bại / Hoàn hàng
                        </button>
                    }
                    else if (Model.Status == OrderStatus.Delivered)
                    {
                        <button type="button" class="w-full bg-amber-500 hover:bg-amber-600 text-white font-semibold py-3 px-4 rounded-lg flex items-center justify-center gap-2 transition-all"
                                onclick="openReturnModal()">
                            <span class="material-icons-outlined">undo</span>
                            Xử lý trả hàng
                        </button>
                        <div class="text-center text-slate-500 py-2 text-sm">
                            <span class="material-icons-outlined text-green-500">check_circle</span>
                            Đơn hàng đã hoàn thành
                        </div>
                    }
                    else if (Model.Status == OrderStatus.Cancelled || Model.Status == OrderStatus.Returned)
                    {
                        <div class="text-center text-slate-500 py-4">
                            <span class="material-icons-outlined text-4xl mb-2 block">lock</span>
                            <small>Đơn hàng đã kết thúc, không thể thay đổi trạng thái.</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </main>
    <div class="h-16"></div>
</div>

<!-- Modals -->
<!-- Action Modal -->
<div class="modal fade" id="actionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Xác nhận</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="actionMessage"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="actionForm" method="post" asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.Id">
                    <input type="hidden" name="newStatus" id="actionTargetStatus">
                    <textarea name="notes" class="form-control mt-2" id="actionNotes" rows="2" placeholder="Ghi chú (không bắt buộc)" style="display:none;"></textarea>
                    <button type="submit" class="btn btn-primary">Xác nhận</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Cancel Modal -->
<div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Hủy đơn hàng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-danger fw-bold">⚠️ Thao tác này không thể hoàn tác. Kho hàng sẽ được hoàn trả.</p>
                <form id="cancelForm" method="post" asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.Id">
                    <input type="hidden" name="newStatus" value="@((int)OrderStatus.Cancelled)">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Lý do hủy <span class="text-danger">*</span></label>
                        <textarea name="notes" class="form-control" rows="3" required placeholder="Nhập lý do hủy đơn hàng..."></textarea>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                        <button type="submit" class="btn btn-danger">Xác nhận hủy đơn</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Return Modal -->
<div class="modal fade" id="returnModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-warning">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title">Xử lý Hoàn hàng / Trả hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted">Sau khi xác nhận, trạng thái thanh toán sẽ chuyển sang <strong>Đã hoàn tiền</strong>.</p>
                <form id="returnForm" method="post" asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.Id">
                    <input type="hidden" name="newStatus" value="@((int)OrderStatus.Returned)">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Lý do hoàn hàng <span class="text-danger">*</span></label>
                        <textarea name="notes" class="form-control" rows="3" required placeholder="Nhập lý do hoàn hàng..."></textarea>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                        <button type="submit" class="btn btn-warning text-dark">Xác nhận hoàn hàng</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Payment Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-success">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Xác nhận Thu tiền</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn xác nhận đã nhận được <strong>@Model.Total.ToString("N0")đ</strong> từ khách hàng?</p>
                <form id="paymentForm" method="post" asp-area="Admin" asp-controller="Order" asp-action="UpdatePaymentStatus">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.Id">
                    <input type="hidden" name="newPaymentStatus" value="@((int)PaymentStatus.Paid)">
                    <div class="mb-3">
                        <label class="form-label">Ghi chú (không bắt buộc)</label>
                        <textarea name="notes" class="form-control" rows="2" placeholder="VD: Thu tiền mặt qua shipper lúc 14:30..."></textarea>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success">Xác nhận đã thu tiền</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusDisplayName(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "Chờ xử lý",
        OrderStatus.Processing => "Đang xử lý",
        OrderStatus.Shipped => "Đang giao",
        OrderStatus.Delivered => "Đã giao",
        OrderStatus.Cancelled => "Đã hủy",
        OrderStatus.Returned => "Trả hàng",
        _ => status.ToString()
    };

    string GetPaymentStatusDisplayName(PaymentStatus status) => status switch
    {
        PaymentStatus.Pending => "Chờ thanh toán",
        PaymentStatus.Paid => "Đã thanh toán",
        PaymentStatus.Refunded => "Đã hoàn tiền",
        _ => status.ToString()
    };

    string GetStatusBadgeClass(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400",
        OrderStatus.Processing => "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400",
        OrderStatus.Shipped => "bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400",
        OrderStatus.Delivered => "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400",
        OrderStatus.Cancelled => "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400",
        OrderStatus.Returned => "bg-gray-100 text-gray-800 dark:bg-gray-900/30 dark:text-gray-400",
        _ => "bg-gray-100 text-gray-800"
    };

    string GetPaymentStatusBadgeClass(PaymentStatus status) => status switch
    {
        PaymentStatus.Pending => "bg-amber-50 text-amber-600 dark:bg-amber-900/20 dark:text-amber-400",
        PaymentStatus.Paid => "bg-green-50 text-green-600 dark:bg-green-900/20 dark:text-green-400",
        PaymentStatus.Refunded => "bg-blue-50 text-blue-600 dark:bg-blue-900/20 dark:text-blue-400",
        _ => "bg-gray-50 text-gray-600"
    };

    string GetPaymentMethodDisplayName(PaymentMethod method) => method switch
    {
        PaymentMethod.BankTransfer => "Chuyển khoản",
        PaymentMethod.Check => "Séc",
        PaymentMethod.COD => "Thanh toán khi nhận hàng (COD)",
        PaymentMethod.Paypal => "PayPal",
        _ => method.ToString()
    };

    string GetShippingMethodDisplayName(ShippingMethod method) => method switch
    {
        ShippingMethod.Free => "Miễn phí",
        ShippingMethod.FlatRate => "Phí cố định",
        ShippingMethod.LocalPickup => "Nhận tại cửa hàng",
        _ => method.ToString()
    };
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const orderId = @Model.Id;
    const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    // Modal helpers
    function confirmAction(newStatus, message, showNotes) {
        document.getElementById('actionMessage').textContent = message;
        document.getElementById('actionTargetStatus').value = newStatus;
        const notesEl = document.getElementById('actionNotes');
        notesEl.style.display = showNotes ? '' : 'none';
        new bootstrap.Modal(document.getElementById('actionModal')).show();
    }

    function openCancelModal() {
        new bootstrap.Modal(document.getElementById('cancelModal')).show();
    }

    function openReturnModal() {
        new bootstrap.Modal(document.getElementById('returnModal')).show();
    }

    function openPaymentModal() {
        new bootstrap.Modal(document.getElementById('paymentModal')).show();
    }

    // Character counter
    document.getElementById('noteContent')?.addEventListener('input', function () {
        document.getElementById('noteCharCount').textContent = this.value.length;
    });

    // Add note
    document.getElementById('addNoteBtn')?.addEventListener('click', async function () {
        const content = document.getElementById('noteContent').value.trim();
        if (!content) return;

        this.disabled = true;
        try {
            const resp = await fetch(`/Admin/Order/${orderId}/AddNote`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': antiForgeryToken
                },
                body: JSON.stringify({ content })
            });
            const data = await resp.json();
            if (data.success) {
                const n = data.note;
                const html = `
                    <div class="border-l-4 border-blue-500 pl-3 py-2 bg-slate-50 dark:bg-slate-800/50 rounded-r" data-note-id="${n.id}">
                        <div class="flex justify-between items-start">
                            <div>
                                <p class="text-xs font-semibold text-slate-700 dark:text-slate-300">${n.adminName}</p>
                                <p class="text-xs text-slate-500 dark:text-slate-400">${n.createdAt}</p>
                            </div>
                            ${n.isOwner ? `<button type="button" class="text-red-500 hover:text-red-700 delete-note-btn" data-note-id="${n.id}"><span class="material-icons-outlined text-sm">close</span></button>` : ''}
                        </div>
                        <p class="text-sm text-slate-600 dark:text-slate-300 mt-1">${escHtml(n.content)}</p>
                    </div>`;
                const notesList = document.getElementById('notesList');
                const emptyMsg = document.getElementById('emptyNotesMsg');
                if (emptyMsg) emptyMsg.remove();
                notesList.insertAdjacentHTML('afterbegin', html);
                document.getElementById('noteContent').value = '';
                document.getElementById('noteCharCount').textContent = '0';
                attachDeleteHandlers();
            }
        } finally {
            this.disabled = false;
        }
    });

    function attachDeleteHandlers() {
        document.querySelectorAll('.delete-note-btn').forEach(btn => {
            btn.replaceWith(btn.cloneNode(true));
        });
        document.querySelectorAll('.delete-note-btn').forEach(btn => {
            btn.addEventListener('click', async function () {
                if (!confirm('Xóa ghi chú này?')) return;
                const noteId = this.dataset.noteId;
                const resp = await fetch(`/Admin/Order/DeleteNote/${noteId}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': antiForgeryToken }
                });
                const data = await resp.json();
                if (data.success) {
                    const item = document.querySelector(`[data-note-id="${noteId}"]`);
                    if (item) item.remove();
                    if (!document.querySelector('[data-note-id]')) {
                        document.getElementById('notesList').innerHTML = '<div class="flex items-center gap-3 text-sm text-slate-500 italic" id="emptyNotesMsg"><span class="material-icons-outlined text-sm">history_edu</span>Chưa có ghi chú nào</div>';
                    }
                }
            });
        });
    }

    function escHtml(str) {
        return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    attachDeleteHandlers();

    // Dark mode toggle with localStorage
    const darkModeToggle = document.getElementById('darkModeToggle');
    const htmlElement = document.documentElement;
    
    // Load dark mode preference from localStorage
    if (localStorage.getItem('darkMode') === 'true') {
        htmlElement.classList.add('dark');
    }
    
    // Toggle dark mode
    darkModeToggle?.addEventListener('click', function() {
        htmlElement.classList.toggle('dark');
        localStorage.setItem('darkMode', htmlElement.classList.contains('dark'));
    });
</script>
</body>
</html>


