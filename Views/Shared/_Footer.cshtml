@inject Fruitables.Services.Interfaces.ISettingsService SettingsService
@{
    var siteName = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.SiteName, "Fruitables");
    var contactAddress = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.ContactAddress, "Địa chỉ cửa hàng");
    var contactEmail = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.ContactEmail, "hotro@fruitables.vn");
    var contactPhone = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.ContactPhone, "+0123 4567 8910");
    var socialFacebook = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.SocialFacebook);
    var socialTwitter = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.SocialTwitter);
    var socialYoutube = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.SocialYoutube);
    var socialLinkedIn = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.SocialLinkedIn);
    var socialInstagram = await SettingsService.GetSettingAsync(Fruitables.Constants.SettingKeys.SocialInstagram);
}
<div class="container-fluid bg-dark text-white-50 footer pt-5 mt-5">
    <div class="container py-5">
        <div class="pb-4 mb-4" style="border-bottom: 1px solid rgba(226, 175, 24, 0.5);">
            <div class="row g-4">
                <div class="col-lg-3 text-center text-lg-start">
                    <a href="#">
                        <h1 class="text-primary mb-0">@siteName</h1>
                        <p class="text-secondary mb-0">Nông sản tươi mỗi ngày</p>
                    </a>
                </div>
                <div class="col-lg-6 my-4 my-lg-0">
                    <div class="position-relative mx-auto">
                        <input class="form-control border-0 w-100 py-3 px-4 rounded-pill" type="email" placeholder="Email của bạn">
                        <button type="submit" class="btn btn-primary border-0 border-secondary py-3 px-4 position-absolute rounded-pill text-white" style="top: 0; right: 0;">Đăng ký nhận tin</button>
                    </div>
                </div>
                <div class="col-lg-3">
                    <div class="d-flex justify-content-center justify-content-lg-end pt-3 pt-lg-0">
                        @if (!string.IsNullOrEmpty(socialTwitter))
                        {
                            <a class="btn btn-outline-secondary me-2 btn-md-square rounded-circle" href="@socialTwitter" target="_blank"><i class="fab fa-twitter"></i></a>
                        }
                        @if (!string.IsNullOrEmpty(socialFacebook))
                        {
                            <a class="btn btn-outline-secondary me-2 btn-md-square rounded-circle" href="@socialFacebook" target="_blank"><i class="fab fa-facebook-f"></i></a>
                        }
                        @if (!string.IsNullOrEmpty(socialInstagram))
                        {
                            <a class="btn btn-outline-secondary me-2 btn-md-square rounded-circle" href="@socialInstagram" target="_blank"><i class="fab fa-instagram"></i></a>
                        }
                        @if (!string.IsNullOrEmpty(socialYoutube))
                        {
                            <a class="btn btn-outline-secondary me-2 btn-md-square rounded-circle" href="@socialYoutube" target="_blank"><i class="fab fa-youtube"></i></a>
                        }
                        @if (!string.IsNullOrEmpty(socialLinkedIn))
                        {
                            <a class="btn btn-outline-secondary btn-md-square rounded-circle" href="@socialLinkedIn" target="_blank"><i class="fab fa-linkedin-in"></i></a>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="row g-5">
            <div class="col-lg-3 col-md-6 col-sm-6">
                <div class="footer-item">
                    <h4 class="text-light mb-3">Vì sao chọn Fruitables?</h4>
                    <p class="mb-4">Chúng tôi ưu tiên sản phẩm tươi, quy trình đặt hàng đơn giản và hỗ trợ khách hàng nhanh chóng.</p>
                    <a asp-controller="Shop" asp-action="Index" class="btn border-secondary py-2 px-4 rounded-pill text-primary">Mua sắm ngay</a>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 col-sm-6">
                <div class="d-flex flex-column text-start footer-item">
                    <h4 class="text-light mb-3">Thông tin cửa hàng</h4>
                    <a class="btn-link" href="">Giới thiệu</a>
                    <a class="btn-link" asp-controller="Contact" asp-action="Index">Liên hệ</a>
                    <a class="btn-link" href="">Chính sách bảo mật</a>
                    <a class="btn-link" href="">Điều khoản sử dụng</a>
                    <a class="btn-link" href="">Chính sách đổi trả</a>
                    <a class="btn-link" href="">Câu hỏi thường gặp</a>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 col-sm-6">
                <div class="d-flex flex-column text-start footer-item">
                    <h4 class="text-light mb-3">Tài khoản</h4>
                    <a class="btn-link" asp-controller="Profile" asp-action="Index">Tài khoản của tôi</a>
                    <a class="btn-link" asp-controller="Shop" asp-action="Index">Cửa hàng</a>
                    <a class="btn-link" asp-controller="Cart" asp-action="Index">Giỏ hàng</a>
                    <a class="btn-link" href="">Sản phẩm yêu thích</a>
                    <a class="btn-link" asp-controller="OrderHistory" asp-action="Index">Lịch sử đơn hàng</a>
                    <a class="btn-link" href="">Hỗ trợ đặt hàng</a>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 col-sm-6">
                <div class="footer-item">
                    <h4 class="text-light mb-3">Liên hệ</h4>
                    <p>Địa chỉ: @contactAddress</p>
                    <p>Email: @contactEmail</p>
                    <p>Điện thoại: @contactPhone</p>
                    <p>Phương thức thanh toán</p>
                    <img src="~/img/payment.png" class="img-fluid" alt="Phương thức thanh toán">
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Copyright Start -->
<div class="container-fluid copyright bg-dark py-4">
    <div class="container">
        <div class="row">
            <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                <span class="text-light"><a href="#"><i class="fas fa-copyright text-light me-2"></i>@siteName</a>, đã đăng ký bản quyền.</span>
            </div>
            <div class="col-md-6 my-auto text-center text-md-end text-white">
                Thiết kế bởi <a class="border-bottom" href="https://htmlcodex.com">HTML Codex</a>
            </div>
        </div>
    </div>
</div>
<!-- Copyright End -->
