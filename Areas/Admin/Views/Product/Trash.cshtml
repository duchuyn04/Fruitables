@model Fruitables.ViewModels.ProductListViewModel
@{
    ViewData["Title"] = "Thùng rác - Sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminDashboardLayout.cshtml";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Thùng rác</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Sản phẩm</a></li>
                <li class="breadcrumb-item active">Thùng rác</li>
            </ol>
        </nav>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Quay lại
        </a>
    </div>
</div>

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
    @if (TempData["Success"] != null)
    {
        <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
            <div class="toast-header bg-success text-white">
                <i class="fas fa-check-circle me-2"></i>
                <strong class="me-auto">Thành công</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">@TempData["Success"]</div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
            <div class="toast-header bg-danger text-white">
                <i class="fas fa-exclamation-circle me-2"></i>
                <strong class="me-auto">Lỗi</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">@TempData["Error"]</div>
        </div>
    }
</div>

<div class="admin-card">
    <div class="card-header">
        <i class="fas fa-trash me-2"></i>Sản phẩm đã xóa (@Model.TotalItems)
    </div>
    <div class="card-body p-0">
        @if (Model.Products.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 80px">Ảnh</th>
                            <th>Tên sản phẩm</th>
                            <th>Danh mục</th>
                            <th class="text-end">Giá</th>
                            <th>Ngày xóa</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.Products)
                        {
                            <tr>
                                <td>
                                    @if (product.Images?.Any() == true)
                                    {
                                        var primaryImage = product.Images.FirstOrDefault(i => i.IsPrimary) ?? product.Images.First();
                                        <img src="@primaryImage.ImageUrl" alt="@product.Name" class="img-thumbnail" style="width: 60px; height: 60px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                            <i class="fas fa-image text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <div class="fw-semibold">@product.Name</div>
                                    <small class="text-muted">@product.Slug</small>
                                </td>
                                <td>@product.Category?.Name</td>
                                <td class="text-end">
                                    @if (product.SalePrice.HasValue && product.SalePrice < product.Price)
                                    {
                                        <div class="text-decoration-line-through text-muted small">@product.Price.ToString("N0") đ</div>
                                        <div class="text-danger fw-semibold">@product.SalePrice.Value.ToString("N0") đ</div>
                                    }
                                    else
                                    {
                                        <div class="fw-semibold">@product.Price.ToString("N0") đ</div>
                                    }
                                </td>
                                <td>
                                    @if (product.DeletedAt.HasValue)
                                    {
                                        @product.DeletedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <form asp-action="Restore" asp-route-id="@product.Id" method="post" style="display: inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-success" title="Khôi phục">
                                                <i class="fas fa-undo"></i> Khôi phục
                                            </button>
                                        </form>
                                        <button type="button" class="btn btn-danger" onclick="confirmHardDelete(@product.Id, '@product.Name')" title="Xóa vĩnh viễn">
                                            <i class="fas fa-trash-alt"></i> Xóa vĩnh viễn
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <div class="card-footer">
                    <nav>
                        <ul class="pagination justify-content-center mb-0">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Trash" asp-route-page="@(Model.CurrentPage - 1)">Trước</a>
                            </li>
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                    <a class="page-link" asp-action="Trash" asp-route-page="@i">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Trash" asp-route-page="@(Model.CurrentPage + 1)">Sau</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-trash fa-3x text-muted mb-3"></i>
                <p class="text-muted">Thùng rác trống</p>
                <a asp-action="Index" class="btn btn-primary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại danh sách
                </a>
            </div>
        }
    </div>
</div>

<!-- Hard Delete Confirmation Modal -->
<div class="modal fade" id="hardDeleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Xác nhận xóa vĩnh viễn</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa vĩnh viễn sản phẩm <strong id="hardDeleteProductName"></strong>?</p>
                <p class="text-danger mb-0"><strong>Cảnh báo:</strong> Hành động này không thể hoàn tác. Tất cả dữ liệu liên quan (ảnh, tags, variants) sẽ bị xóa.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="hardDeleteForm" method="post" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Xóa vĩnh viễn</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function confirmHardDelete(id, name) {
        document.getElementById('hardDeleteProductName').textContent = name;
        document.getElementById('hardDeleteForm').action = '@Url.Action("HardDelete", "Product", new { area = "Admin" })/' + id;
        new bootstrap.Modal(document.getElementById('hardDeleteModal')).show();
    }
</script>
}
