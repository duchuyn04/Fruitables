@{
    ViewData["Title"] = "Cài đặt";
    Layout = "~/Areas/Admin/Views/Shared/_AdminDashboardLayout.cshtml";
    var activeTab = ViewBag.ActiveTab as string ?? "general";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="fas fa-cog me-2"></i>Cài đặt hệ thống</h4>
        <p class="text-muted mb-0">Quản lý cấu hình website</p>
    </div>
</div>

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
    @if (TempData["Success"] != null)
    {
        <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
            <div class="toast-header bg-success text-white">
                <i class="fas fa-check-circle me-2"></i>
                <strong class="me-auto">Thành công</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">@TempData["Success"]</div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
            <div class="toast-header bg-danger text-white">
                <i class="fas fa-exclamation-circle me-2"></i>
                <strong class="me-auto">Lỗi</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">@TempData["Error"]</div>
        </div>
    }
</div>

<div class="admin-card p-4">
                <!-- Tabs Navigation -->
                <ul class="nav nav-tabs mb-4" id="settingsTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link @(activeTab == "general" ? "active" : "")" 
                           href="@Url.Action("Index", new { tab = "general" })">
                            <i class="fas fa-home me-1"></i>Chung
                        </a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link @(activeTab == "seo" ? "active" : "")" 
                           href="@Url.Action("Index", new { tab = "seo" })">
                            <i class="fas fa-search me-1"></i>SEO
                        </a>
                    </li>

                    <li class="nav-item" role="presentation">
                        <a class="nav-link @(activeTab == "contact" ? "active" : "")" 
                           href="@Url.Action("Index", new { tab = "contact" })">
                            <i class="fas fa-envelope me-1"></i>Liên hệ
                        </a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link @(activeTab == "social" ? "active" : "")" 
                           href="@Url.Action("Index", new { tab = "social" })">
                            <i class="fas fa-share-alt me-1"></i>Mạng xã hội
                        </a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link @(activeTab == "banner" ? "active" : "")" 
                           href="@Url.Action("Index", new { tab = "banner" })">
                            <i class="fas fa-images me-1"></i>Banner
                        </a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link @(activeTab == "shipping" ? "active" : "")" 
                           href="@Url.Action("Index", new { tab = "shipping" })">
                            <i class="fas fa-truck me-1"></i>Vận chuyển
                        </a>
                    </li>
                </ul>

                <!-- Tab Content -->
                <div class="tab-content">
                    @if (activeTab == "general")
                    {
                        await Html.RenderPartialAsync("_GeneralSettings", Model as Fruitables.ViewModels.GeneralSettingsViewModel ?? new Fruitables.ViewModels.GeneralSettingsViewModel());
                    }
                    else if (activeTab == "seo")
                    {
                        await Html.RenderPartialAsync("_SeoSettings", Model as Fruitables.ViewModels.SeoSettingsViewModel ?? new Fruitables.ViewModels.SeoSettingsViewModel());
                    }
                    else if (activeTab == "contact")
                    {
                        await Html.RenderPartialAsync("_ContactSettings", Model as Fruitables.ViewModels.ContactSettingsViewModel ?? new Fruitables.ViewModels.ContactSettingsViewModel());
                    }
                    else if (activeTab == "social")
                    {
                        await Html.RenderPartialAsync("_SocialSettings", Model as Fruitables.ViewModels.SocialSettingsViewModel ?? new Fruitables.ViewModels.SocialSettingsViewModel());
                    }
                    else if (activeTab == "banner")
                    {
                        await Html.RenderPartialAsync("_BannerSettings", Model as Fruitables.ViewModels.BannerSettingsViewModel ?? new Fruitables.ViewModels.BannerSettingsViewModel());
                    }
                    else if (activeTab == "shipping")
                    {
                        await Html.RenderPartialAsync("_ShippingSettings", Model as Fruitables.ViewModels.ShippingSettingsViewModel ?? new Fruitables.ViewModels.ShippingSettingsViewModel());
                    }
                </div>
</div>

@section Styles {
<style>
    .nav-tabs .nav-link {
        color: #6c757d;
        border: none;
        border-bottom: 2px solid transparent;
        padding: 0.75rem 1.25rem;
    }
    .nav-tabs .nav-link:hover {
        color: #81c408;
        border-color: transparent;
    }
    .nav-tabs .nav-link.active {
        color: #81c408;
        background: transparent;
        border-color: transparent transparent #81c408;
        font-weight: 600;
    }
    .form-label {
        font-weight: 500;
        color: #495057;
    }
    .preview-image {
        max-width: 150px;
        max-height: 100px;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 5px;
    }
    .char-counter {
        font-size: 0.85rem;
        color: #6c757d;
    }
    .char-counter.warning {
        color: #ffc107;
    }
    .char-counter.danger {
        color: #dc3545;
    }
</style>
}
