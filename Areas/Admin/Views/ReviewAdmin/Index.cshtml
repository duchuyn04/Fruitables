@model PagedResult<ReviewAdminViewModel>
@using Fruitables.Helpers
@inject Fruitables.Data.ApplicationDbContext _context
@{
    ViewData["Title"] = "Quản lý đánh giá";
    Layout = null;
    
    // Fallback/Default Avatar logic
    var userAvatar = "/img/default-avatar.svg";
    var userName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Admin";
    
    if (User.Identity?.IsAuthenticated == true)
    {
        var userIdStr = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(userIdStr, out var userId))
        {
            var dbAvatar = _context.Users.Where(u => u.Id == userId).Select(u => u.Avatar).FirstOrDefault();
            if (!string.IsNullOrEmpty(dbAvatar))
            {
                userAvatar = dbAvatar;
            }
        }
    }

    var qsRaw = Context.Request.QueryString.Value?.TrimStart('?') ?? "";
    var filteredQsParts = qsRaw.Split('&', StringSplitOptions.RemoveEmptyEntries)
        .Where(p => !p.StartsWith("page=", StringComparison.OrdinalIgnoreCase));
    var baseQuery = string.IsNullOrEmpty(string.Join("&", filteredQsParts)) ? "" : "&" + string.Join("&", filteredQsParts);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"]</title>
    <script>
        // Load dark mode immediately to prevent flash
        const darkMode = localStorage.getItem('darkMode');
        if (darkMode === 'true' || darkMode === null) {
            document.documentElement.classList.add('dark');
            if (darkMode === null) localStorage.setItem('darkMode', 'true');
        }
    </script>
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: "class",
            important: true,
            theme: {
                extend: {
                    colors: {
                        primary: "#10b981",
                        "background-light": "#f8fafc",
                        "background-dark": "#0f172a",
                    },
                    fontFamily: {
                        sans: ["'Be Vietnam Pro'", "sans-serif"],
                    },
                    borderRadius: { DEFAULT: "0.625rem" },
                },
            },
        };
    </script>
    <style>
        :root {
            --sidebar-width: 260px;
            --primary-color: #81c408;
            --primary-dark: #5a8a06;
            --sidebar-bg: #1a1a2e;
            --sidebar-hover: #16213e;
        }
        body { font-family: 'Be Vietnam Pro', sans-serif; margin: 0 !important; padding: 0 !important; overflow-x: hidden; }
        * { box-sizing: border-box; }
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .dark .custom-scrollbar::-webkit-scrollbar-thumb { background: #475569; }

        /* Sidebar CSS */
        .admin-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--sidebar-bg);
            color: #fff;
            z-index: 1000;
            transition: all 0.3s ease;
            overflow-y: auto;
        }
        .admin-sidebar.collapsed { margin-left: calc(-1 * var(--sidebar-width)); }
        .sidebar-brand { padding: 1.5rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.1); text-align: center; }
        .sidebar-brand h4 { margin: 0; font-family: 'Be Vietnam Pro', sans-serif; font-weight: 800; font-size: 1.5rem; }
        .sidebar-brand .text-primary { color: var(--primary-color) !important; }
        .sidebar-menu { padding: 1rem 0; }
        .sidebar-menu-title { padding: 0.5rem 1.5rem; font-size: 0.75rem; text-transform: uppercase; color: rgba(255,255,255,0.4); letter-spacing: 1px; }
        .sidebar-nav { list-style: none; padding: 0; margin: 0; }
        .sidebar-nav-item { margin: 2px 0; }
        .sidebar-nav-link { 
            display: flex; align-items: center; padding: 0.75rem 1.5rem; 
            color: rgba(255,255,255,0.7); text-decoration: none; transition: all 0.2s ease; border-left: 3px solid transparent; 
        }
        .sidebar-nav-link:hover { background: var(--sidebar-hover); color: #fff; border-left-color: var(--primary-color); }
        .sidebar-nav-link.active { background: var(--sidebar-hover); color: var(--primary-color); border-left-color: var(--primary-color); }
        .sidebar-nav-link i { width: 20px; margin-right: 12px; text-align: center; }
        
        /* Main Content */
        .admin-main {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            transition: all 0.3s ease;
        }
        .admin-main.expanded { margin-left: 0; }
        @@media (max-width: 992px) {
            .admin-sidebar { margin-left: calc(-1 * var(--sidebar-width)); }
            .admin-sidebar.show { margin-left: 0; }
            .admin-main { margin-left: 0; }
        }
    </style>
    <!-- Icon Font Stylesheet -->
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css" />
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 min-h-screen transition-colors duration-200">

@Html.AntiForgeryToken()

<!-- Sidebar -->
<aside class="admin-sidebar" id="adminSidebar">
    @await Html.PartialAsync("_AdminSidebar")
</aside>

<!-- Main Wrapper -->
<div class="admin-main flex flex-col" id="adminMain">

<!-- Header -->
<header class="sticky top-0 z-30 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800">
    <div class="px-6 py-3 flex items-center justify-between">
        <div class="flex items-center space-x-4">
            <button id="sidebarToggle" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors text-slate-900 dark:text-white">
                <i class="fas fa-bars fa-lg text-slate-500"></i>
            </button>
            <nav class="flex text-sm font-medium text-slate-500 dark:text-slate-400">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="hover:text-primary cursor-pointer text-decoration-none transition-colors">Admin</a>
                <span class="mx-2 text-slate-300 dark:text-slate-700">/</span>
                <span class="text-slate-900 dark:text-white">Quản lý đánh giá</span>
            </nav>
        </div>
        <div class="flex items-center space-x-3">
            <button id="darkModeToggle" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors">
                <span class="material-icons-round dark:hidden text-slate-500">dark_mode</span>
                <span class="material-icons-round hidden dark:block text-slate-400">light_mode</span>
            </button>
            <div class="h-6 w-px bg-slate-200 dark:bg-slate-800"></div>
            <!-- User Dropdown -->
            <div class="relative" id="userDropdownWrapper">
                <button id="userDropdownBtn" class="flex items-center space-x-2 px-3 py-1.5 rounded-xl border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                    @if (!userAvatar.Contains("default-avatar.svg"))
                    {
                        <img src="@userAvatar" alt="Avatar" class="w-7 h-7 rounded-full border border-slate-200 dark:border-slate-700 object-cover"/>
                    }
                    else
                    {
                        <div class="w-7 h-7 rounded-full bg-primary/10 text-primary font-bold text-sm flex items-center justify-center">@userAvatar.Substring(0,1).ToUpper()</div>
                    }
                    <span class="text-sm font-semibold text-slate-800 dark:text-slate-100 hidden sm:block">@userName</span>
                    <span class="material-icons-round text-slate-400 text-sm">expand_more</span>
                </button>
                <!-- Dropdown Menu -->
                <div id="userDropdownMenu" class="hidden absolute right-0 mt-2 w-48 bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 shadow-xl z-50 overflow-hidden">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="flex items-center gap-3 px-4 py-3 text-sm text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">
                        <span class="material-icons-round text-base text-slate-500">home</span>
                        Xem trang chủ
                    </a>
                    <div class="border-t border-slate-100 dark:border-slate-700"></div>
                    <a asp-area="Admin" asp-controller="Auth" asp-action="Logout" class="flex items-center gap-3 px-4 py-3 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
                        <span class="material-icons-round text-base">logout</span>
                        Đăng xuất
                    </a>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- Main -->
<main class="p-6 lg:px-10 max-w-7xl mx-auto w-full flex-grow pb-12">

    <!-- Page Title & Stats -->
    <div class="mb-8 flex flex-col lg:flex-row justify-between items-start lg:items-end gap-4">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white">Quản lý đánh giá</h1>
            <p class="mt-2 text-slate-500 dark:text-slate-400">
                Hiển thị và quản lý các đánh giá từ khách hàng
            </p>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <!-- Avg Rating Card -->
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm p-6 relative overflow-hidden">
            <div class="flex justify-between items-start">
                <div>
                    <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-4">Trung bình sao</h3>
                    <div class="flex items-end gap-3">
                        <span class="text-3xl font-bold text-slate-900 dark:text-white">@(ViewBag.AverageRating != null ? ((decimal)ViewBag.AverageRating).ToString("0.0") : "0.0")</span>
                        <span class="text-emerald-500 text-sm font-semibold flex items-center mb-1">
                            <span class="material-icons-round text-sm mr-1">trending_up</span>+0.2 tháng này
                        </span>
                    </div>
                </div>
                <div class="w-10 h-10 rounded-xl bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center">
                    <span class="material-icons-round text-amber-500">star</span>
                </div>
            </div>
        </div>

        <!-- Total Valid Reviews Card -->
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm p-6 relative overflow-hidden">
            <div class="flex justify-between items-start">
                <div>
                    <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-4">Tổng đánh giá</h3>
                    <div class="flex items-end gap-3">
                        <span class="text-3xl font-bold text-slate-900 dark:text-white">@(ViewBag.TotalValidReviews ?? 0)</span>
                        <span class="text-emerald-500 text-sm font-semibold flex items-center mb-1">
                            <span class="material-icons-round text-sm mr-1">arrow_circle_up</span>+@(ViewBag.NewReviewsToday ?? 0) hôm nay
                        </span>
                    </div>
                </div>
                <div class="w-10 h-10 rounded-xl bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center">
                    <span class="material-icons-round text-emerald-500">rate_review</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Card -->
    <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm overflow-hidden mb-8">
        <div class="p-6">
            <form method="get" asp-area="Admin" asp-controller="ReviewAdmin" asp-action="Index" id="filterForm">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
                    <div class="lg:col-span-2">
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-2">Tìm kiếm</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
                                <span class="material-icons-round text-lg">search</span>
                            </span>
                            <input type="text" name="SearchTerm"
                                   class="w-full pl-10 pr-4 py-2.5 bg-slate-50 dark:bg-slate-900 border-none rounded-xl focus:ring-2 focus:ring-primary text-sm dark:placeholder-slate-500 dark:text-slate-100"
                                   placeholder="Tên sản phẩm, nội dung, người dùng..."
                                   value="@Context.Request.Query["SearchTerm"]"/>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-2">Trạng thái</label>
                        <select name="Status" class="w-full py-2.5 bg-slate-50 dark:bg-slate-900 border-none rounded-xl focus:ring-2 focus:ring-primary text-sm dark:text-slate-100">
                            <option value="">Tất cả trạng thái</option>
                            <option value="Visible" selected="@(Context.Request.Query["Status"] == "Visible")">Hiện</option>
                            <option value="Hidden" selected="@(Context.Request.Query["Status"] == "Hidden")">Ẩn</option>
                            <option value="Deleted" selected="@(Context.Request.Query["Status"] == "Deleted")">Đã xóa</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-2">Đánh giá</label>
                        <select name="Rating" class="w-full py-2.5 bg-slate-50 dark:bg-slate-900 border-none rounded-xl focus:ring-2 focus:ring-primary text-sm dark:text-slate-100">
                            <option value="">Tất cả mức sao</option>
                            <option value="5" selected="@(Context.Request.Query["Rating"] == "5")">5 sao ⭐⭐⭐⭐⭐</option>
                            <option value="4" selected="@(Context.Request.Query["Rating"] == "4")">4 sao ⭐⭐⭐⭐</option>
                            <option value="3" selected="@(Context.Request.Query["Rating"] == "3")">3 sao ⭐⭐⭐</option>
                            <option value="2" selected="@(Context.Request.Query["Rating"] == "2")">2 sao ⭐⭐</option>
                            <option value="1" selected="@(Context.Request.Query["Rating"] == "1")">1 sao ⭐</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-2">Sắp xếp</label>
                        <select name="SortBy" class="w-full py-2.5 bg-slate-50 dark:bg-slate-900 border-none rounded-xl focus:ring-2 focus:ring-primary text-sm dark:text-slate-100">
                            <option value="Newest" selected="@(Context.Request.Query["SortBy"] == "Newest" || string.IsNullOrEmpty(Context.Request.Query["SortBy"]))">Mới nhất</option>
                            <option value="Oldest" selected="@(Context.Request.Query["SortBy"] == "Oldest")">Cũ nhất</option>
                            <option value="HighestRating" selected="@(Context.Request.Query["SortBy"] == "HighestRating")">Đánh giá cao</option>
                            <option value="LowestRating" selected="@(Context.Request.Query["SortBy"] == "LowestRating")">Đánh giá thấp</option>
                            <option value="MostReported" selected="@(Context.Request.Query["SortBy"] == "MostReported")">Nhiều báo cáo</option>
                        </select>
                    </div>
                </div>

                <div class="mt-6 flex items-center justify-between border-t border-slate-100 dark:border-slate-700 pt-6">
                    <div class="flex items-center space-x-2">
                        @if (Model.Data?.Any(r => r.ReportCount > 0) == true)
                        {
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary/10 text-primary">
                                Đã báo cáo: @Model.Data.Sum(r => r.ReportCount)
                            </span>
                        }
                    </div>
                    <div class="flex space-x-3">
                        <a href="@Url.Action("Index")" class="px-5 py-2.5 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-200 font-semibold rounded-xl hover:bg-slate-200 dark:hover:bg-slate-600 transition-all flex items-center text-sm">
                            <span class="material-icons-round text-base mr-2">refresh</span> Đặt lại
                        </a>
                        <button type="submit" class="px-5 py-2.5 bg-primary text-white font-semibold rounded-xl hover:bg-emerald-600 shadow-lg shadow-primary/20 transition-all flex items-center text-sm">
                            <span class="material-icons-round text-base mr-2">search</span> Tìm kiếm
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Table Card -->
    <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm overflow-hidden mb-8">
        <div class="overflow-x-auto custom-scrollbar" id="reviewTableContainer">
            @await Html.PartialAsync("_ReviewTable", Model)
        </div>
    </div>

</main>

<!-- Hide Modal -->
<div class="modal fade" id="hideModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-amber-500 text-white">
                <h5 class="modal-title fw-bold">
                    <span class="material-icons-round align-middle me-1">visibility_off</span> Ẩn đánh giá
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="hideForm">
                    <input type="hidden" id="hideReviewId"/>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Lý do ẩn <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="hideReason" rows="3" required
                                  placeholder="Nhập lý do ẩn đánh giá này..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-warning" id="confirmHide">
                    <span class="material-icons-round align-middle" style="font-size:16px;">visibility_off</span> Ẩn đánh giá
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-bold">
                    <span class="material-icons-round align-middle me-1">delete_outline</span> Xóa đánh giá
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="deleteForm">
                    <input type="hidden" id="deleteReviewId"/>
                    <div class="alert alert-danger">
                        <span class="material-icons-round align-middle me-1" style="font-size:16px;">warning</span>
                        <strong>Cảnh báo:</strong> Hành động này không thể hoàn tác!
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Lý do xóa <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="deleteReason" rows="3" required
                                  placeholder="Nhập lý do xóa đánh giá này..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-danger" id="confirmDelete">
                    <span class="material-icons-round align-middle" style="font-size:16px;">delete_outline</span> Xóa đánh giá
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Toast Container -->
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1100;"></div>

</script>

</div> <!-- End adminMain -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/reviewAdmin.js" asp-append-version="true"></script>
<script>
    // Sidebar toggle logic (from old Layout)
    document.getElementById('sidebarToggle')?.addEventListener('click', function() {
        document.getElementById('adminSidebar').classList.toggle('collapsed');
        document.getElementById('adminMain').classList.toggle('expanded');
    });

    // Dark mode toggle
    const darkModeToggle = document.getElementById('darkModeToggle');
    darkModeToggle?.addEventListener('click', function () {
        document.documentElement.classList.toggle('dark');
        localStorage.setItem('darkMode', document.documentElement.classList.contains('dark'));
    });

    // User dropdown toggle
    const userDropdownBtn = document.getElementById('userDropdownBtn');
    const userDropdownMenu = document.getElementById('userDropdownMenu');
    userDropdownBtn?.addEventListener('click', function (e) {
        e.stopPropagation();
        userDropdownMenu.classList.toggle('hidden');
    });
    document.addEventListener('click', function () {
        userDropdownMenu?.classList.add('hidden');
    });
</script>
</body>
</html>
