@model Fruitables.ViewModels.BannerSettingsViewModel

<form asp-action="SaveBanner" method="post" enctype="multipart/form-data">
    <div class="row">
        <!-- Banner 1 -->
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="fas fa-image me-2"></i>Banner 1</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Hình ảnh hiện tại</label>
                                <div class="border rounded p-2 text-center" style="min-height: 150px;">
                                    @if (!string.IsNullOrEmpty(Model.Banner1.ImagePath))
                                    {
                                        <img src="@Model.Banner1.ImagePath" class="img-fluid" style="max-height: 140px;" alt="Banner 1">
                                    }
                                    else
                                    {
                                        <div class="text-muted py-5">Chưa có hình ảnh</div>
                                    }
                                </div>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Banner1.ImageFile" class="form-label">Thay đổi hình ảnh</label>
                                <input asp-for="Banner1.ImageFile" type="file" class="form-control" accept="image/*">
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label asp-for="Banner1.Title" class="form-label">Tiêu đề</label>
                                <input asp-for="Banner1.Title" class="form-control" placeholder="VD: Fresh Apples">
                            </div>
                            <div class="mb-3">
                                <label asp-for="Banner1.Subtitle" class="form-label">Phụ đề</label>
                                <input asp-for="Banner1.Subtitle" class="form-control" placeholder="VD: 20% OFF">
                            </div>
                            <div class="mb-3">
                                <label asp-for="Banner1.Link" class="form-label">Link (tùy chọn)</label>
                                <input asp-for="Banner1.Link" class="form-control" placeholder="VD: /shop?category=fruits">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Banner 2 -->
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h6 class="mb-0"><i class="fas fa-image me-2"></i>Banner 2</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Hình ảnh hiện tại</label>
                                <div class="border rounded p-2 text-center" style="min-height: 150px;">
                                    @if (!string.IsNullOrEmpty(Model.Banner2.ImagePath))
                                    {
                                        <img src="@Model.Banner2.ImagePath" class="img-fluid" style="max-height: 140px;" alt="Banner 2">
                                    }
                                    else
                                    {
                                        <div class="text-muted py-5">Chưa có hình ảnh</div>
                                    }
                                </div>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Banner2.ImageFile" class="form-label">Thay đổi hình ảnh</label>
                                <input asp-for="Banner2.ImageFile" type="file" class="form-control" accept="image/*">
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label asp-for="Banner2.Title" class="form-label">Tiêu đề</label>
                                <input asp-for="Banner2.Title" class="form-control" placeholder="VD: Tasty Fruits">
                            </div>
                            <div class="mb-3">
                                <label asp-for="Banner2.Subtitle" class="form-label">Phụ đề</label>
                                <input asp-for="Banner2.Subtitle" class="form-control" placeholder="VD: Free delivery">
                            </div>
                            <div class="mb-3">
                                <label asp-for="Banner2.Link" class="form-label">Link (tùy chọn)</label>
                                <input asp-for="Banner2.Link" class="form-control" placeholder="VD: /shop?category=fruits">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Banner 3 -->
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header" style="background-color: #81c408; color: white;">
                    <h6 class="mb-0"><i class="fas fa-image me-2"></i>Banner 3</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Hình ảnh hiện tại</label>
                                <div class="border rounded p-2 text-center" style="min-height: 150px;">
                                    @if (!string.IsNullOrEmpty(Model.Banner3.ImagePath))
                                    {
                                        <img src="@Model.Banner3.ImagePath" class="img-fluid" style="max-height: 140px;" alt="Banner 3">
                                    }
                                    else
                                    {
                                        <div class="text-muted py-5">Chưa có hình ảnh</div>
                                    }
                                </div>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Banner3.ImageFile" class="form-label">Thay đổi hình ảnh</label>
                                <input asp-for="Banner3.ImageFile" type="file" class="form-control" accept="image/*">
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label asp-for="Banner3.Title" class="form-label">Tiêu đề</label>
                                <input asp-for="Banner3.Title" class="form-control" placeholder="VD: Exotic Vegetables">
                            </div>
                            <div class="mb-3">
                                <label asp-for="Banner3.Subtitle" class="form-label">Phụ đề</label>
                                <input asp-for="Banner3.Subtitle" class="form-control" placeholder="VD: Discount 30$">
                            </div>
                            <div class="mb-3">
                                <label asp-for="Banner3.Link" class="form-label">Link (tùy chọn)</label>
                                <input asp-for="Banner3.Link" class="form-control" placeholder="VD: /shop?category=vegetables">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-end">
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save me-2"></i>Lưu cài đặt
        </button>
    </div>
</form>
