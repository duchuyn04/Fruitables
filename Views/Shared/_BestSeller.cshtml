@using Fruitables.Models
@{
    var products = ViewBag.FeaturedProducts as List<Product> ?? new List<Product>();
    var bestSellers = products.Take(6).ToList();
}

<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="text-center mx-auto mb-5" style="max-width: 700px;">
            <h1 class="display-4">Sản phẩm bán chạy</h1>
            <p>Khám phá những sản phẩm hữu cơ được yêu thích nhất của chúng tôi.</p>
        </div>
        <div class="row g-4">
            @if (bestSellers.Any())
            {
                @foreach (var product in bestSellers)
                {
                    var primaryImage = product.Images?.FirstOrDefault(i => i.IsPrimary)?.ImageUrl 
                        ?? product.Images?.FirstOrDefault()?.ImageUrl 
                        ?? "~/img/best-product-1.jpg";
                    <div class="col-lg-6 col-xl-4">
                        <div class="p-4 rounded bg-light">
                            <div class="row align-items-center">
                                <div class="col-6">
                                    <a asp-controller="Shop" asp-action="Detail" asp-route-id="@product.Id">
                                        <img src="@primaryImage" class="img-fluid rounded-circle w-100" alt="@product.Name">
                                    </a>
                                </div>
                                <div class="col-6">
                                    <a asp-controller="Shop" asp-action="Detail" asp-route-id="@product.Id" class="h5">@product.Name</a>
                                    <div class="d-flex my-3">
                                        @for (int i = 0; i < 5; i++)
                                        {
                                            <i class="fas fa-star @(i < 4 ? "text-primary" : "")"></i>
                                        }
                                    </div>
                                    @if (product.SalePrice.HasValue)
                                    {
                                        <h4 class="mb-3">@product.SalePrice.Value.ToString("N0")đ</h4>
                                    }
                                    else
                                    {
                                        <h4 class="mb-3">@product.Price.ToString("N0")đ</h4>
                                    }
                                    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-inline">
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <button type="submit" class="btn border border-secondary rounded-pill px-3 text-primary">
                                            <i class="fa fa-shopping-bag me-2 text-primary"></i> Thêm vào giỏ
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center">
                    <p>Chưa có sản phẩm bán chạy.</p>
                </div>
            }
        </div>
    </div>
</div>
