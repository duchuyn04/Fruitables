@using Fruitables.ViewModels
@model ShopViewModel
@{
    ViewData["Title"] = "Cửa hàng";
    var hasFilter = Model.SelectedCategoryId.HasValue
        || !string.IsNullOrWhiteSpace(Model.SearchTerm)
        || Model.MinPrice.HasValue
        || Model.MaxPrice.HasValue
        || !string.IsNullOrWhiteSpace(Model.SortBy);
}

<main class="shop-page">
    <section class="shop-hero">
        <div class="container">
            <div class="shop-hero-grid">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb shop-breadcrumb">
                            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Cửa hàng</li>
                        </ol>
                    </nav>
                    <span class="shop-label">Chợ Fruitables</span>
                    <h1>Chọn nông sản tươi, lọc nhanh và thêm vào giỏ dễ dàng</h1>
                    <p>Tìm rau củ, trái cây và combo phù hợp cho bữa ăn gia đình trong vài bước.</p>
                </div>

                <form asp-controller="Shop" asp-action="Index" method="get" class="shop-hero-search">
                    @if (Model.SelectedCategoryId.HasValue)
                    {
                        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                    }
                    @if (Model.MinPrice.HasValue)
                    {
                        <input type="hidden" name="minPrice" value="@Model.MinPrice" />
                    }
                    @if (Model.MaxPrice.HasValue)
                    {
                        <input type="hidden" name="maxPrice" value="@Model.MaxPrice" />
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.SortBy))
                    {
                        <input type="hidden" name="sortBy" value="@Model.SortBy" />
                    }
                    <label for="shopSearch" class="visually-hidden">Tìm sản phẩm</label>
                    <input id="shopSearch" type="search" name="search" class="form-control" placeholder="Tìm rau củ, trái cây, combo..." value="@Model.SearchTerm" />
                    <button type="submit" class="btn btn-secondary text-white">
                        <i class="fa fa-search"></i>
                        <span>Tìm kiếm</span>
                    </button>
                </form>
            </div>
        </div>
    </section>

    <section class="shop-shell">
        <div class="container">
            <div class="shop-toolbar">
                <div>
                    <span>@Model.Products.Count sản phẩm</span>
                    <strong>@(hasFilter ? "Kết quả đang lọc" : "Tất cả sản phẩm")</strong>
                </div>
                <div class="shop-toolbar-actions">
                    <button class="btn btn-primary d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#shopFilterOffcanvas" aria-controls="shopFilterOffcanvas">
                        <i class="fas fa-filter"></i>
                        <span>Bộ lọc</span>
                    </button>
                    <label for="sortBy" class="visually-hidden">Sắp xếp sản phẩm</label>
                    <select id="sortBy" class="shop-sort" onchange="location.href=this.value">
                        <option value="@Url.Action("Index", "Shop", new { categoryId = Model.SelectedCategoryId, search = Model.SearchTerm, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice })" selected="@(string.IsNullOrEmpty(Model.SortBy))">Sắp xếp mặc định</option>
                        <option value="@Url.Action("Index", "Shop", new { categoryId = Model.SelectedCategoryId, search = Model.SearchTerm, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, sortBy = "newest" })" selected="@(Model.SortBy == "newest")">Mới nhất</option>
                        <option value="@Url.Action("Index", "Shop", new { categoryId = Model.SelectedCategoryId, search = Model.SearchTerm, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, sortBy = "price_asc" })" selected="@(Model.SortBy == "price_asc")">Giá tăng dần</option>
                        <option value="@Url.Action("Index", "Shop", new { categoryId = Model.SelectedCategoryId, search = Model.SearchTerm, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, sortBy = "price_desc" })" selected="@(Model.SortBy == "price_desc")">Giá giảm dần</option>
                        <option value="@Url.Action("Index", "Shop", new { categoryId = Model.SelectedCategoryId, search = Model.SearchTerm, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, sortBy = "name" })" selected="@(Model.SortBy == "name")">Tên A-Z</option>
                    </select>
                </div>
            </div>

            @if (hasFilter)
            {
                <div class="shop-active-filter">
                    <span>Đang áp dụng bộ lọc</span>
                    <a asp-controller="Shop" asp-action="Index">Xóa tất cả</a>
                </div>
            }

            <div class="shop-layout">
                <aside class="shop-sidebar-col">
                    <partial name="_ShopSidebar" model="Model" />
                </aside>
                <section class="shop-products-col" aria-label="Danh sách sản phẩm">
                    <div class="shop-products-grid">
                        <partial name="_ShopProducts" model="Model" />
                    </div>
                </section>
            </div>
        </div>
    </section>
</main>

<style>
    .shop-page {
        background: #f7faf1;
        color: #273438;
        font-family: 'Be Vietnam Pro', sans-serif;
    }

    .shop-page h1,
    .shop-page h2,
    .shop-page h3,
    .shop-page h4,
    .shop-page h5,
    .shop-page h6,
    .shop-page input,
    .shop-page button,
    .shop-page select,
    .shop-page .btn {
        font-family: 'Be Vietnam Pro', sans-serif;
        letter-spacing: 0;
    }

    .shop-hero {
        padding: 154px 0 36px;
        background:
            linear-gradient(135deg, rgba(32, 74, 20, 0.94), rgba(129, 196, 8, 0.78)),
            url('/img/banner-fruits.jpg') center/cover;
        color: #ffffff;
    }

    .shop-hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(320px, 520px);
        gap: 32px;
        align-items: end;
    }

    .shop-breadcrumb {
        margin-bottom: 18px;
    }

    .shop-breadcrumb a,
    .shop-breadcrumb .active,
    .shop-breadcrumb .breadcrumb-item::before {
        color: rgba(255, 255, 255, 0.78);
    }

    .shop-label {
        display: inline-flex;
        margin-bottom: 10px;
        padding: 6px 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.16);
        color: #ffffff;
        font-size: 0.82rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .shop-hero h1 {
        max-width: 760px;
        margin: 0 0 14px;
        color: #ffffff;
        font-size: clamp(2rem, 4vw, 3.35rem);
        font-weight: 900;
        line-height: 1.08;
    }

    .shop-hero p {
        max-width: 560px;
        margin: 0;
        color: rgba(255, 255, 255, 0.88);
        font-size: 1.02rem;
    }

    .shop-hero-search {
        display: flex;
        gap: 8px;
        padding: 8px;
        border-radius: 999px;
        background: #ffffff;
        box-shadow: 0 18px 42px rgba(15, 23, 42, 0.2);
    }

    .shop-hero-search .form-control {
        min-height: 54px;
        border: 0;
        border-radius: 999px;
        padding-left: 18px;
        color: #273438;
    }

    .shop-hero-search .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-width: 138px;
        justify-content: center;
        border-radius: 999px;
        font-weight: 800;
    }

    .shop-shell {
        padding: 32px 0 64px;
    }

    .shop-toolbar,
    .shop-active-filter,
    .shop-filter-panel,
    .shop-product-card,
    .shop-empty-state {
        border-radius: 8px;
        background: #ffffff;
        border: 1px solid rgba(39, 52, 56, 0.08);
        box-shadow: 0 10px 28px rgba(31, 41, 55, 0.07);
    }

    .shop-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 16px;
        padding: 16px;
        position: sticky;
        top: 96px;
        z-index: 20;
    }

    .shop-toolbar span {
        display: block;
        color: #e8590c;
        font-size: 0.82rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .shop-toolbar strong {
        display: block;
        color: #273438;
        font-size: 1.15rem;
    }

    .shop-toolbar-actions {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .shop-toolbar-actions .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border-radius: 999px;
        font-weight: 800;
    }

    .shop-sort {
        min-height: 42px;
        padding: 0 38px 0 14px;
        border: 1px solid #dfe7d2;
        border-radius: 999px;
        background: #f8fbf3;
        color: #273438;
        font-weight: 700;
    }

    .shop-active-filter {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
        padding: 12px 16px;
    }

    .shop-active-filter span {
        color: #64748b;
        font-weight: 700;
    }

    .shop-active-filter a {
        color: #df2f2f;
        font-weight: 800;
        text-decoration: none;
    }

    .shop-layout {
        display: grid;
        grid-template-columns: 296px minmax(0, 1fr);
        gap: 22px;
        align-items: start;
    }

    .shop-sidebar-col {
        position: sticky;
        top: 182px;
    }

    .shop-products-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
    }

    .shop-products-grid.is-loading {
        opacity: 0.55;
        pointer-events: none;
    }

    @@media (max-width: 1199.98px) {
        .shop-products-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 991.98px) {
        .shop-hero {
            padding-top: 124px;
        }

        .shop-hero-grid,
        .shop-layout {
            grid-template-columns: 1fr;
        }

        .shop-sidebar-col {
            position: static;
        }

        .shop-toolbar {
            top: 86px;
        }
    }

    @@media (max-width: 575.98px) {
        .shop-hero {
            padding-top: 108px;
        }

        .shop-hero-search,
        .shop-toolbar,
        .shop-toolbar-actions {
            align-items: stretch;
            flex-direction: column;
        }

        .shop-hero-search {
            border-radius: 8px;
        }

        .shop-hero-search .form-control,
        .shop-hero-search .btn,
        .shop-sort {
            width: 100%;
            border-radius: 6px;
        }

        .shop-products-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
