@using Fruitables.Models
@{
    var products = ViewBag.AllProducts as List<Product> ?? new List<Product>();
    var parentCategories = ViewBag.Categories as List<Category> ?? new List<Category>();
}

<div class="container-fluid fruite py-5">
    <div class="container py-5">
        <div class="tab-class text-center">
            <div class="row g-4">
                <div class="col-lg-4 text-start">
                    <h1>Sản phẩm hữu cơ</h1>
                </div>
                <div class="col-lg-8 text-end">
                    <div id="tabsContainer">
                        <!-- Main tabs: Tất cả + Danh mục cha -->
                        <ul class="nav nav-pills d-inline-flex text-center mb-5" id="mainCategoryTabs">
                            <li class="nav-item">
                                <a class="d-flex m-2 py-2 bg-light rounded-pill active" data-bs-toggle="pill" href="#tab-all">
                                    <span class="text-dark" style="width: 130px;">Tất cả</span>
                                </a>
                            </li>
                            @foreach (var category in parentCategories.Take(4))
                            {
                                <li class="nav-item">
                                    <a class="d-flex py-2 m-2 bg-light rounded-pill" data-bs-toggle="pill" href="#tab-@category.Id" data-category-id="@category.Id" data-category-name="@category.Name">
                                        <span class="text-dark" style="width: 130px;">@category.Name</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
            <div class="tab-content">
                <!-- Tab Tất cả -->
                <div id="tab-all" class="tab-pane fade show p-0 active">
                    <div class="d-flex justify-content-start align-items-center mb-3 flex-wrap gap-3">
                        <span class="text-muted small">Lọc theo:</span>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input filter-checkbox" type="checkbox" id="filter-featured-all" data-filter="featured" data-category="all">
                            <label class="form-check-label small" for="filter-featured-all">Nổi bật</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input filter-checkbox" type="checkbox" id="filter-sale-all" data-filter="sale" data-category="all">
                            <label class="form-check-label small" for="filter-sale-all">Giá tốt</label>
                        </div>
                    </div>
                    <div class="row g-4">
                        <div class="col-lg-12">
                            <div class="row g-4 products-grid" data-category="all">
                                @if (products.Any())
                                {
                                    @foreach (var product in products)
                                    {
                                        <partial name="_ProductCard" model="product" view-data='new ViewDataDictionary(ViewData) { { "ShowCategoryBadge", true } }' />
                                    }
                                }
                                else
                                {
                                    <div class="col-12 text-center no-products">
                                        <p>Chưa có sản phẩm.</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tabs cho từng danh mục cha -->
                @foreach (var parentCat in parentCategories.Take(4))
                {
                    var parentProducts = products.Where(p => p.CategoryId == parentCat.Id || (p.Category?.ParentId == parentCat.Id)).ToList();
                    var childCategories = parentCat.Children?.Where(c => c.IsActive && !c.IsDeleted).OrderBy(c => c.SortOrder).ToList() ?? new List<Category>();
                    
                    <div id="tab-@parentCat.Id" class="tab-pane fade show p-0">
                        <!-- Sub-tab: Tất cả sản phẩm của danh mục cha -->
                        <div id="subtab-@parentCat.Id-all" class="subtab-pane active">
                            <div class="d-flex justify-content-start align-items-center mb-3 flex-wrap gap-3">
                                <span class="text-muted small">Lọc theo:</span>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input filter-checkbox" type="checkbox" id="filter-featured-@parentCat.Id" data-filter="featured" data-category="@parentCat.Id">
                                    <label class="form-check-label small" for="filter-featured-@parentCat.Id">Nổi bật</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input filter-checkbox" type="checkbox" id="filter-sale-@parentCat.Id" data-filter="sale" data-category="@parentCat.Id">
                                    <label class="form-check-label small" for="filter-sale-@parentCat.Id">Giá tốt</label>
                                </div>
                            </div>
                            <div class="row g-4">
                                <div class="col-lg-12">
                                    <div class="row g-4 products-grid" data-category="@parentCat.Id">
                                        @if (parentProducts.Any())
                                        {
                                            @foreach (var product in parentProducts)
                                            {
                                                <partial name="_ProductCard" model="product" view-data='new ViewDataDictionary(ViewData) { { "ShowCategoryBadge", true } }' />
                                            }
                                        }
                                        else
                                        {
                                            <div class="col-12 text-center no-products">
                                                <p>Chưa có sản phẩm trong danh mục này.</p>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Sub-tabs cho từng danh mục con -->
                        @foreach (var childCat in childCategories)
                        {
                            var childProducts = products.Where(p => p.CategoryId == childCat.Id).ToList();
                            <div id="subtab-@childCat.Id" class="subtab-pane" style="display: none;">
                                <div class="d-flex justify-content-start align-items-center mb-3 flex-wrap gap-3">
                                    <span class="text-muted small">Lọc theo:</span>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input filter-checkbox" type="checkbox" id="filter-featured-@childCat.Id" data-filter="featured" data-category="@childCat.Id">
                                        <label class="form-check-label small" for="filter-featured-@childCat.Id">Nổi bật</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input filter-checkbox" type="checkbox" id="filter-sale-@childCat.Id" data-filter="sale" data-category="@childCat.Id">
                                        <label class="form-check-label small" for="filter-sale-@childCat.Id">Giá tốt</label>
                                    </div>
                                </div>
                                <div class="row g-4">
                                    <div class="col-lg-12">
                                        <div class="row g-4 products-grid" data-category="@childCat.Id">
                                            @if (childProducts.Any())
                                            {
                                                @foreach (var product in childProducts)
                                                {
                                                    <partial name="_ProductCard" model="product" view-data='new ViewDataDictionary(ViewData) { { "ShowCategoryBadge", false } }' />
                                                }
                                            }
                                            else
                                            {
                                                <div class="col-12 text-center no-products">
                                                    <p>Chưa có sản phẩm trong danh mục này.</p>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Template cho sub-category tabs (ẩn hoàn toàn) -->
<div style="display: none;">
@foreach (var parentCat in parentCategories.Take(4))
{
    var childCategories = parentCat.Children?.Where(c => c.IsActive && !c.IsDeleted).OrderBy(c => c.SortOrder).ToList() ?? new List<Category>();
    if (childCategories.Any())
    {
        <ul class="nav nav-pills d-inline-flex text-center mb-5 sub-category-tabs" id="subTabs-@parentCat.Id" data-parent-id="@parentCat.Id" data-parent-name="@parentCat.Name">
            <li class="nav-item">
                <a class="d-flex m-2 py-2 bg-light rounded-pill back-to-main" href="#" data-back="true">
                    <span class="text-dark" style="width: 130px;">Quay lại</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="d-flex m-2 py-2 bg-light rounded-pill active" data-bs-toggle="pill" href="#subtab-@parentCat.Id-all" data-subtab-target="subtab-@parentCat.Id-all">
                    <span class="text-dark" style="width: 130px;">Tất cả @parentCat.Name</span>
                </a>
            </li>
            @foreach (var childCat in childCategories)
            {
                <li class="nav-item">
                    <a class="d-flex py-2 m-2 bg-light rounded-pill" data-bs-toggle="pill" href="#subtab-@childCat.Id" data-subtab-target="subtab-@childCat.Id">
                        <span class="text-dark" style="width: 130px;">@childCat.Name</span>
                    </a>
                </li>
            }
        </ul>
    }
}
</div>

<style>
.filter-tag {
    display: inline-flex;
    align-items: center;
    background-color: #81c408;
    color: white;
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 0.85rem;
    margin-left: 5px;
}
.filter-tag .remove-filter {
    margin-left: 6px;
    cursor: pointer;
    font-weight: bold;
}
.filter-tag .remove-filter:hover {
    opacity: 0.7;
}

/* Active state cho tabs - màu xanh mặc định */
#mainCategoryTabs .nav-item a.active,
#mainCategoryTabs .nav-item a.active:hover,
#mainCategoryTabs .nav-item a.active:focus,
.sub-category-tabs .nav-item a.active,
.sub-category-tabs .nav-item a.active:hover,
.sub-category-tabs .nav-item a.active:focus,
#activeSubTabs .nav-item a.active,
#activeSubTabs .nav-item a.active:hover,
#activeSubTabs .nav-item a.active:focus {
    background-color: #81c408 !important;
}
#mainCategoryTabs .nav-item a.active .text-dark,
#mainCategoryTabs .nav-item a.active:hover .text-dark,
.sub-category-tabs .nav-item a.active .text-dark,
.sub-category-tabs .nav-item a.active:hover .text-dark,
#activeSubTabs .nav-item a.active .text-dark,
#activeSubTabs .nav-item a.active:hover .text-dark {
    color: white !important;
}

/* Hover cho main category tabs */
#mainCategoryTabs .nav-item a {
    transition: all 0.3s ease;
}
#mainCategoryTabs .nav-item a:hover:not(.active) {
    background-color: #81c408 !important;
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(129, 196, 8, 0.3);
}
#mainCategoryTabs .nav-item a:hover:not(.active) .text-dark {
    color: white !important;
}

/* Hover cho sub-category tabs - bao gồm cả active */
.sub-category-tabs .nav-item a,
#activeSubTabs .nav-item a {
    transition: all 0.3s ease;
}
.sub-category-tabs .nav-item a:hover,
#activeSubTabs .nav-item a:hover {
    background-color: #81c408 !important;
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(129, 196, 8, 0.3);
}
.sub-category-tabs .nav-item a:hover .text-dark,
#activeSubTabs .nav-item a:hover .text-dark {
    color: white !important;
}

/* Hover cho nút Quay lại */
.back-to-main {
    cursor: pointer;
    transition: all 0.3s ease;
}
.back-to-main:hover {
    background-color: #81c408 !important;
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(129, 196, 8, 0.3);
}
.back-to-main:hover .text-dark {
    color: white !important;
}
</style>
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var tabsContainer = document.getElementById('tabsContainer');
    var mainCategoryTabs = document.getElementById('mainCategoryTabs');
    
    // Xử lý khi click vào main category tab
    document.querySelectorAll('#mainCategoryTabs a[data-bs-toggle="pill"]').forEach(function(tab) {
        tab.addEventListener('shown.bs.tab', function(e) {
            var categoryId = this.getAttribute('data-category-id');
            
            // Nếu có categoryId, thay thế main tabs bằng sub-tabs
            if (categoryId) {
                var subTabsTemplate = document.getElementById('subTabs-' + categoryId);
                if (subTabsTemplate) {
                    // Clone sub-tabs
                    var clonedSubTabs = subTabsTemplate.cloneNode(true);
                    clonedSubTabs.style.display = 'flex';
                    clonedSubTabs.id = 'activeSubTabs';
                    
                    // Thay thế main tabs bằng sub-tabs
                    tabsContainer.innerHTML = '';
                    tabsContainer.appendChild(clonedSubTabs);
                    
                    // Gắn sự kiện cho sub-tabs
                    attachSubTabEvents(clonedSubTabs);
                    
                    // Hiển thị sub-tab đầu tiên (Tất cả)
                    var firstSubTab = clonedSubTabs.querySelector('a[data-subtab-target]');
                    if (firstSubTab) {
                        var targetId = firstSubTab.getAttribute('data-subtab-target');
                        showSubTab(targetId);
                    }
                }
            }
        });
    });
    
    function attachSubTabEvents(subTabsElement) {
        // Xử lý nút "Quay lại"
        var backButton = subTabsElement.querySelector('.back-to-main');
        if (backButton) {
            backButton.addEventListener('click', function(e) {
                e.preventDefault();
                
                // Khôi phục main tabs
                tabsContainer.innerHTML = '';
                tabsContainer.appendChild(mainCategoryTabs);
                mainCategoryTabs.style.display = 'flex';
                
                // Kích hoạt tab "Tất cả"
                var allTab = mainCategoryTabs.querySelector('a[href="#tab-all"]');
                if (allTab) {
                    var bsTab = new bootstrap.Tab(allTab);
                    bsTab.show();
                }
            });
        }
        
        // Xử lý click vào sub-tabs
        subTabsElement.querySelectorAll('a[data-subtab-target]').forEach(function(tab) {
            tab.addEventListener('click', function(e) {
                e.preventDefault();
                var targetId = this.getAttribute('data-subtab-target');
                showSubTab(targetId);
                
                // Cập nhật active state
                subTabsElement.querySelectorAll('a[data-subtab-target]').forEach(function(link) {
                    link.classList.remove('active');
                });
                this.classList.add('active');
            });
        });
    }
    
    function showSubTab(targetId) {
        // Ẩn tất cả subtab-pane trong parent tab hiện tại
        var parentTab = document.querySelector('.tab-pane.active');
        if (parentTab) {
            parentTab.querySelectorAll('.subtab-pane').forEach(function(pane) {
                pane.style.display = 'none';
                pane.classList.remove('active');
            });
            
            // Hiển thị subtab-pane được chọn
            var targetPane = document.getElementById(targetId);
            if (targetPane) {
                targetPane.style.display = 'block';
                targetPane.classList.add('active');
            }
        }
    }
    
    // Filter functionality
    document.querySelectorAll('.filter-checkbox').forEach(function(checkbox) {
        checkbox.addEventListener('change', function() {
            var categoryId = this.getAttribute('data-category');
            applyFilters(categoryId);
        });
    });

    function applyFilters(categoryId) {
        var productsGrid = document.querySelector('.subtab-pane.active .products-grid[data-category="' + categoryId + '"]');
        if (!productsGrid) {
            productsGrid = document.querySelector('.tab-pane.active .products-grid[data-category="' + categoryId + '"]');
        }
        if (!productsGrid) return;
        
        var productItems = productsGrid.querySelectorAll('.product-card-wrapper');
        var filterContainer = productsGrid.closest('.subtab-pane, .tab-pane');
        var featuredCheckbox = filterContainer.querySelector('.filter-checkbox[data-filter="featured"][data-category="' + categoryId + '"]');
        var saleCheckbox = filterContainer.querySelector('.filter-checkbox[data-filter="sale"][data-category="' + categoryId + '"]');
        
        var featuredChecked = featuredCheckbox ? featuredCheckbox.checked : false;
        var saleChecked = saleCheckbox ? saleCheckbox.checked : false;
        
        var hasVisibleProducts = false;
        
        productItems.forEach(function(item) {
            var isFeatured = item.getAttribute('data-featured') === 'true';
            var isSale = item.getAttribute('data-sale') === 'true';
            var show = true;
            
            if (featuredChecked && !isFeatured) show = false;
            if (saleChecked && !isSale) show = false;
            
            if (show) {
                item.style.display = '';
                hasVisibleProducts = true;
            } else {
                item.style.display = 'none';
            }
        });
        
        // Hiển thị/ẩn thông báo không có sản phẩm
        var filteredMsg = productsGrid.querySelector('.no-products-filtered');
        if (!hasVisibleProducts) {
            if (!filteredMsg) {
                var msg = document.createElement('div');
                msg.className = 'col-12 text-center no-products-filtered';
                msg.innerHTML = '<p>Không có sản phẩm phù hợp với bộ lọc.</p>';
                productsGrid.appendChild(msg);
            }
        } else {
            if (filteredMsg) filteredMsg.remove();
        }
    }
});
</script>
