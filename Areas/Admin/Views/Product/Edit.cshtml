@model Fruitables.ViewModels.EditProductViewModel
@{
    ViewData["Title"] = "Sửa sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminDashboardLayout.cshtml";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Sửa sản phẩm</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Sản phẩm</a></li>
                <li class="breadcrumb-item active">@Model.Product.Name</li>
            </ol>
        </nav>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Quay lại
        </a>
    </div>
</div>

<form asp-action="Edit" asp-route-id="@Model.Product.Id" method="post" enctype="multipart/form-data">
    <input type="hidden" name="request.Id" value="@Model.Product.Id" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
    
    <div class="row">
        <!-- Main Info -->
        <div class="col-lg-8">
            <div class="admin-card mb-3">
                <div class="card-header">
                    <i class="fas fa-info-circle me-2"></i>Thông tin cơ bản
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="request_Name" class="form-label">Tên sản phẩm <span class="text-danger">*</span></label>
                        <input type="text" name="request.Name" id="request_Name" value="@Model.Product.Name" class="form-control" placeholder="Nhập tên sản phẩm" />
                    </div>

                    <div class="mb-3">
                        <label for="request_Slug" class="form-label">Slug</label>
                        <input type="text" name="request.Slug" id="request_Slug" value="@Model.Product.Slug" class="form-control" placeholder="Tự động tạo nếu để trống" />
                        <small class="text-muted">URL thân thiện cho sản phẩm</small>
                    </div>

                    <div class="mb-3">
                        <label for="request_ShortDescription" class="form-label">Mô tả ngắn</label>
                        <textarea name="request.ShortDescription" id="request_ShortDescription" class="form-control" rows="2" placeholder="Mô tả ngắn gọn về sản phẩm">@Model.Product.ShortDescription</textarea>
                    </div>

                    <div class="mb-3">
                        <label for="request_Description" class="form-label">Mô tả chi tiết</label>
                        <textarea name="request.Description" id="request_Description" class="form-control" rows="5" placeholder="Mô tả chi tiết về sản phẩm">@Model.Product.Description</textarea>
                    </div>
                </div>
            </div>

            <!-- Pricing & Inventory -->
            <div class="admin-card mb-3">
                <div class="card-header">
                    <i class="fas fa-dollar-sign me-2"></i>Giá & Kho hàng
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="request_Price" class="form-label">Giá gốc <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" name="request.Price" id="request_Price" value="@Model.Product.Price" step="0.01" class="form-control" placeholder="0" />
                                <span class="input-group-text">đ</span>
                            </div>
                            <small class="text-muted d-flex align-items-center mt-1">
                                <i class="fas fa-eye me-1"></i>
                                <span id="pricePreview">@Model.Product.Price.ToString("N0") VND</span>
                            </small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="request_SalePrice" class="form-label">Giá khuyến mãi</label>
                            <div class="input-group">
                                <input type="number" name="request.SalePrice" id="request_SalePrice" value="@Model.Product.SalePrice" step="0.01" class="form-control" placeholder="0" />
                                <span class="input-group-text">đ</span>
                            </div>
                            <small class="text-muted d-flex align-items-center mt-1">
                                <i class="fas fa-eye me-1"></i>
                                <span id="salePricePreview">@(Model.Product.SalePrice?.ToString("N0") ?? "0") VND</span>
                            </small>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="request_StockQuantity" class="form-label">Số lượng tồn kho</label>
                            <input type="number" name="request.StockQuantity" id="request_StockQuantity" value="@Model.Product.StockQuantity" class="form-control" placeholder="0" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="request_MinOrderQuantity" class="form-label">Số lượng đặt tối thiểu</label>
                            <input type="number" name="request.MinOrderQuantity" id="request_MinOrderQuantity" value="@Model.Product.MinOrderQuantity" class="form-control" placeholder="1" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Product Details -->
            <div class="admin-card mb-3">
                <div class="card-header">
                    <i class="fas fa-clipboard-list me-2"></i>Thông tin chi tiết
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="request_Unit" class="form-label">Đơn vị</label>
                            <input type="text" name="request.Unit" id="request_Unit" value="@Model.Product.Unit" class="form-control" placeholder="kg, hộp, gói..." />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="request_Weight" class="form-label">Trọng lượng</label>
                            <div class="input-group">
                                <input type="number" name="request.Weight" id="request_Weight" value="@Model.Product.Weight" step="0.01" class="form-control" placeholder="0" />
                                <span class="input-group-text">kg</span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="request_CountryOrigin" class="form-label">Xuất xứ</label>
                            <input type="text" name="request.CountryOrigin" id="request_CountryOrigin" value="@Model.Product.CountryOrigin" class="form-control" placeholder="Việt Nam, Thái Lan..." />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="request_Quality" class="form-label">Chất lượng</label>
                            <input type="text" name="request.Quality" id="request_Quality" value="@Model.Product.Quality" class="form-control" placeholder="Organic, Premium..." />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Images Management -->
            <div class="admin-card mb-3">
                <div class="card-header">
                    <i class="fas fa-images me-2"></i>Quản lý hình ảnh
                </div>
                <div class="card-body">
                    <!-- Current Images -->
                    @if (Model.Product.Images?.Any() == true)
                    {
                        <div class="row g-3 mb-3" id="imagesList">
                            @foreach (var image in Model.Product.Images.OrderBy(i => i.SortOrder))
                            {
                                <div class="col-md-3" data-image-id="@image.Id">
                                    <div class="card">
                                        <img src="@image.ImageUrl" class="card-img-top" alt="Product image" style="height: 150px; object-fit: cover;" />
                                        <div class="card-body p-2">
                                            <div class="d-flex justify-content-between align-items-center">
                                                @if (image.IsPrimary)
                                                {
                                                    <span class="badge bg-success">Ảnh chính</span>
                                                }
                                                else
                                                {
                                                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="setPrimaryImage(@Model.Product.Id, @image.Id)">
                                                        Đặt làm chính
                                                    </button>
                                                }
                                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteImage(@Model.Product.Id, @image.Id)">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <!-- Upload New Images -->
                    <div class="mb-3">
                        <label class="form-label">Thêm hình ảnh mới</label>
                        <input type="file" name="images" id="imageUploadInput" class="form-control" multiple accept="image/*" />
                        <small class="text-muted">Chọn nhiều ảnh (tối đa 5MB/ảnh)</small>
                    </div>
                    
                    <!-- Image Preview Section -->
                    <div id="imagePreviewContainer" class="row g-3" style="display: none;">
                        <div class="col-12">
                            <label class="form-label text-muted">Xem trước hình ảnh sẽ upload:</label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Variants Management -->
            <div class="admin-card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-layer-group me-2"></i>Biến thể sản phẩm</span>
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addVariantModal">
                        <i class="fas fa-plus me-1"></i>Thêm biến thể
                    </button>
                </div>
                <div class="card-body">
                    @if (Model.Product.Variants?.Any() == true)
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>SKU</th>
                                        <th>Tên</th>
                                        <th>Giá</th>
                                        <th>Tồn kho</th>
                                        <th>Trạng thái</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody id="variantsList">
                                    @foreach (var variant in Model.Product.Variants)
                                    {
                                        <tr data-variant-id="@variant.Id">
                                            <td><code>@variant.SKU</code></td>
                                            <td>@variant.Name</td>
                                            <td>@variant.Price.ToString("N0") đ</td>
                                            <td>@variant.StockQuantity</td>
                                            <td>
                                                @if (variant.IsActive)
                                                {
                                                    <span class="badge bg-success">Hoạt động</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Tạm ẩn</span>
                                                }
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteVariant(@variant.Id)">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">Chưa có biến thể nào</p>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Category & Status -->
            <div class="admin-card mb-3">
                <div class="card-header">
                    <i class="fas fa-cog me-2"></i>Cài đặt
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="request_CategoryId" class="form-label">Danh mục <span class="text-danger">*</span></label>
                        <select name="request.CategoryId" id="request_CategoryId" class="form-select">
                            <option value="">-- Chọn danh mục --</option>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.Id" selected="@(Model.Product.CategoryId == category.Id)">@category.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input type="checkbox" name="request.IsActive" id="request_IsActive" value="true" class="form-check-input" checked="@Model.Product.IsActive" />
                            <label class="form-check-label" for="request_IsActive">Kích hoạt sản phẩm</label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input type="checkbox" name="request.IsFeatured" id="request_IsFeatured" value="true" class="form-check-input" checked="@Model.Product.IsFeatured" />
                            <label class="form-check-label" for="request_IsFeatured">Sản phẩm nổi bật</label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tags -->
            <div class="admin-card mb-3">
                <div class="card-header">
                    <i class="fas fa-tags me-2"></i>Tags
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Tags sản phẩm</label>
                        <input type="text" id="tagsInput" class="form-control" placeholder="Nhập tag và nhấn Enter" />
                        <small class="text-muted">Nhập tag và nhấn Enter để thêm</small>
                    </div>
                    <div id="tagsList" class="d-flex flex-wrap gap-2"></div>
                    <button type="button" class="btn btn-sm btn-primary mt-2" onclick="updateTags()">
                        <i class="fas fa-save me-1"></i>Cập nhật tags
                    </button>
                </div>
            </div>

            <!-- Actions -->
            <div class="admin-card">
                <div class="card-body">
                    <button type="submit" class="btn btn-primary w-100 mb-2">
                        <i class="fas fa-save me-2"></i>Cập nhật sản phẩm
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">Hủy</a>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- Add Variant Modal -->
<div class="modal fade" id="addVariantModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Thêm biến thể</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">SKU <span class="text-danger">*</span></label>
                    <input type="text" id="variantSKU" class="form-control" placeholder="Mã SKU" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Tên biến thể <span class="text-danger">*</span></label>
                    <input type="text" id="variantName" class="form-control" placeholder="VD: Size L, Màu đỏ" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Giá <span class="text-danger">*</span></label>
                    <input type="number" id="variantPrice" class="form-control" placeholder="0" step="0.01" />
                    <small class="text-muted d-flex align-items-center mt-1">
                        <i class="fas fa-eye me-1"></i>
                        <span id="variantPricePreview">0 VND</span>
                    </small>
                </div>
                <div class="mb-3">
                    <label class="form-label">Giá khuyến mãi</label>
                    <input type="number" id="variantSalePrice" class="form-control" placeholder="0" step="0.01" />
                    <small class="text-muted d-flex align-items-center mt-1">
                        <i class="fas fa-eye me-1"></i>
                        <span id="variantSalePricePreview">0 VND</span>
                    </small>
                </div>
                <div class="mb-3">
                    <label class="form-label">Số lượng tồn kho</label>
                    <input type="number" id="variantStock" class="form-control" placeholder="0" />
                </div>
                <div class="mb-3">
                    <div class="form-check form-switch">
                        <input type="checkbox" id="variantIsActive" class="form-check-input" checked />
                        <label class="form-check-label">Kích hoạt</label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" onclick="addVariant()">Thêm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const productId = @Model.Product.Id;
        
        // Price formatting
        function formatPrice(value) {
            if (!value || value === '' || isNaN(value)) return '0 VND';
            return new Intl.NumberFormat('vi-VN').format(value) + ' VND';
        }

        document.getElementById('request_Price')?.addEventListener('input', function(e) {
            document.getElementById('pricePreview').textContent = formatPrice(e.target.value);
        });

        document.getElementById('request_SalePrice')?.addEventListener('input', function(e) {
            document.getElementById('salePricePreview').textContent = formatPrice(e.target.value);
        });

        // Variant price formatting
        document.getElementById('variantPrice')?.addEventListener('input', function(e) {
            document.getElementById('variantPricePreview').textContent = formatPrice(e.target.value);
        });

        document.getElementById('variantSalePrice')?.addEventListener('input', function(e) {
            document.getElementById('variantSalePricePreview').textContent = formatPrice(e.target.value);
        });

        // Tags management
        let tags = @Html.Raw(Json.Serialize(Model.Product.Tags?.Select(pt => pt.Name).ToList() ?? new List<string>()));
        const tagsInput = document.getElementById('tagsInput');
        const tagsList = document.getElementById('tagsList');

        tagsInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                const tag = this.value.trim();
                if (tag && !tags.includes(tag)) {
                    tags.push(tag);
                    updateTagsDisplay();
                    this.value = '';
                }
            }
        });

        function removeTag(tag) {
            tags = tags.filter(t => t !== tag);
            updateTagsDisplay();
        }

        function updateTagsDisplay() {
            tagsList.innerHTML = tags.map(tag => 
                `<span class="badge bg-primary">
                    ${tag}
                    <i class="fas fa-times ms-1" style="cursor: pointer;" onclick="removeTag('${tag}')"></i>
                </span>`
            ).join('');
        }

        function updateTags() {
            fetch('@Url.Action("UpdateTags", "Product", new { area = "Admin" })', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({ productId: productId, tagNames: tags })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Cập nhật tags thành công!');
                } else {
                    alert('Lỗi: ' + data.message);
                }
            });
        }

        // Image management
        function setPrimaryImage(productId, imageId) {
            fetch('@Url.Action("SetPrimaryImage", "Product", new { area = "Admin" })', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId: productId, imageId: imageId })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Lỗi: ' + data.message);
                }
            });
        }

        function deleteImage(productId, imageId) {
            if (confirm('Bạn có chắc chắn muốn xóa ảnh này?')) {
                fetch('@Url.Action("DeleteImage", "Product", new { area = "Admin" })', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId: productId, imageId: imageId })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Lỗi: ' + data.message);
                    }
                });
            }
        }

        // Variant management
        function addVariant() {
            const variant = {
                productId: productId,
                sku: document.getElementById('variantSKU').value,
                name: document.getElementById('variantName').value,
                price: parseFloat(document.getElementById('variantPrice').value),
                salePrice: document.getElementById('variantSalePrice').value ? parseFloat(document.getElementById('variantSalePrice').value) : null,
                stockQuantity: parseInt(document.getElementById('variantStock').value) || 0,
                isActive: document.getElementById('variantIsActive').checked
            };

            fetch('@Url.Action("AddVariant", "Product", new { area = "Admin" })', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(variant)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Lỗi: ' + data.message);
                }
            });
        }

        function deleteVariant(variantId) {
            if (confirm('Bạn có chắc chắn muốn xóa biến thể này?')) {
                fetch('@Url.Action("DeleteVariant", "Product", new { area = "Admin" })/' + variantId, {
                    method: 'POST'
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Lỗi: ' + data.message);
                    }
                });
            }
        }

        // Initialize tags display
        updateTagsDisplay();

        // Image preview functionality
        const imageUploadInput = document.getElementById('imageUploadInput');
        const imagePreviewContainer = document.getElementById('imagePreviewContainer');

        imageUploadInput.addEventListener('change', function(e) {
            const files = e.target.files;
            
            // Clear previous previews (keep the label)
            const existingPreviews = imagePreviewContainer.querySelectorAll('.preview-item');
            existingPreviews.forEach(item => item.remove());
            
            if (files.length === 0) {
                imagePreviewContainer.style.display = 'none';
                return;
            }
            
            imagePreviewContainer.style.display = 'flex';
            
            Array.from(files).forEach((file, index) => {
                if (!file.type.startsWith('image/')) return;
                
                const reader = new FileReader();
                reader.onload = function(e) {
                    const previewCol = document.createElement('div');
                    previewCol.className = 'col-md-3 preview-item';
                    previewCol.innerHTML = `
                        <div class="card">
                            <img src="${e.target.result}" class="card-img-top" alt="Preview" style="height: 150px; object-fit: cover;" />
                            <div class="card-body p-2">
                                <small class="text-muted text-truncate d-block">${file.name}</small>
                                <small class="text-muted">${(file.size / 1024).toFixed(1)} KB</small>
                            </div>
                        </div>
                    `;
                    imagePreviewContainer.appendChild(previewCol);
                };
                reader.readAsDataURL(file);
            });
        });
    </script>
}
