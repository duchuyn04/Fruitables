@model Fruitables.ViewModels.OrderListResult
@using Fruitables.Models
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminDashboardLayout.cshtml";

    var search = ViewBag.Search as string;
    var status = ViewBag.Status as OrderStatus?;
    var paymentStatus = ViewBag.PaymentStatus as PaymentStatus?;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var sortByVal = ViewBag.SortBy as string ?? "CreatedAt";
    var sortDescending = (bool)(ViewBag.SortDescending ?? true);
}

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1">Quản lý đơn hàng</h4>
            <p class="text-muted mb-0">Tổng cộng <span id="totalCount">@Model.TotalCount</span> đơn hàng</p>
        </div>
        <div id="loadingIndicator" class="d-none">
            <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
            <span class="text-muted ms-1">Đang tải...</span>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        @if (TempData["Success"] != null)
        {
            <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
                <div class="toast-header bg-success text-white">
                    <i class="fas fa-check-circle me-2"></i>
                    <strong class="me-auto">Thành công</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">@TempData["Success"]</div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
                <div class="toast-header bg-danger text-white">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    <strong class="me-auto">Lỗi</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">@TempData["Error"]</div>
            </div>
        }
    </div>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Tìm kiếm</label>
                    <input type="text" id="filterSearch" class="form-control" placeholder="Mã đơn hàng..." value="@search">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Trạng thái</label>
                    <select id="filterStatus" class="form-select">
                        <option value="">Tất cả</option>
                        @foreach (OrderStatus s in Enum.GetValues(typeof(OrderStatus)))
                        {
                            <option value="@s" selected="@(status == s)">@GetStatusDisplayName(s)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Thanh toán</label>
                    <select id="filterPaymentStatus" class="form-select">
                        <option value="">Tất cả</option>
                        @foreach (PaymentStatus ps in Enum.GetValues(typeof(PaymentStatus)))
                        {
                            <option value="@ps" selected="@(paymentStatus == ps)">@GetPaymentStatusDisplayName(ps)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Từ ngày</label>
                    <input type="date" id="filterFromDate" class="form-control" value="@fromDate?.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Đến ngày</label>
                    <input type="date" id="filterToDate" class="form-control" value="@toDate?.ToString("yyyy-MM-dd")">
                </div>
            </div>
        </div>
    </div>

    <!-- Orders Table -->
    <div class="card" id="orderListContainer">
        @await Html.PartialAsync("_OrderList", Model)
    </div>
</div>

@section Scripts {
<script>
    let debounceTimer;
    let currentSortBy = '@sortByVal';
    let currentSortDescending = @(sortDescending ? "true" : "false");

    function debounce(func, delay) {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(func, delay);
    }

    function loadOrders(page = 1) {
        const search = document.getElementById('filterSearch').value;
        const status = document.getElementById('filterStatus').value;
        const paymentStatus = document.getElementById('filterPaymentStatus').value;
        const fromDate = document.getElementById('filterFromDate').value;
        const toDate = document.getElementById('filterToDate').value;

        const params = new URLSearchParams();
        if (search) params.append('search', search);
        if (status) params.append('status', status);
        if (paymentStatus) params.append('paymentStatus', paymentStatus);
        if (fromDate) params.append('fromDate', fromDate);
        if (toDate) params.append('toDate', toDate);
        params.append('sortBy', currentSortBy);
        params.append('sortDescending', currentSortDescending);
        params.append('page', page);

        document.getElementById('loadingIndicator').classList.remove('d-none');

        fetch(`@Url.Action("Index", "Order", new { area = "Admin" })?${params.toString()}`, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => response.text())
        .then(html => {
            document.getElementById('orderListContainer').innerHTML = html;
            // Update total count
            const totalCountEl = document.getElementById('orderTotalCount');
            if (totalCountEl) {
                document.getElementById('totalCount').textContent = totalCountEl.value;
            }
            // Update URL without reload
            const newUrl = `@Url.Action("Index", "Order", new { area = "Admin" })?${params.toString()}`;
            window.history.replaceState({}, '', newUrl);
        })
        .catch(error => console.error('Error:', error))
        .finally(() => {
            document.getElementById('loadingIndicator').classList.add('d-none');
        });
    }

    function loadPage(page) {
        loadOrders(page);
    }

    function sortBy(column) {
        if (currentSortBy === column) {
            currentSortDescending = !currentSortDescending;
        } else {
            currentSortBy = column;
            currentSortDescending = true;
        }
        loadOrders(1);
    }

    // Real-time filter with 300ms debounce
    document.getElementById('filterSearch').addEventListener('input', function() {
        debounce(() => loadOrders(1), 300);
    });

    document.getElementById('filterStatus').addEventListener('change', function() {
        loadOrders(1);
    });

    document.getElementById('filterPaymentStatus').addEventListener('change', function() {
        loadOrders(1);
    });

    document.getElementById('filterFromDate').addEventListener('change', function() {
        loadOrders(1);
    });

    document.getElementById('filterToDate').addEventListener('change', function() {
        loadOrders(1);
    });
</script>
}

@functions {
    string GetStatusDisplayName(OrderStatus orderStatus) => orderStatus switch
    {
        OrderStatus.Pending => "Chờ xử lý",
        OrderStatus.Processing => "Đang xử lý",
        OrderStatus.Shipped => "Đang giao",
        OrderStatus.Delivered => "Đã giao",
        OrderStatus.Cancelled => "Đã hủy",
        OrderStatus.Returned => "Trả hàng",
        _ => orderStatus.ToString()
    };

    string GetPaymentStatusDisplayName(PaymentStatus payStatus) => payStatus switch
    {
        PaymentStatus.Pending => "Chờ thanh toán",
        PaymentStatus.Paid => "Đã thanh toán",
        PaymentStatus.Refunded => "Đã hoàn tiền",
        _ => payStatus.ToString()
    };
}
