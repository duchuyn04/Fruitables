@model Fruitables.Models.Role
@{
    ViewData["Title"] = $"Chi tiết vai trò - {Model.Name}";
    Layout = "~/Areas/Admin/Views/Shared/_AdminDashboardLayout.cshtml";

    var permissions = ViewBag.Permissions as List<Fruitables.Models.Permission> ?? new List<Fruitables.Models.Permission>();
    var permissionsByModule = permissions.GroupBy(p => p.Module).OrderBy(g => g.Key).ToList();
}

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="@Url.Action("Index", "Role", new { area = "Admin" })" class="text-muted text-decoration-none mb-2 d-inline-block">
                <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
            </a>
            <h4 class="mb-1">Chi tiết vai trò</h4>
            <p class="text-muted mb-0">Thông tin chi tiết và quyền hạn của vai trò</p>
        </div>
        <div>
            @if (Model.IsActive)
            {
                <span class="badge bg-success fs-6">Hoạt động</span>
            }
            else
            {
                <span class="badge bg-danger fs-6">Vô hiệu hóa</span>
            }
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        @if (TempData["Success"] != null)
        {
            <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
                <div class="toast-header bg-success text-white">
                    <i class="fas fa-check-circle me-2"></i>
                    <strong class="me-auto">Thành công</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">@TempData["Success"]</div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
                <div class="toast-header bg-danger text-white">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    <strong class="me-auto">Lỗi</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">@TempData["Error"]</div>
            </div>
        }
    </div>

    <div class="row">
        <!-- Left Column -->
        <div class="col-lg-8">
            <!-- Role Info Card -->
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-user-tag me-2"></i>Thông tin vai trò</h5>
                    <div>
                        <a href="@Url.Action("Edit", "Role", new { area = "Admin", id = Model.Id })" class="btn btn-sm btn-warning">
                            <i class="fas fa-edit me-1"></i>Chỉnh sửa
                        </a>
                        <button type="button" class="btn btn-sm btn-danger" onclick="confirmDelete()">
                            <i class="fas fa-trash me-1"></i>Xóa
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="text-muted small">Tên vai trò</label>
                            <p class="mb-0 fw-semibold">@Model.Name</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted small">Trạng thái</label>
                            <p class="mb-0">
                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Vô hiệu hóa</span>
                                }
                            </p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted small">Ngày tạo</label>
                            <p class="mb-0">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted small">Cập nhật lần cuối</label>
                            <p class="mb-0">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="col-12">
                            <label class="text-muted small">Mô tả</label>
                            <p class="mb-0">
                                @if (!string.IsNullOrEmpty(Model.Description))
                                {
                                    @Model.Description
                                }
                                else
                                {
                                    <span class="text-muted">Không có mô tả</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Permissions Card -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-key me-2"></i>Quyền hạn 
                        <span class="badge bg-primary">@permissions.Count</span>
                    </h5>
                </div>
                <div class="card-body">
                    @if (permissions.Any())
                    {
                        @foreach (var moduleGroup in permissionsByModule)
                        {
                            <div class="mb-4">
                                <h6 class="fw-semibold text-primary mb-3">
                                    <i class="fas fa-folder me-2"></i>@moduleGroup.Key
                                    <span class="badge bg-secondary">@moduleGroup.Count()</span>
                                </h6>
                                <div class="row">
                                    @foreach (var permission in moduleGroup)
                                    {
                                        <div class="col-md-6 mb-2">
                                            <div class="d-flex align-items-start">
                                                <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                                                <div>
                                                    <div class="fw-semibold">@permission.Name</div>
                                                    @if (!string.IsNullOrEmpty(permission.Description))
                                                    {
                                                        <small class="text-muted">@permission.Description</small>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-key fa-3x text-muted mb-3"></i>
                            <p class="text-muted mb-0">Vai trò này chưa có quyền hạn nào</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Assign Permissions Partial -->
            @await Html.PartialAsync("_AssignPermissions", Model)
        </div>

        <!-- Right Column -->
        <div class="col-lg-4">
            <!-- Statistics Card -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-chart-bar me-2"></i>Thống kê</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                        <div>
                            <div class="text-muted small">Tổng quyền hạn</div>
                            <div class="fs-4 fw-bold text-primary">@permissions.Count</div>
                        </div>
                        <i class="fas fa-key fa-2x text-primary opacity-25"></i>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted small">Số module</div>
                            <div class="fs-4 fw-bold text-info">@permissionsByModule.Count</div>
                        </div>
                        <i class="fas fa-folder fa-2x text-info opacity-25"></i>
                    </div>
                </div>
            </div>

            <!-- Actions Card -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-cog me-2"></i>Thao tác</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="@Url.Action("Edit", "Role", new { area = "Admin", id = Model.Id })" class="btn btn-warning">
                            <i class="fas fa-edit me-2"></i>Chỉnh sửa vai trò
                        </a>
                        <button type="button" class="btn btn-danger" onclick="confirmDelete()">
                            <i class="fas fa-trash me-2"></i>Xóa vai trò
                        </button>
                        <a href="@Url.Action("Index", "Role", new { area = "Admin" })" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Quay lại danh sách
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle me-2"></i>Xác nhận xóa vai trò
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa vai trò <strong>@Model.Name</strong>?</p>
                <div class="alert alert-warning mb-0">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Lưu ý quan trọng:</strong>
                    <ul class="mb-0 mt-2">
                        <li>Không thể xóa vai trò đang được gán cho người dùng</li>
                        <li>Hành động này không thể hoàn tác</li>
                        <li>Tất cả quyền hạn được gán cho vai trò này sẽ bị xóa</li>
                    </ul>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form method="post" asp-action="Delete" asp-controller="Role" asp-area="Admin" asp-route-id="@Model.Id" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i>Xóa vai trò
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Confirm delete
    function confirmDelete() {
        const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
        modal.show();
    }

    // Initialize toasts
    document.addEventListener('DOMContentLoaded', function() {
        const toastElList = [].slice.call(document.querySelectorAll('.toast'));
        toastElList.map(function(toastEl) {
            return new bootstrap.Toast(toastEl);
        });
    });
</script>
}
