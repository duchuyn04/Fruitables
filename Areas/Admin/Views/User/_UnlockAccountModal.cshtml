@using Fruitables.Models

<!-- Unlock Account Modal -->
<div class="modal fade" id="unlockAccountModal" tabindex="-1" aria-labelledby="unlockAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="unlockAccountModalLabel">
                    <i class="fas fa-unlock me-2"></i>Mở khóa tài khoản
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="unlockAccountForm">
                    <input type="hidden" id="unlockCustomerId" name="CustomerId">

                    <!-- Customer Name Display -->
                    <div class="alert alert-info mb-3">
                        <i class="fas fa-user me-2"></i>
                        Bạn đang mở khóa tài khoản: <strong id="unlockCustomerName"></strong>
                    </div>

                    <!-- Permanent Lock Warning (hidden by default) -->
                    <div class="alert alert-danger d-none" id="permanentUnlockWarning">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <strong>Cảnh báo:</strong> Tài khoản này đang bị khóa <strong>vĩnh viễn</strong>. 
                        Việc mở khóa cần được xem xét kỹ lưỡng.
                    </div>

                    <!-- Abnormal History Warning (hidden by default) -->
                    <div class="alert alert-warning d-none" id="abnormalHistoryWarning">
                        <i class="fas fa-history me-2"></i>
                        <strong>Lưu ý:</strong> Tài khoản này có lịch sử bất thường 
                        (bị khóa/mở khóa nhiều hơn 3 lần trong 30 ngày gần đây).
                    </div>

                    <!-- Unlock Reason -->
                    <div class="mb-3">
                        <label for="unlockReason" class="form-label">
                            Lý do mở khóa <span class="text-danger">*</span>
                        </label>
                        <textarea class="form-control" id="unlockReason" name="Reason" rows="3" 
                                  minlength="10" required
                                  placeholder="Nhập lý do mở khóa tài khoản (tối thiểu 10 ký tự)"></textarea>
                        <div class="form-text">
                            <span id="unlockReasonCount">0</span>/10 ký tự (tối thiểu 10 ký tự)
                        </div>
                        <div class="invalid-feedback">Lý do mở khóa phải có ít nhất 10 ký tự</div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Hủy bỏ
                </button>
                <button type="button" class="btn btn-success" id="unlockAccountBtn" onclick="submitUnlockAccount()">
                    <i class="fas fa-unlock me-1"></i>Mở khóa tài khoản
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Unlock Confirmation Modal -->
<div class="modal fade" id="unlockConfirmModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle me-2"></i>Xác nhận mở khóa tài khoản
                </h5>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn mở khóa tài khoản này?</p>
                <div class="bg-light p-3 rounded">
                    <p class="mb-1"><strong>Khách hàng:</strong> <span id="confirmUnlockCustomerName"></span></p>
                    <p class="mb-0"><strong>Lý do mở khóa:</strong> <span id="confirmUnlockReason"></span></p>
                </div>
                
                <!-- Permanent Lock Double Confirmation (hidden by default) -->
                <div class="mt-3 d-none" id="permanentUnlockDoubleConfirm">
                    <div class="alert alert-danger mb-2">
                        <i class="fas fa-ban me-2"></i>
                        <strong>Tài khoản này bị khóa vĩnh viễn!</strong> Vui lòng xác nhận lần nữa.
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="permanentUnlockConfirmCheckbox">
                        <label class="form-check-label" for="permanentUnlockConfirmCheckbox">
                            Tôi xác nhận muốn mở khóa tài khoản bị khóa vĩnh viễn này
                        </label>
                    </div>
                </div>

                <!-- Abnormal History Confirmation (hidden by default) -->
                <div class="mt-3 d-none" id="abnormalHistoryConfirm">
                    <div class="alert alert-warning mb-2">
                        <i class="fas fa-history me-2"></i>
                        Tài khoản có lịch sử bất thường. Bạn có muốn tiếp tục?
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="abnormalHistoryConfirmCheckbox">
                        <label class="form-check-label" for="abnormalHistoryConfirmCheckbox">
                            Tôi xác nhận muốn mở khóa dù tài khoản có lịch sử bất thường
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="cancelUnlockConfirmation()">
                    <i class="fas fa-arrow-left me-1"></i>Quay lại
                </button>
                <button type="button" class="btn btn-success" id="confirmUnlockBtn" onclick="confirmUnlockAccount()">
                    <i class="fas fa-check me-1"></i>Xác nhận mở khóa
                </button>
            </div>
        </div>
    </div>
</div>
