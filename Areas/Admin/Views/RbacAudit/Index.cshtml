@model List<Fruitables.Models.RbacAuditLog>
@{
    ViewData["Title"] = "Nhật ký kiểm toán RBAC";
    Layout = "~/Areas/Admin/Views/Shared/_AdminDashboardLayout.cshtml";

    var entityType = ViewBag.EntityType as string;
    var entityId = ViewBag.EntityId as int?;
    var changedBy = ViewBag.ChangedBy as int?;
    var startDate = ViewBag.StartDate as string;
    var endDate = ViewBag.EndDate as string;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var totalCount = (int)(ViewBag.TotalCount ?? 0);
}

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1">Nhật ký kiểm toán RBAC</h4>
            <p class="text-muted mb-0">Tổng cộng <span id="totalCount">@totalCount</span> bản ghi</p>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        @if (TempData["Success"] != null)
        {
            <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
                <div class="toast-header bg-success text-white">
                    <i class="fas fa-check-circle me-2"></i>
                    <strong class="me-auto">Thành công</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">@TempData["Success"]</div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
                <div class="toast-header bg-danger text-white">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    <strong class="me-auto">Lỗi</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">@TempData["Error"]</div>
            </div>
        }
    </div>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <form id="filterForm" method="get">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Loại thực thể</label>
                        <select id="filterEntityType" name="entityType" class="form-select">
                            <option value="">Tất cả</option>
                            <option value="Role" selected="@(entityType == "Role")">Role</option>
                            <option value="Permission" selected="@(entityType == "Permission")">Permission</option>
                            <option value="UserRole" selected="@(entityType == "UserRole")">UserRole</option>
                            <option value="RolePermission" selected="@(entityType == "RolePermission")">RolePermission</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">ID thực thể</label>
                        <input type="number" id="filterEntityId" name="entityId" class="form-control" 
                               placeholder="ID..." value="@entityId">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">ID người thay đổi</label>
                        <input type="number" id="filterChangedBy" name="changedBy" class="form-control" 
                               placeholder="Admin ID..." value="@changedBy">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Từ ngày</label>
                        <input type="date" id="filterStartDate" name="startDate" class="form-control" 
                               value="@startDate">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Đến ngày</label>
                        <input type="date" id="filterEndDate" name="endDate" class="form-control" 
                               value="@endDate">
                    </div>
                    <div class="col-md-1 d-flex align-items-end">
                        <button type="button" id="clearFiltersBtn" class="btn btn-secondary w-100" title="Xóa bộ lọc">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Audit Logs Table -->
    <div class="card">
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 10%">ID</th>
                                <th style="width: 12%">Hành động</th>
                                <th style="width: 15%">Loại thực thể</th>
                                <th style="width: 8%">ID thực thể</th>
                                <th style="width: 15%">Người thay đổi</th>
                                <th style="width: 15%">Thời gian</th>
                                <th style="width: 25%">Chi tiết</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model)
                            {
                                <tr>
                                    <td class="align-middle">
                                        <span class="badge bg-secondary">#@log.Id</span>
                                    </td>
                                    <td class="align-middle">
                                        @{
                                            var actionBadgeClass = log.Action switch
                                            {
                                                "Create" => "bg-success",
                                                "Update" => "bg-info",
                                                "Delete" => "bg-danger",
                                                "Assign" => "bg-primary",
                                                "Revoke" => "bg-warning",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @actionBadgeClass">@log.Action</span>
                                    </td>
                                    <td class="align-middle">
                                        <span class="fw-semibold">@log.EntityType</span>
                                    </td>
                                    <td class="align-middle text-center">
                                        <code>@log.EntityId</code>
                                    </td>
                                    <td class="align-middle">
                                        @if (log.ChangedByAdmin != null)
                                        {
                                            <div>
                                                <i class="fas fa-user-shield me-1"></i>
                                                @log.ChangedByAdmin.Name
                                            </div>
                                            <small class="text-muted">ID: @log.ChangedByAdminId</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">ID: @log.ChangedByAdminId</span>
                                        }
                                    </td>
                                    <td class="align-middle">
                                        <div>@log.ChangedAt.ToString("dd/MM/yyyy")</div>
                                        <small class="text-muted">@log.ChangedAt.ToString("HH:mm:ss")</small>
                                    </td>
                                    <td class="align-middle">
                                        @if (!string.IsNullOrEmpty(log.OldValue) || !string.IsNullOrEmpty(log.NewValue))
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-info" 
                                                    data-log-id="@log.Id"
                                                    data-old-value="@Html.Raw(log.OldValue?.Replace("\"", "&quot;") ?? "")"
                                                    data-new-value="@Html.Raw(log.NewValue?.Replace("\"", "&quot;") ?? "")"
                                                    onclick="AuditLogFilter.showDetails(@log.Id, this.getAttribute('data-old-value'), this.getAttribute('data-new-value'))">
                                                <i class="fas fa-info-circle me-1"></i>Xem chi tiết
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (totalPages > 1)
                {
                    <div class="card-footer">
                        <nav>
                            <ul class="pagination pagination-sm mb-0 justify-content-center">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="javascript:void(0)" onclick="AuditLogFilter.loadPage(@(currentPage - 1))">
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                </li>

                                @for (int i = 1; i <= totalPages; i++)
                                {
                                    if (i == 1 || i == totalPages || (i >= currentPage - 2 && i <= currentPage + 2))
                                    {
                                        <li class="page-item @(i == currentPage ? "active" : "")">
                                            <a class="page-link" href="javascript:void(0)" onclick="AuditLogFilter.loadPage(@i)">@i</a>
                                        </li>
                                    }
                                    else if (i == currentPage - 3 || i == currentPage + 3)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link">...</span>
                                        </li>
                                    }
                                }

                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <a class="page-link" href="javascript:void(0)" onclick="AuditLogFilter.loadPage(@(currentPage + 1))">
                                        <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-clipboard-list fa-3x text-muted mb-3"></i>
                    <p class="text-muted">Không tìm thấy bản ghi nào</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Details Modal -->
<div class="modal fade" id="detailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">
                    <i class="fas fa-info-circle me-2"></i>Chi tiết thay đổi
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">Giá trị cũ:</h6>
                        <div class="border rounded p-3 bg-light">
                            <pre id="oldValueContent" class="mb-0" style="white-space: pre-wrap; word-wrap: break-word;"></pre>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">Giá trị mới:</h6>
                        <div class="border rounded p-3 bg-light">
                            <pre id="newValueContent" class="mb-0" style="white-space: pre-wrap; word-wrap: break-word;"></pre>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/auditLogFilter.js"></script>
}
