@{
    ViewData["Title"] = "Tạo vai trò mới";
    Layout = "~/Areas/Admin/Views/Shared/_AdminDashboardLayout.cshtml";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="mb-4">
        <a href="@Url.Action("Index", "Role", new { area = "Admin" })" class="text-muted text-decoration-none mb-2 d-inline-block">
            <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
        </a>
        <h4 class="mb-1">Tạo vai trò mới</h4>
        <p class="text-muted mb-0">Nhập thông tin vai trò mới</p>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        @if (TempData["Error"] != null)
        {
            <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
                <div class="toast-header bg-danger text-white">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    <strong class="me-auto">Lỗi</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">@TempData["Error"]</div>
            </div>
        }
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-user-tag me-2"></i>Thông tin vai trò</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="Create" asp-controller="Role" asp-area="Admin" id="createRoleForm">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-3">
                            <label for="name" class="form-label">
                                Tên vai trò <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control @(TempData["Error"] != null && TempData["Error"].ToString().Contains("tên") ? "is-invalid" : "")" 
                                   id="name" name="name" 
                                   placeholder="Ví dụ: Manager, Moderator..." required maxlength="100"
                                   value="@ViewBag.Name">
                            <div class="invalid-feedback" id="nameError">
                                @if (TempData["Error"] != null && TempData["Error"].ToString().Contains("tên"))
                                {
                                    @TempData["Error"]
                                }
                            </div>
                            <div class="form-text">Tên vai trò phải là duy nhất trong hệ thống</div>
                        </div>

                        <div class="mb-4">
                            <label for="description" class="form-label">Mô tả</label>
                            <textarea class="form-control" id="description" name="description" 
                                      rows="4" maxlength="500" 
                                      placeholder="Mô tả vai trò và trách nhiệm...">@ViewBag.Description</textarea>
                            <div class="form-text">Tối đa 500 ký tự</div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i>Tạo vai trò
                            </button>
                            <a href="@Url.Action("Index", "Role", new { area = "Admin" })" class="btn btn-secondary">
                                <i class="fas fa-times me-1"></i>Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Hướng dẫn</h5>
                </div>
                <div class="card-body">
                    <h6 class="fw-semibold mb-2">Tạo vai trò mới</h6>
                    <p class="small text-muted mb-3">
                        Vai trò được sử dụng để nhóm các quyền hạn và gán cho người dùng. 
                        Sau khi tạo vai trò, bạn có thể gán quyền hạn cho vai trò đó.
                    </p>

                    <h6 class="fw-semibold mb-2">Lưu ý</h6>
                    <ul class="small text-muted mb-0">
                        <li>Tên vai trò phải là duy nhất</li>
                        <li>Vai trò mới sẽ được kích hoạt mặc định</li>
                        <li>Bạn có thể gán quyền hạn sau khi tạo vai trò</li>
                        <li>Vai trò có thể được vô hiệu hóa thay vì xóa</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Initialize toasts
    document.addEventListener('DOMContentLoaded', function() {
        const toastElList = [].slice.call(document.querySelectorAll('.toast'));
        toastElList.map(function(toastEl) {
            return new bootstrap.Toast(toastEl);
        });
    });

    // Form validation with Bootstrap styles
    const form = document.getElementById('createRoleForm');
    const nameInput = document.getElementById('name');
    const nameError = document.getElementById('nameError');

    form.addEventListener('submit', function(e) {
        let isValid = true;
        
        // Reset validation states
        nameInput.classList.remove('is-invalid', 'is-valid');
        
        // Validate name
        const name = nameInput.value.trim();
        if (!name) {
            e.preventDefault();
            nameInput.classList.add('is-invalid');
            nameError.textContent = 'Tên vai trò không được để trống';
            isValid = false;
        } else if (name.length > 100) {
            e.preventDefault();
            nameInput.classList.add('is-invalid');
            nameError.textContent = 'Tên vai trò không được vượt quá 100 ký tự';
            isValid = false;
        } else {
            nameInput.classList.add('is-valid');
        }
        
        if (!isValid) {
            nameInput.focus();
        }
    });

    // Real-time validation
    nameInput.addEventListener('input', function() {
        const name = this.value.trim();
        if (name && name.length <= 100) {
            this.classList.remove('is-invalid');
            this.classList.add('is-valid');
        } else if (name.length > 100) {
            this.classList.remove('is-valid');
            this.classList.add('is-invalid');
            nameError.textContent = 'Tên vai trò không được vượt quá 100 ký tự';
        }
    });
</script>
}
