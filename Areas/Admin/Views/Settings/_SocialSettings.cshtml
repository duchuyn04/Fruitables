@model Fruitables.ViewModels.SocialSettingsViewModel

<form asp-action="SaveSocial" method="post">
    @Html.AntiForgeryToken()
    
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="fas fa-share-alt me-2"></i>Cài đặt mạng xã hội</h5>
        </div>
        <div class="card-body">
            <!-- Facebook -->
            <div class="mb-4">
                <label asp-for="Facebook" class="form-label">
                    <i class="fab fa-facebook text-primary me-1"></i>Facebook
                </label>
                <input asp-for="Facebook" class="form-control" placeholder="https://facebook.com/yourpage" />
                <span asp-validation-for="Facebook" class="text-danger"></span>
            </div>

            <!-- Twitter -->
            <div class="mb-4">
                <label asp-for="Twitter" class="form-label">
                    <i class="fab fa-twitter text-info me-1"></i>Twitter / X
                </label>
                <input asp-for="Twitter" class="form-control" placeholder="https://twitter.com/yourhandle" />
                <span asp-validation-for="Twitter" class="text-danger"></span>
            </div>

            <!-- Instagram -->
            <div class="mb-4">
                <label asp-for="Instagram" class="form-label">
                    <i class="fab fa-instagram text-danger me-1"></i>Instagram
                </label>
                <input asp-for="Instagram" class="form-control" placeholder="https://instagram.com/yourprofile" />
                <span asp-validation-for="Instagram" class="text-danger"></span>
            </div>

            <!-- Youtube -->
            <div class="mb-4">
                <label asp-for="Youtube" class="form-label">
                    <i class="fab fa-youtube text-danger me-1"></i>Youtube
                </label>
                <input asp-for="Youtube" class="form-control" placeholder="https://youtube.com/yourchannel" />
                <span asp-validation-for="Youtube" class="text-danger"></span>
            </div>

            <!-- LinkedIn -->
            <div class="mb-4">
                <label asp-for="LinkedIn" class="form-label">
                    <i class="fab fa-linkedin text-primary me-1"></i>LinkedIn
                </label>
                <input asp-for="LinkedIn" class="form-control" placeholder="https://linkedin.com/company/yourcompany" />
                <span asp-validation-for="LinkedIn" class="text-danger"></span>
            </div>

            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>
                Để trống các trường nếu bạn không muốn hiển thị liên kết mạng xã hội đó trên website.
            </div>
        </div>
        <div class="card-footer bg-light">
            <button type="submit" class="btn btn-success">
                <i class="fas fa-save me-1"></i>Lưu cài đặt
            </button>
        </div>
    </div>
</form>
