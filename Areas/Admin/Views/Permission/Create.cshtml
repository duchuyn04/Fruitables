@{
    ViewData["Title"] = "Tạo quyền hạn mới";
    Layout = "~/Areas/Admin/Views/Shared/_AdminDashboardLayout.cshtml";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="mb-4">
        <a href="@Url.Action("Index", "Permission", new { area = "Admin" })" class="text-muted text-decoration-none mb-2 d-inline-block">
            <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
        </a>
        <h4 class="mb-1">Tạo quyền hạn mới</h4>
        <p class="text-muted mb-0">Nhập thông tin quyền hạn mới</p>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        @if (TempData["Error"] != null)
        {
            <div class="toast show" role="alert" data-bs-autohide="true" data-bs-delay="5000">
                <div class="toast-header bg-danger text-white">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    <strong class="me-auto">Lỗi</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">@TempData["Error"]</div>
            </div>
        }
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-key me-2"></i>Thông tin quyền hạn</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="Create" asp-controller="Permission" asp-area="Admin" id="createPermissionForm">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-3">
                            <label for="module" class="form-label">
                                Module <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control @(TempData["Error"] != null && TempData["Error"].ToString().Contains("Module") ? "is-invalid" : "")" 
                                   id="module" name="module" 
                                   placeholder="Ví dụ: products, orders, users..." required maxlength="50"
                                   list="moduleList"
                                   value="@ViewBag.Module">
                            <datalist id="moduleList">
                                <option value="products"></option>
                                <option value="orders"></option>
                                <option value="users"></option>
                                <option value="reviews"></option>
                                <option value="settings"></option>
                                <option value="dashboard"></option>
                                <option value="system"></option>
                            </datalist>
                            <div class="invalid-feedback" id="moduleError">
                                @if (TempData["Error"] != null && TempData["Error"].ToString().Contains("Module"))
                                {
                                    @TempData["Error"]
                                }
                            </div>
                            <div class="form-text">Tên module nghiệp vụ (chữ thường, không dấu)</div>
                        </div>

                        <div class="mb-3">
                            <label for="action" class="form-label">
                                Action <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control" id="action" name="action" 
                                   placeholder="Ví dụ: view, create, update, delete..." required maxlength="50"
                                   value="@ViewBag.Action">
                            <div class="invalid-feedback" id="actionError"></div>
                            <div class="form-text">Hành động cụ thể (chữ thường, không dấu)</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Tên quyền hạn (tự động tạo)</label>
                            <input type="text" class="form-control @(TempData["Error"] != null && TempData["Error"].ToString().Contains("format") ? "is-invalid" : "")" 
                                   id="name" name="name" readonly>
                            <div class="invalid-feedback" id="nameError">
                                @if (TempData["Error"] != null && TempData["Error"].ToString().Contains("format"))
                                {
                                    @TempData["Error"]
                                }
                                else if (TempData["Error"] != null && TempData["Error"].ToString().Contains("already exists"))
                                {
                                    @TempData["Error"]
                                }
                            </div>
                            <div class="form-text">Format: module.action</div>
                        </div>

                        <div class="mb-4">
                            <label for="description" class="form-label">Mô tả</label>
                            <textarea class="form-control" id="description" name="description" 
                                      rows="4" maxlength="500" 
                                      placeholder="Mô tả quyền hạn và mục đích sử dụng...">@ViewBag.Description</textarea>
                            <div class="form-text">Tối đa 500 ký tự</div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i>Tạo quyền hạn
                            </button>
                            <a href="@Url.Action("Index", "Permission", new { area = "Admin" })" class="btn btn-secondary">
                                <i class="fas fa-times me-1"></i>Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Hướng dẫn</h5>
                </div>
                <div class="card-body">
                    <h6 class="fw-semibold mb-2">Tạo quyền hạn mới</h6>
                    <p class="small text-muted mb-3">
                        Quyền hạn được sử dụng để kiểm soát truy cập vào các chức năng cụ thể trong hệ thống. 
                        Quyền hạn được gán cho vai trò, và vai trò được gán cho người dùng.
                    </p>

                    <h6 class="fw-semibold mb-2">Format tên quyền hạn</h6>
                    <p class="small text-muted mb-3">
                        Tên quyền hạn phải theo format <code>module.action</code>:
                    </p>
                    <ul class="small text-muted mb-3">
                        <li><code>products.view</code> - Xem sản phẩm</li>
                        <li><code>products.create</code> - Tạo sản phẩm</li>
                        <li><code>orders.update_status</code> - Cập nhật trạng thái đơn hàng</li>
                        <li><code>users.lock</code> - Khóa tài khoản người dùng</li>
                    </ul>

                    <h6 class="fw-semibold mb-2">Lưu ý</h6>
                    <ul class="small text-muted mb-0">
                        <li>Tên quyền hạn phải là duy nhất</li>
                        <li>Sử dụng chữ thường, không dấu</li>
                        <li>Module và action phân tách bởi dấu chấm</li>
                        <li>Có thể sử dụng dấu gạch dưới trong action</li>
                    </ul>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-cube me-2"></i>Modules phổ biến</h5>
                </div>
                <div class="card-body">
                    <ul class="small mb-0">
                        <li><strong>products</strong> - Quản lý sản phẩm</li>
                        <li><strong>orders</strong> - Quản lý đơn hàng</li>
                        <li><strong>users</strong> - Quản lý người dùng</li>
                        <li><strong>reviews</strong> - Quản lý đánh giá</li>
                        <li><strong>settings</strong> - Cài đặt hệ thống</li>
                        <li><strong>dashboard</strong> - Dashboard quản trị</li>
                        <li><strong>system</strong> - Quản lý hệ thống</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Initialize toasts
    document.addEventListener('DOMContentLoaded', function() {
        const toastElList = [].slice.call(document.querySelectorAll('.toast'));
        toastElList.map(function(toastEl) {
            return new bootstrap.Toast(toastEl);
        });
    });

    // Auto-generate permission name from module and action
    function updatePermissionName() {
        const module = document.getElementById('module').value.trim().toLowerCase();
        const action = document.getElementById('action').value.trim().toLowerCase();
        
        if (module && action) {
            document.getElementById('name').value = `${module}.${action}`;
        } else {
            document.getElementById('name').value = '';
        }
    }

    document.getElementById('module').addEventListener('input', updatePermissionName);
    document.getElementById('action').addEventListener('input', updatePermissionName);

    // Form validation with Bootstrap styles
    const form = document.getElementById('createPermissionForm');
    const moduleInput = document.getElementById('module');
    const actionInput = document.getElementById('action');
    const nameInput = document.getElementById('name');
    const moduleError = document.getElementById('moduleError');
    const actionError = document.getElementById('actionError');
    const nameError = document.getElementById('nameError');

    // Validate format (lowercase, no special chars except underscore)
    const validFormat = /^[a-z0-9_]+$/;

    form.addEventListener('submit', function(e) {
        let isValid = true;
        
        // Reset validation states
        moduleInput.classList.remove('is-invalid', 'is-valid');
        actionInput.classList.remove('is-invalid', 'is-valid');
        nameInput.classList.remove('is-invalid', 'is-valid');
        
        // Validate module
        const module = moduleInput.value.trim();
        if (!module) {
            e.preventDefault();
            moduleInput.classList.add('is-invalid');
            moduleError.textContent = 'Module không được để trống';
            isValid = false;
        } else if (!validFormat.test(module)) {
            e.preventDefault();
            moduleInput.classList.add('is-invalid');
            moduleError.textContent = 'Module chỉ được chứa chữ thường, số và dấu gạch dưới';
            isValid = false;
        } else {
            moduleInput.classList.add('is-valid');
        }
        
        // Validate action
        const action = actionInput.value.trim();
        if (!action) {
            e.preventDefault();
            actionInput.classList.add('is-invalid');
            actionError.textContent = 'Action không được để trống';
            isValid = false;
        } else if (!validFormat.test(action)) {
            e.preventDefault();
            actionInput.classList.add('is-invalid');
            actionError.textContent = 'Action chỉ được chứa chữ thường, số và dấu gạch dưới';
            isValid = false;
        } else {
            actionInput.classList.add('is-valid');
        }
        
        // Validate name format
        const name = nameInput.value.trim();
        if (name && !name.includes('.')) {
            e.preventDefault();
            nameInput.classList.add('is-invalid');
            nameError.textContent = 'Tên quyền hạn phải theo format module.action';
            isValid = false;
        } else if (name) {
            nameInput.classList.add('is-valid');
        }
        
        if (!isValid) {
            if (moduleInput.classList.contains('is-invalid')) {
                moduleInput.focus();
            } else if (actionInput.classList.contains('is-invalid')) {
                actionInput.focus();
            }
        }
    });

    // Real-time validation for module
    moduleInput.addEventListener('input', function() {
        const module = this.value.trim();
        if (module && validFormat.test(module)) {
            this.classList.remove('is-invalid');
            this.classList.add('is-valid');
        } else if (module && !validFormat.test(module)) {
            this.classList.remove('is-valid');
            this.classList.add('is-invalid');
            moduleError.textContent = 'Module chỉ được chứa chữ thường, số và dấu gạch dưới';
        }
        updatePermissionName();
    });

    // Real-time validation for action
    actionInput.addEventListener('input', function() {
        const action = this.value.trim();
        if (action && validFormat.test(action)) {
            this.classList.remove('is-invalid');
            this.classList.add('is-valid');
        } else if (action && !validFormat.test(action)) {
            this.classList.remove('is-valid');
            this.classList.add('is-invalid');
            actionError.textContent = 'Action chỉ được chứa chữ thường, số và dấu gạch dưới';
        }
        updatePermissionName();
    });
</script>
}
