@model Fruitables.Models.Role
@{
    var allPermissions = ViewBag.AllPermissions as List<Fruitables.Models.Permission> ?? new List<Fruitables.Models.Permission>();
    var rolePermissions = ViewBag.RolePermissions as List<Fruitables.Models.Permission> ?? new List<Fruitables.Models.Permission>();
    var rolePermissionIds = rolePermissions.Select(p => p.Id).ToHashSet();
    var permissionsByModule = allPermissions.GroupBy(p => p.Module).OrderBy(g => g.Key).ToList();
}

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="fas fa-key me-2"></i>Gán quyền hạn cho vai trò
        </h5>
    </div>
    <div class="card-body">
        @if (permissionsByModule.Any())
        {
            <form id="assignPermissionsForm" method="post" asp-action="AssignPermissions" asp-controller="Role" asp-area="Admin" asp-route-id="@Model.Id">
                @Html.AntiForgeryToken()
                
                <!-- Select All/None Controls -->
                <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                    <div>
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="selectAllPermissions()">
                            <i class="fas fa-check-square me-1"></i>Chọn tất cả
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="deselectAllPermissions()">
                            <i class="fas fa-square me-1"></i>Bỏ chọn tất cả
                        </button>
                    </div>
                    <div>
                        <span class="text-muted">
                            <span id="selectedCount">@rolePermissionIds.Count</span> / @allPermissions.Count quyền hạn được chọn
                        </span>
                    </div>
                </div>

                <!-- Permissions Grouped by Module -->
                @foreach (var moduleGroup in permissionsByModule)
                {
                    <div class="module-group mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-semibold text-primary mb-0">
                                <i class="fas fa-folder me-2"></i>@moduleGroup.Key
                                <span class="badge bg-secondary">@moduleGroup.Count()</span>
                            </h6>
                            <div>
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="selectModulePermissions('@moduleGroup.Key')">
                                    <i class="fas fa-check-square me-1"></i>Chọn module
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="deselectModulePermissions('@moduleGroup.Key')">
                                    <i class="fas fa-square me-1"></i>Bỏ chọn
                                </button>
                            </div>
                        </div>
                        
                        <div class="row g-2 ms-3">
                            @foreach (var permission in moduleGroup.OrderBy(p => p.Name))
                            {
                                <div class="col-md-6">
                                    <div class="form-check">
                                        <input class="form-check-input permission-checkbox" 
                                               type="checkbox" 
                                               name="permissionIds" 
                                               value="@permission.Id" 
                                               id="permission_@permission.Id"
                                               data-module="@moduleGroup.Key"
                                               @(rolePermissionIds.Contains(permission.Id) ? "checked" : "")
                                               onchange="updateSelectedCount()">
                                        <label class="form-check-label" for="permission_@permission.Id">
                                            <span class="fw-semibold">@permission.Name</span>
                                            @if (!string.IsNullOrEmpty(permission.Description))
                                            {
                                                <br />
                                                <small class="text-muted">@permission.Description</small>
                                            }
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Submit Button -->
                <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                    <button type="button" class="btn btn-secondary" onclick="resetForm()">
                        <i class="fas fa-undo me-1"></i>Đặt lại
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Lưu thay đổi
                    </button>
                </div>
            </form>
        }
        else
        {
            <div class="text-center py-4">
                <i class="fas fa-key fa-3x text-muted mb-3"></i>
                <p class="text-muted mb-0">Không có quyền hạn nào trong hệ thống</p>
                <a href="@Url.Action("Create", "Permission", new { area = "Admin" })" class="btn btn-sm btn-primary mt-3">
                    <i class="fas fa-plus me-1"></i>Tạo quyền hạn mới
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    // Store initial state for reset
    const initialState = new Set();
    document.querySelectorAll('.permission-checkbox:checked').forEach(cb => {
        initialState.add(cb.value);
    });

    // Update selected count
    function updateSelectedCount() {
        const count = document.querySelectorAll('.permission-checkbox:checked').length;
        document.getElementById('selectedCount').textContent = count;
    }

    // Select all permissions
    function selectAllPermissions() {
        document.querySelectorAll('.permission-checkbox').forEach(cb => {
            cb.checked = true;
        });
        updateSelectedCount();
    }

    // Deselect all permissions
    function deselectAllPermissions() {
        document.querySelectorAll('.permission-checkbox').forEach(cb => {
            cb.checked = false;
        });
        updateSelectedCount();
    }

    // Select all permissions in a module
    function selectModulePermissions(module) {
        document.querySelectorAll(`.permission-checkbox[data-module="${module}"]`).forEach(cb => {
            cb.checked = true;
        });
        updateSelectedCount();
    }

    // Deselect all permissions in a module
    function deselectModulePermissions(module) {
        document.querySelectorAll(`.permission-checkbox[data-module="${module}"]`).forEach(cb => {
            cb.checked = false;
        });
        updateSelectedCount();
    }

    // Reset form to initial state
    function resetForm() {
        document.querySelectorAll('.permission-checkbox').forEach(cb => {
            cb.checked = initialState.has(cb.value);
        });
        updateSelectedCount();
    }

    // Form submission with loading state
    document.getElementById('assignPermissionsForm')?.addEventListener('submit', function(e) {
        const submitBtn = this.querySelector('button[type="submit"]');
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Đang lưu...';
    });
</script>
}
